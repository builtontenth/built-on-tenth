---
import Layout from '../layouts/Layout.astro';
interface Props {
  toolNumber: string;
  toolName: string;
  slug: string;
  headline: string;
  subheadline: string;
  metaDescription: string;
  toolCount?: string;
  showCrossTool?: boolean;
}
const {
  toolName,
  slug,
  headline,
  subheadline,
  metaDescription,
  showCrossTool = false,
} = Astro.props;
const toolImageMap = {
  'phone-calculator': '/images/brand/core/tool-phone-calculator.png',
  'estimate-follow-up': '/images/brand/core/tool-estimate-follow-up.png',
  'agency-report-card': '/images/brand/core/tool-agency-report-card.png',
  'revenue-per-tech': '/images/brand/core/tool-revenue-per-tech.png',
  'marketing-calculator': '/images/brand/core/tool-marketing-calculator.png',
  'gbp-scorecard': '/images/brand/core/tool-gbp-scorecard.png',
  'website-audit': '/images/brand/core/tool-website-audit.png',
};
const toolHeroImage = toolImageMap[slug as keyof typeof toolImageMap] ?? null;
const toolSeoTopicMap = {
  'phone-calculator': 'Missed Calls and Lost Revenue',
  'estimate-follow-up': 'Estimate Follow-Up and Unbooked Revenue',
  'agency-report-card': 'Agency Accountability and Booked-Job Reporting',
  'revenue-per-tech': 'Revenue Per Technician Benchmarks',
  'marketing-calculator': 'Marketing Cost Per Booked Job',
  'gbp-scorecard': 'Google Business Profile Map Pack Strength',
  'website-audit': 'Website Conversion and Call Friction',
} as const;
const toolContextMap = {
  'phone-calculator': {
    title: 'Missed calls create a revenue gap before better marketing can help.',
    body: 'Use this to turn answer rate and booking rate into a hard dollar number so you can see whether the leak is operational, not lead volume.',
    bullets: [
      'How much revenue missed calls are costing each month',
      'Whether answer rate is the real bottleneck',
      'What closing the response gap could recover',
    ],
  },
  'estimate-follow-up': {
    title: 'Quoted work often dies because nobody keeps the conversation alive.',
    body: 'This tool shows how much booked revenue disappears after the estimate goes out, so you can see whether follow-up is a bigger leak than lead generation.',
    bullets: [
      'How much estimate value is going cold',
      'What stronger follow-up could recover',
      'Whether this gap is large enough to prioritize now',
    ],
  },
  'agency-report-card': {
    title: 'Bad reporting hides the real cost of weak marketing decisions.',
    body: 'Use this scorecard to see whether your HVAC marketing reporting is showing numbers that help you make decisions or just numbers that keep you calm.',
    bullets: [
      'Whether your reporting matches booked-job reality',
      'Where accountability is missing',
      'How much blind spend risk may be hiding underneath',
    ],
  },
  'revenue-per-tech': {
    title: 'Revenue per tech shows whether your capacity is producing enough output.',
    body: 'This HVAC benchmark helps you see if the gap is likely coming from weak demand flow, weak booking, or underperforming operational throughput.',
    bullets: [
      'How your revenue per tech compares to benchmark',
      'What the annual team gap looks like',
      'Whether utilization is weaker than it should be',
    ],
  },
  'marketing-calculator': {
    title: 'Lead counts are noisy. Cost per booked job is what tells the truth.',
    body: 'Use this to translate HVAC spend into booked-job economics so you can see whether your current channel mix is efficient or quietly expensive.',
    bullets: [
      'Your true cost per booked job',
      'How far you are from top benchmark ranges',
      'Whether spend or conversion is the bigger issue',
    ],
  },
  'gbp-scorecard': {
    title: 'Local visibility is often lost through small profile gaps that compound.',
    body: 'This scorecard shows whether your HVAC Google Business Profile is strong enough to compete in the map pack or quietly giving away calls.',
    bullets: [
      'How strong your profile is vs common benchmark factors',
      'Which profile sections are weakening visibility',
      'Why stronger competitors are easier to trust at a glance',
    ],
  },
  'website-audit': {
    title: 'A website can look fine and still leak trust, speed, and calls.',
    body: 'Use this quick review to spot whether your HVAC site is creating friction before the homeowner ever picks up the phone.',
    bullets: [
      'Where your site is leaking conversion',
      'Whether trust and speed issues are visible',
      'How much stronger the next layer of analysis should be',
    ],
  },
} as const;
const toolContext = toolContextMap[slug as keyof typeof toolContextMap];
const toolSeoTopic = toolSeoTopicMap[slug as keyof typeof toolSeoTopicMap];
---
<Layout title={`${toolName} | HVAC Calculator for ${toolSeoTopic} | Built on Tenth`} description={metaDescription} active="tools">


<div class={`tool-page tool-page--${slug}`}>

  <!-- Hero -->
  <div class="tool-hero">
    {toolHeroImage && <img src={toolHeroImage} alt="" class="tool-hero-bg" loading="eager" decoding="async" aria-hidden="true" />}
    <div class="tool-hero-overlay"></div>
    <div class="tool-hero-inner">
      <a href="/tools" class="tool-back-link">Back to HVAC calculators</a>
      <h1 set:html={headline}></h1>
      <p class="tool-hero-sub">{subheadline}</p>
    </div>
  </div>

  <!-- Main tool slot -->
  <div class="tool-slot-wrap">
    <div class="tool-stage">
      <section class="tool-context-block">
        <h2>{toolContext?.title}</h2>
        <p>{toolContext?.body}</p>
        <ul class="tool-context-list">
          {toolContext?.bullets.map((item) => <li>{item}</li>)}
        </ul>
      </section>
      <div class="tool-workspace">
        <slot name="tool-body" />
      </div>
    </div>
  </div>

  <div class="tool-upgrade-wrap">
    <div class="cta-card cta-card--report cta-card--tool-upgrade">
      <div class="cta-card__inner">
        <h2 class="cta-card__title">This tool shows one leak. The report shows the <em>full local market picture.</em></h2>
        <p class="cta-card__body">The HVAC Local Market Report shows who is outranking you locally, what they are doing differently, and what that gap is likely costing you in missed calls.</p>
        <div class="cta-card__actions">
          <a href={`/report?source=${slug}`} class="btn btn--primary">Request your report</a>
        </div>
      </div>
    </div>
  </div>

</div>
</Layout>

<script is:inline>
  const initToolReveal = () => {
    document.querySelectorAll('.tool-layout').forEach((layout) => {
      const resultPanel = layout.querySelector('.result-panel');
      const resultSection = layout.querySelector('.result-section');
      if (!resultPanel || !resultSection) return;

      const syncReadyState = () => {
        const hasResults = resultSection.classList.contains('show');
        resultPanel.classList.toggle('is-ready', hasResults);
      };

      syncReadyState();
      const observer = new MutationObserver(syncReadyState);
      observer.observe(resultSection, { attributes: true, attributeFilter: ['class'] });
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initToolReveal, { once: true });
  } else {
    initToolReveal();
  }
</script>
