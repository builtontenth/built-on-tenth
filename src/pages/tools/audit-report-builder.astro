<script>
  const form = document.getElementById('audit-form');
  const exportBtn = document.getElementById('exportPdf');
  const resetBtn = document.getElementById('resetBuilder');

  const binds = [
    ['companyName', 'reportTitle', (v) => `${v || 'Company'} Revenue Leak Audit`],
    ['trade', 'reportTrade'],
    ['location', 'reportLocation'],
    ['annualRevenue', 'reportRevenue'],
    ['monthlySpend', 'reportFooterTag', (v) => `Monthly spend: ${v || '$0'}`],
    ['summaryHeadline', 'reportSummaryHeadline'],
    ['summaryBody', 'reportSummaryBody'],
    ['impactTotal', 'reportImpactTotal'],
    ['impactNote', 'reportImpactNote'],
    ['impact1Label', 'reportImpact1Label'],
    ['impact1Value', 'reportImpact1Value'],
    ['impact2Label', 'reportImpact2Label'],
    ['impact2Value', 'reportImpact2Value'],
    ['impact3Label', 'reportImpact3Label'],
    ['impact3Value', 'reportImpact3Value'],
    ['impact4Label', 'reportImpact4Label'],
    ['impact4Value', 'reportImpact4Value'],
    ['competitor1', 'reportCompetitor1'],
    ['competitor1Note', 'reportCompetitor1Note'],
    ['competitor2', 'reportCompetitor2'],
    ['competitor2Note', 'reportCompetitor2Note'],
    ['competitor3', 'reportCompetitor3'],
    ['competitor3Note', 'reportCompetitor3Note'],
    ['action1', 'reportAction1'],
    ['action2', 'reportAction2'],
    ['action3', 'reportAction3'],
    ['action4', 'reportAction4'],
    ['action5', 'reportAction5'],
    ['proof1Caption', 'reportProof1Caption'],
    ['proof2Caption', 'reportProof2Caption'],
    ['proof3Caption', 'reportProof3Caption'],
  ];

  const scoreMap = [
    ['scoreGbp', 'reportScoreGbpValue', 'reportScoreGbpBar'],
    ['scoreWebsite', 'reportScoreWebsiteValue', 'reportScoreWebsiteBar'],
    ['scorePhone', 'reportScorePhoneValue', 'reportScorePhoneBar'],
    ['scoreCompetition', 'reportScoreCompetitionValue', 'reportScoreCompetitionBar'],
  ];

  const impactMap = [
    ['impact1Value', 'reportImpact1Bar'],
    ['impact2Value', 'reportImpact2Bar'],
    ['impact3Value', 'reportImpact3Bar'],
    ['impact4Value', 'reportImpact4Bar'],
  ];

  function formatDateLabel(value) {
    if (!value) return '';
    const date = new Date(`${value}T00:00:00`);
    if (Number.isNaN(date.getTime())) return value;
    return new Intl.DateTimeFormat('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    }).format(date);
  }

  function parseMoney(value) {
    const clean = String(value || '').replace(/[^0-9.]/g, '');
    return Number(clean || 0);
  }

  function setHtmlText(id, value) {
    const el = document.getElementById(id);
    if (!el) return;
    el.innerHTML = String(value || '').replaceAll('\n', '<br>');
  }

  function updateBindings() {
    binds.forEach(([inputId, targetId, formatter]) => {
      const input = document.getElementById(inputId);
      if (!input) return;
      const value = formatter ? formatter(input.value) : input.value;
      setHtmlText(targetId, value);
    });

    const auditDate = document.getElementById('auditDate');
    if (auditDate) {
      setHtmlText('reportDate', formatDateLabel(auditDate.value));
    }

    scoreMap.forEach(([inputId, valueId, barId]) => {
      const input = document.getElementById(inputId);
      const valueEl = document.getElementById(valueId);
      const barEl = document.getElementById(barId);
      if (!input || !valueEl || !barEl) return;
      const score = Math.max(0, Math.min(10, Number(input.value || 0)));
      valueEl.textContent = `${score}/10`;
      barEl.style.width = `${score * 10}%`;
      barEl.style.background = score >= 8 ? 'var(--pos)' : score >= 6 ? 'var(--teal)' : score >= 4 ? '#C9A035' : 'var(--neg)';
    });

    const impactValues = impactMap.map(([inputId]) => parseMoney(document.getElementById(inputId)?.value));
    const maxImpact = Math.max(...impactValues, 1);
    impactMap.forEach(([inputId, barId], index) => {
      const barEl = document.getElementById(barId);
      if (!barEl) return;
      const value = impactValues[index];
      barEl.style.width = `${(value / maxImpact) * 100}%`;
    });
  }

  function attachImageInput(fileInputId, targetId) {
    const input = document.getElementById(fileInputId);
    const target = document.getElementById(targetId);
    if (!input || !target) return;
    input.addEventListener('change', () => {
      const file = input.files && input.files[0];
      if (!file) {
        target.innerHTML = 'Screenshot';
        return;
      }
      const reader = new FileReader();
      reader.onload = () => {
        target.innerHTML = `<img src="${reader.result}" alt="Audit proof screenshot" />`;
      };
      reader.readAsDataURL(file);
    });
  }

  exportBtn?.addEventListener('click', () => {
    updateBindings();
    document.body.classList.add('print-shell');
    setTimeout(() => {
      window.print();
      setTimeout(() => {
        document.body.classList.remove('print-shell');
      }, 300);
    }, 80);
  });

  resetBtn?.addEventListener('click', () => {
    form?.reset();
    document.getElementById('trade').value = 'HVAC';
    document.getElementById('auditDate').value = '2026-03-20';
    document.getElementById('companyName').value = 'Apex Heating & Air';
    document.getElementById('location').value = 'Atlanta, Georgia';
    document.getElementById('annualRevenue').value = '$2.3M';
    document.getElementById('monthlySpend').value = '$11,400';
    document.getElementById('scoreGbp').value = '6';
    document.getElementById('scoreWebsite').value = '5';
    document.getElementById('scorePhone').value = '4';
    document.getElementById('scoreCompetition').value = '5';
    document.getElementById('summaryHeadline').value = '$247,000 in annual leakage identified';
    document.getElementById('summaryBody').value = 'The biggest leaks are missed calls, stalled review velocity, weak above-the-fold phone placement, and no estimate follow-up system. None of these require more ad spend. They require better measurement and tighter office systems.';
    document.getElementById('impactTotal').value = '$247,000';
    document.getElementById('impactNote').value = 'Across the four highest-confidence gaps identified in public and manual review.';
    document.getElementById('impact1Label').value = 'Missed calls';
    document.getElementById('impact1Value').value = '$121,000';
    document.getElementById('impact2Label').value = 'Review velocity gap';
    document.getElementById('impact2Value').value = '$64,000';
    document.getElementById('impact3Label').value = 'Estimate follow-up';
    document.getElementById('impact3Value').value = '$42,000';
    document.getElementById('impact4Label').value = 'Mobile conversion friction';
    document.getElementById('impact4Value').value = '$20,000';
    document.getElementById('competitor1').value = 'Northside Comfort';
    document.getElementById('competitor1Note').value = '11 reviews in 30 days · stronger map pack visibility';
    document.getElementById('competitor2').value = 'Comfort First Heating';
    document.getElementById('competitor2Note').value = 'Phone number above fold · faster mobile experience';
    document.getElementById('competitor3').value = 'Premier Air Experts';
    document.getElementById('competitor3Note').value = 'LSAs active · stronger trust stack on homepage';
    document.getElementById('action1').value = 'Put answer rate on a daily dashboard and assign ownership when it drops below 88%.';
    document.getElementById('action2').value = 'Launch a job-close review ask process that targets 8 new Google reviews per month.';
    document.getElementById('action3').value = 'Move the primary phone CTA above the fold on mobile and tighten the hero trust stack.';
    document.getElementById('action4').value = 'Build a 3-touch estimate follow-up sequence owned by the front desk, not estimators.';
    document.getElementById('action5').value = 'Reallocate budget only after phone and review systems are fixed so more spend is not wasted.';
    document.getElementById('proof1Caption').value = 'Google Business Profile review velocity vs. top competitor';
    document.getElementById('proof2Caption').value = 'Homepage mobile hero with weak phone visibility';
    document.getElementById('proof3Caption').value = 'Competitor LSA presence and ad coverage';
    ['reportProof1Image', 'reportProof2Image', 'reportProof3Image'].forEach((id) => {
      const target = document.getElementById(id);
      if (target) target.innerHTML = 'Screenshot';
    });
    ['proof1File', 'proof2File', 'proof3File'].forEach((id) => {
      const input = document.getElementById(id);
      if (input) input.value = '';
    });
    updateBindings();
  });

  form?.addEventListener('input', updateBindings);
  form?.addEventListener('change', updateBindings);

  attachImageInput('proof1File', 'reportProof1Image');
  attachImageInput('proof2File', 'reportProof2Image');
  attachImageInput('proof3File', 'reportProof3Image');

  updateBindings();
</script>

