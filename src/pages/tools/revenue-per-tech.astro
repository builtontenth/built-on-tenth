---
import ToolShareResult from '../../components/ToolShareResult.astro';
import ToolLayout from '../../layouts/ToolLayout.astro';

const suiteTools = [
  { num: '01', name: 'Phone Revenue', href: '/tools/phone-calculator' },
  { num: '02', name: 'Estimate Follow-Up', href: '/tools/estimate-follow-up' },
  { num: '03', name: 'Agency Report Card', href: '/tools/agency-report-card' },
  { num: '05', name: 'Marketing Cost', href: '/tools/marketing-calculator' },
  { num: '06', name: 'GBP Scorecard', href: '/tools/gbp-scorecard' },
  { num: '07', name: 'Website Conversion', href: '/tools/website-audit' },
];
---
<ToolLayout
  toolNumber="04"
  toolCount="07"
  toolName="Revenue Per Technician"
  slug="revenue-per-tech"
  showCrossTool={false}
  headline="How Much Revenue Is Each of Your Techs<br><em>Actually Producing?</em>"
  subheadline="Most HVAC owners track total revenue. Far fewer track revenue per tech - the number that shows whether your field team is running at capacity or leaving booked work on the table. Enter your numbers and see where your team stands against HVAC benchmark ranges."
  metaDescription="HVAC revenue per technician benchmarker. Compare annual revenue per tech against HVAC benchmark ranges and see the size of your team output gap."
>


<div class="tool-layout" slot="tool-body">
  <div class="input-panel">
    <div class="ip-header">
      <span class="ip-title">Per-Tech Revenue Inputs</span>
      <span class="ip-micro">Benchmarked against HVAC field-team output ranges</span>
    </div>
    <div class="ip-body">
      <div class="field">
        <div class="field-label">
          <span>Number of field technicians</span>
          <span class="field-hint">Techs who run jobs, not office staff</span>
        </div>
        <input type="number" class="field-input" id="tech-count" min="1" />
      </div>

      <div class="field">
        <div class="field-label">
          <span>Annual revenue</span>
          <span class="field-hint">Last full year or trailing 12 months</span>
        </div>
        <div class="prefix-wrap">
          <span class="prefix">$</span>
          <input type="number" class="field-input" id="annual-revenue" min="0" />
        </div>
        <div class="benchmark-hint">
          <span>HVAC benchmark:</span>
          <span class="benchmark-value" id="benchmark-hint">HVAC average: $380,000 per tech</span>
        </div>
      </div>

      <button class="calc-btn" id="calc-btn">Benchmark My Team</button>
    </div>
  </div>

  <div class="result-panel">
    <div class="rp-header">
      <span class="rp-title">HVAC Team Output Snapshot</span>
      <span class="rp-status status-wait" id="rp-status">Waiting for your numbers</span>
    </div>
    <div class="rp-body">
      <div class="empty-state" id="empty-state">
        <div class="empty-icon">04</div>
        <p class="empty-text"><strong>Total revenue can hide an HVAC team output problem.</strong><br /><br />Revenue per tech shows whether your field team is producing at benchmark or leaving booked work, ticket value, or capacity on the table.</p>
      </div>

      <div class="result-section" id="results">
        <div class="main-result">
          <div class="main-label">Your revenue per technician</div>
          <div class="main-value" id="revenue-per-tech">$0</div>
          <div class="main-sub" id="tier-label">Below benchmark</div>
        </div>

        <div class="benchmark-wrap">
          <div class="benchmark-title">HVAC benchmark comparison</div>
          <div class="benchmark-track">
            <div class="benchmark-point ref benchmark-point--low" id="point-low"></div>
            <div class="benchmark-point ref benchmark-point--average" id="point-average"></div>
            <div class="benchmark-point ref benchmark-point--top25" id="point-top25"></div>
            <div class="benchmark-point ref benchmark-point--top10" id="point-top10"></div>
            <div class="benchmark-point user benchmark-point--origin" id="point-user"></div>
          </div>
          <div class="benchmark-labels" id="benchmark-labels">
            <span>Low end<br />$0</span>
            <span>Industry avg<br />$0</span>
            <span>Top 25%<br />$0</span>
            <span>Top 10%<br />$0</span>
          </div>
        </div>

        <div class="gap-cards" id="gap-cards"></div>
        <div class="note-box" id="note-box" hidden></div>

        <p class="psych-line">Revenue per tech is one of the fastest ways to see whether your HVAC business has a demand problem, an operational bottleneck, or both.</p>
        <p class="consequence-line" id="consequence-line">That gap across your team shows how much room there is between where you are and what your market will support.</p>

        <a href="/report?source=revenue-per-tech" class="btn btn--primary tool-cta">
          <span class="tool-cta-title">Request your report</span>
          <span class="tool-cta-copy">This benchmark shows one operational gap. The full report shows whether calls, visibility, or process issues are the bigger constraint.</span>
        </a>
        <p class="cta-note">Benchmarking helps. The full report shows whether local visibility, review strength, booking rate, or average ticket is the bigger driver behind the gap.</p>

        <ToolShareResult sectionId="share-section" profile="mixed" />

        <div class="result-rail">
          <div class="rail-title">Continue your diagnosis</div>
          <div class="rail-grid">
            {suiteTools.map((tool) => (
              <a href={tool.href} class="rail-link">
                <span class="rail-num">{tool.num}</span>
                <span class="rail-name">{tool.name}</span>
              </a>
            ))}
          </div>
          <a href="/report?source=revenue-per-tech" class="full-picture">
            <span class="full-picture-label">Next step</span>
            <span class="full-picture-title">HVAC Local Market Report</span>
          <span class="full-picture-copy">See whether local visibility and competitor strength are limiting the demand flowing to your team.</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const benchmarks = {
  HVAC: { low: 250000, average: 380000, top25: 620000, top10: 820000 },
};

document.getElementById('calc-btn').addEventListener('click', calculate);
['tech-count', 'annual-revenue'].forEach((id) => {
  document.getElementById(id).addEventListener('keydown', (event) => {
    if (event.key === 'Enter') calculate();
  });
});

function fmtMoney(value) {
  return '$' + Math.round(value).toLocaleString();
}

function fmtNumber(value) {
  return Math.round(value).toLocaleString();
}

function getTier(value, tradeBenchmark) {
  if (value >= tradeBenchmark.top10) return 'Top 10%';
  if (value >= tradeBenchmark.top25) return 'Top 25%';
  if (value >= tradeBenchmark.average) return 'Above Average';
  if (value >= tradeBenchmark.low) return 'Below Average';
  return 'Significantly Below Benchmark';
}

function setStatus(tier) {
  const status = document.getElementById('rp-status');
  if (tier === 'Top 10%' || tier === 'Top 25%') {
    status.textContent = 'Benchmark leader';
    status.className = 'rp-status status-good';
    return;
  }
  if (tier === 'Above Average' || tier === 'Below Average') {
    status.textContent = 'Benchmark gap found';
    status.className = 'rp-status status-warn';
    return;
  }
  status.textContent = 'Large team output gap';
  status.className = 'rp-status status-alert';
}

function revealShare(trade, revenuePerTech, top25, totalGap) {
  const shareSection = document.getElementById('share-section');
  const toolUrl = window.location.origin + window.location.pathname;
  const consequenceLine = document.getElementById('consequence-line').textContent;
  const internalSummary = `Our ${trade} company is running ${fmtMoney(revenuePerTech)}/tech/year. The gap to the top 25% across the team is ${fmtMoney(totalGap)}. ${toolUrl}`;
  const publicSummary = `My HVAC company runs ${fmtMoney(revenuePerTech)}/tech/year. Industry top 25% is ${fmtMoney(top25)}. That gap across my team is ${fmtMoney(totalGap)}. Free benchmarker: ${toolUrl} via @builtontenth`;
  shareSection.dataset.toolUrl = toolUrl;
  shareSection.dataset.internalShareText = internalSummary;
  shareSection.dataset.publicShareText = publicSummary;
  shareSection.dataset.emailSubject = `Revenue per tech benchmark: ${fmtMoney(revenuePerTech)}/year`;
  shareSection.dataset.emailBody = `${internalSummary}\n\n${consequenceLine}`;
  shareSection.hidden = false;
}

function calculate() {
  const trade = 'HVAC';
  const techCount = parseFloat(document.getElementById('tech-count').value) || 0;
  const annualRevenue = parseFloat(document.getElementById('annual-revenue').value) || 0;

  if (!techCount || !annualRevenue) {
    const button = document.getElementById('calc-btn');
    button.textContent = 'Please fill in all fields';
    window.setTimeout(() => {
      button.textContent = 'Benchmark My Team';
    }, 2000);
    return;
  }

  const tradeBenchmark = benchmarks[trade];
  const revenuePerTech = annualRevenue / techCount;
  const gapToAverage = tradeBenchmark.average - revenuePerTech;
  const gapToTop25 = tradeBenchmark.top25 - revenuePerTech;
  const gapToTop10 = tradeBenchmark.top10 - revenuePerTech;
  const totalGapToAverage = gapToAverage * techCount;
  const totalGapToTop25 = gapToTop25 * techCount;
  const totalGapToTop10 = gapToTop10 * techCount;
  const tier = getTier(revenuePerTech, tradeBenchmark);

  window.botTrack?.('tool_calculation', {
    tool_name: 'revenue-per-tech',
    trade: trade.toLowerCase(),
    tier: tier.toLowerCase().replaceAll(' ', '_'),
  });

  setStatus(tier);

  document.getElementById('revenue-per-tech').textContent = `${fmtMoney(revenuePerTech)}/year`;
  document.getElementById('tier-label').textContent = tier;

  const maxScale = tradeBenchmark.top10 * 1.1;
  const userPercent = Math.min((revenuePerTech / maxScale) * 100, 100);
  document.getElementById('point-user').style.left = `${userPercent}%`;
  document.getElementById('benchmark-labels').innerHTML = `
    <span>Low end<br />${fmtMoney(tradeBenchmark.low)}</span>
    <span>Industry avg<br />${fmtMoney(tradeBenchmark.average)}</span>
    <span>Top 25%<br />${fmtMoney(tradeBenchmark.top25)}</span>
    <span>Top 10%<br />${fmtMoney(tradeBenchmark.top10)}</span>
  `;

  const gapCards = document.getElementById('gap-cards');
  const noteBox = document.getElementById('note-box');

  if (revenuePerTech < tradeBenchmark.top25) {
    gapCards.innerHTML = `
      <div class="gap-card">
        <div class="gap-card-label">Gap to industry average</div>
        <div class="gap-card-value neg">${fmtMoney(Math.max(gapToAverage, 0))}</div>
        <div class="gap-card-sub">Per tech. Team gap: ${fmtMoney(Math.max(totalGapToAverage, 0))}</div>
      </div>
      <div class="gap-card">
        <div class="gap-card-label">Gap to top 25%</div>
        <div class="gap-card-value neg">${fmtMoney(Math.max(gapToTop25, 0))}</div>
        <div class="gap-card-sub">Per tech. Team gap: ${fmtMoney(Math.max(totalGapToTop25, 0))}</div>
      </div>
    `;
    if (revenuePerTech < tradeBenchmark.average) {
      noteBox.hidden = false;
      noteBox.textContent = 'A gap this size usually comes from one of four places: booking rate on inbound calls, average ticket size, estimate follow-up rate, or service agreement penetration. The report helps you see which one is the primary driver for your operation.';
    } else {
      noteBox.hidden = true;
      noteBox.textContent = '';
    }
    document.getElementById('consequence-line').textContent = `That gap to the top 25% is ${fmtMoney(Math.max(totalGapToTop25, 0))} across your team. The report helps you see which one factor is driving most of it.`;
  } else {
    gapCards.innerHTML = `
      <div class="gap-card">
        <div class="gap-card-label">Outperforming 75%</div>
        <div class="gap-card-value pos">${fmtMoney(revenuePerTech)}</div>
        <div class="gap-card-sub">You are outperforming most HVAC companies on revenue per tech.</div>
      </div>
      <div class="gap-card">
        <div class="gap-card-label">Gap to top 10%</div>
        <div class="gap-card-value">${fmtMoney(Math.max(gapToTop10, 0))}</div>
        <div class="gap-card-sub">Per tech. Team gap: ${fmtMoney(Math.max(totalGapToTop10, 0))}</div>
      </div>
    `;
    noteBox.hidden = true;
    noteBox.textContent = '';
    document.getElementById('consequence-line').textContent = `You are outperforming most HVAC companies. The next gap is ${fmtMoney(Math.max(totalGapToTop10, 0))} between your team and the top 10%.`;
  }

  revealShare(trade, revenuePerTech, tradeBenchmark.top25, Math.max(totalGapToTop25, 0));

  document.getElementById('empty-state').hidden = true;
  document.getElementById('results').classList.add('show');
}

</script>
</ToolLayout>
