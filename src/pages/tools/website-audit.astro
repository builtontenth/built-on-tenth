---
import ToolShareResult from '../../components/ToolShareResult.astro';
import ToolLayout from '../../layouts/ToolLayout.astro';

const suiteTools = [
  { num: '01', name: 'Phone Revenue', href: '/tools/phone-calculator' },
  { num: '02', name: 'Estimate Follow-Up', href: '/tools/estimate-follow-up' },
  { num: '03', name: 'Agency Report Card', href: '/tools/agency-report-card' },
  { num: '04', name: 'Revenue Per Tech', href: '/tools/revenue-per-tech' },
  { num: '05', name: 'Marketing Cost', href: '/tools/marketing-calculator' },
  { num: '06', name: 'GBP Scorecard', href: '/tools/gbp-scorecard' },
];
---
<ToolLayout
  toolNumber="07"
  toolCount="07"
  toolName="Website Conversion Audit"
  slug="website-audit"
  suiteVariant="expanded"
  showCrossTool={false}
  headline='Is Your Website<br><em>Losing You Calls?</em>'
  subheadline="Most contractor websites look fine - but fail in 3 critical places: speed, mobile experience, and call friction. Answer 12 quick questions about your site and get a Conversion Leak Score with specific fixes."
  metaDescription="Free website conversion audit for contractors. Check your site against 12 conversion factors that determine whether homeowners call you or leave. Get a scored report with specific fixes."
>

<style>
.tool-layout { display: grid; grid-template-columns: 1fr 480px; gap: 48px; padding-bottom: 80px; align-items: start; }
.input-panel { background: var(--bg2); border: 1px solid var(--rule2); border-radius: 8px; overflow: hidden; }
.ip-header { padding: 18px 24px; border-bottom: 1px solid var(--rule); background: var(--bg3); display: flex; align-items: center; justify-content: space-between; }
.ip-title { font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink3); }
.ip-micro { font-family: var(--mono); font-size: 9px; color: var(--ink3); opacity: 0.7; }
.ip-body { padding: 24px; }
.ip-note { font-size: 13px; color: var(--ink2); line-height: 1.65; font-weight: 300; margin-bottom: 22px; padding: 12px 14px; background: var(--bg3); border-radius: 4px; border-left: 2px solid var(--teal); }
.url-field { margin-bottom: 22px; }
.url-label { font-family: var(--mono); font-size: 9.5px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink3); margin-bottom: 8px; display: block; }
.url-input { width: 100%; background: var(--bg3); border: 1px solid var(--rule2); border-radius: 4px; padding: 11px 14px; font-family: var(--sans); font-size: 14px; color: var(--ink); outline: none; transition: border-color 0.2s; }
.url-input:focus { border-color: rgba(0,196,154,0.55); }
.url-input::placeholder { color: var(--ink3); font-size: 13px; }

.checklist-section { margin-bottom: 22px; }
.cs-title { font-family: var(--mono); font-size: 9.5px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--teal); padding: 8px 0; border-bottom: 1px solid var(--rule); margin-bottom: 12px; }
.check-item { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 10px; }
.check-item input[type="checkbox"] { display: none; }
.check-toggle { width: 18px; height: 18px; border-radius: 3px; border: 1.5px solid var(--rule2); flex-shrink: 0; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s; margin-top: 1px; }
.check-item input:checked ~ label .check-toggle { background: var(--teal); border-color: var(--teal); }
.check-item input:checked ~ label .check-toggle::after { content: '✓'; font-size: 11px; color: var(--bg); font-weight: 700; }
.check-label { cursor: pointer; display: flex; align-items: flex-start; gap: 12px; flex: 1; }
.check-text { font-size: 13px; color: var(--ink2); line-height: 1.55; font-weight: 300; padding-top: 1px; }
.check-text strong { color: var(--ink); font-weight: 500; }

.calc-btn { width: 100%; margin-top: 4px; padding: 14px; border-radius: 4px; cursor: pointer; font-family: var(--mono); font-size: 11.5px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--bg); background: var(--teal); border: 1.5px solid var(--teal); transition: all 0.2s; }
.calc-btn:hover { background: #00DFB0; transform: translateY(-1px); }

.result-panel { background: var(--bg2); border: 1px solid var(--rule2); border-radius: 8px; overflow: hidden; position: sticky; top: 80px; }
.rp-header { padding: 18px 24px; border-bottom: 1px solid var(--rule); background: var(--bg3); display: flex; align-items: center; justify-content: space-between; }
.rp-title { font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink3); }
.rp-status { font-family: var(--mono); font-size: 9px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 8px; border-radius: 3px; }
.s-wait  { color: var(--ink3); background: var(--bg4); border: 1px solid var(--rule); }
.s-alert { color: var(--neg); background: rgba(240,64,64,0.1); border: 1px solid rgba(240,64,64,0.22); }
.s-warn  { color: #C9A035; background: rgba(201,160,53,0.1); border: 1px solid rgba(201,160,53,0.22); }
.s-good  { color: var(--pos); background: rgba(34,211,122,0.1); border: 1px solid rgba(34,211,122,0.22); }
.rp-body { padding: 24px; }
.empty-state { text-align: center; padding: 36px 16px; }
.empty-icon { font-size: 32px; opacity: 0.25; margin-bottom: 14px; }
.empty-text { font-size: 13px; color: var(--ink3); line-height: 1.65; font-weight: 300; }
.result-section { display: none; }
.result-section.show { display: block; }

.score-circle-wrap { text-align: center; padding: 20px 0 24px; border-bottom: 1px solid var(--rule); margin-bottom: 20px; }
.score-label { font-family: var(--mono); font-size: 9.5px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink3); margin-bottom: 8px; }
.score-number { font-family: var(--mono); font-size: 72px; font-weight: 700; letter-spacing: -0.05em; line-height: 1; }
.score-number.bad { color: var(--neg); }
.score-number.warn { color: #C9A035; }
.score-number.good { color: var(--pos); }
.score-sub { font-size: 12.5px; color: var(--ink2); margin-top: 6px; font-weight: 300; }
.score-track { height: 6px; background: var(--bg4); border-radius: 3px; margin: 14px 0 8px; overflow: hidden; }
.score-fill { height: 100%; border-radius: 3px; transition: width 0.8s var(--ease); }
.score-range { display: flex; justify-content: space-between; gap: 8px; font-family: var(--mono); font-size: 8.5px; color: var(--ink3); }

.section-title, .rail-title { font-family: var(--mono); font-size: 9px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink3); margin-bottom: 10px; }
.issues-list { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
.issue-item { display: flex; align-items: flex-start; gap: 9px; padding: 9px 10px; background: var(--bg3); border-radius: 3px; font-size: 12.5px; color: var(--ink2); line-height: 1.5; font-weight: 300; }
.issue-ic { flex-shrink: 0; font-size: 12px; margin-top: 1px; }
.issue-ic.bad { color: var(--neg); }
.issue-ic.ok  { color: var(--pos); }

.diagnosis { background: rgba(240,64,64,0.06); border: 1px solid rgba(240,64,64,0.2); border-radius: 4px; padding: 14px 16px; margin-bottom: 18px; }
.diagnosis.warn { background: rgba(201,160,53,0.06); border-color: rgba(201,160,53,0.22); }
.diagnosis.good { background: rgba(34,211,122,0.06); border-color: rgba(34,211,122,0.2); }
.dt { font-size: 13px; font-weight: 600; color: var(--ink); margin-bottom: 5px; }
.db { font-size: 12px; color: var(--ink2); line-height: 1.62; font-weight: 300; }
.audit-cta { display: block; width: 100%; padding: 13px; border-radius: 4px; cursor: pointer; text-align: center; font-family: var(--mono); font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--bg); background: var(--teal); border: 1.5px solid var(--teal); text-decoration: none; transition: all 0.2s; }
.audit-cta:hover { background: #00DFB0; }
.audit-note { font-size: 11px; color: var(--ink3); text-align: center; margin-top: 10px; font-weight: 300; }

.result-rail { margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--rule); }
.rail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; }
.rail-link {
  display: block; padding: 12px; border-radius: 4px; text-decoration: none; background: var(--bg3); border: 1px solid var(--rule2);
  transition: border-color 0.2s, transform 0.2s;
}
.rail-link:hover { border-color: var(--teal4); transform: translateY(-1px); }
.rail-num { display: block; font-family: var(--mono); font-size: 9px; font-weight: 500; letter-spacing: 0.1em; color: var(--teal); margin-bottom: 4px; }
.rail-name { display: block; font-size: 12.5px; color: var(--ink); line-height: 1.35; }
.full-picture {
  display: block; padding: 14px; border-radius: 4px; text-decoration: none; background: rgba(0,196,154,0.05);
  border: 1px solid rgba(0,196,154,0.28);
}
.full-picture-label { display: block; font-family: var(--mono); font-size: 9px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--teal); margin-bottom: 6px; }
.full-picture-title { display: block; font-size: 14px; color: var(--ink); font-weight: 500; margin-bottom: 4px; }
.full-picture-copy { display: block; font-size: 12px; color: var(--ink2); line-height: 1.55; font-weight: 300; }

@media (max-width: 960px) { .tool-layout { grid-template-columns: 1fr; } .result-panel { position: static; } }
@media (max-width: 600px) { .rail-grid { grid-template-columns: 1fr; } }
</style>

<div class="tool-layout" slot="tool-body">
  <div class="input-panel">
    <div class="ip-header">
      <span class="ip-title">Site Conversion Checklist</span>
      <span class="ip-micro">12 factors · Takes 2 minutes</span>
    </div>
    <div class="ip-body">
      <p class="ip-note">Check every item that currently exists on your website. Be honest - if you're not sure, leave it unchecked. The score is only useful if the inputs are accurate.</p>

      <div class="url-field">
        <label class="url-label" for="site-url">Your website URL (optional - for reference)</label>
        <input type="url" class="url-input" id="site-url" placeholder="https://yourcompany.com" />
      </div>

      <div class="checklist-section">
        <div class="cs-title">Phone &amp; Contact Visibility</div>
        <div class="check-item">
          <input type="checkbox" id="c1" data-points="12">
          <label class="check-label" for="c1">
            <div class="check-toggle"></div>
            <span class="check-text"><strong>Phone number is visible</strong> in the top header - without scrolling</span>
          </label>
        </div>
        <div class="check-item">
          <input type="checkbox" id="c2" data-points="8">
          <label class="check-label" for="c2">
            <div class="check-toggle"></div>
            <span class="check-text"><strong>Phone number is clickable</strong> (tap-to-call) on mobile devices</span>
          </label>
        </div>
        <div class="check-item">
          <input type="checkbox" id="c3" data-points="6">
          <label class="check-label" for="c3">
            <div class="check-toggle"></div>
            <span class="check-text">A <strong>contact form or booking option</strong> is visible without digging</span>
          </label>
        </div>
      </div>

      <div class="checklist-section">
        <div class="cs-title">Speed &amp; Mobile</div>
        <div class="check-item">
          <input type="checkbox" id="c4" data-points="10">
          <label class="check-label" for="c4">
            <div class="check-toggle"></div>
            <span class="check-text">Site loads in <strong>under 3 seconds</strong> on a mobile connection</span>
          </label>
        </div>
        <div class="check-item">
          <input type="checkbox" id="c5" data-points="8">
          <label class="check-label" for="c5">
            <div class="check-toggle"></div>
            <span class="check-text">Site looks <strong>professional on a phone</strong> - text readable, no horizontal scroll</span>
          </label>
        </div>
        <div class="check-item">
          <input type="checkbox" id="c6" data-points="6">
          <label class="check-label" for="c6">
            <div class="check-toggle"></div>
            <span class="check-text">Images and pages <strong>do not shift or jump</strong> while loading</span>
          </label>
        </div>
      </div>

      <div class="checklist-section">
        <div class="cs-title">Trust Signals</div>
        <div class="check-item">
          <input type="checkbox" id="c7" data-points="10">
          <label class="check-label" for="c7">
            <div class="check-toggle"></div>
            <span class="check-text"><strong>Google review count and star rating</strong> is visible on the homepage</span>
          </label>
        </div>
        <div class="check-item">
          <input type="checkbox" id="c8" data-points="8">
          <label class="check-label" for="c8">
            <div class="check-toggle"></div>
            <span class="check-text"><strong>License number, insurance, or certifications</strong> are mentioned</span>
          </label>
        </div>
        <div class="check-item">
          <input type="checkbox" id="c9" data-points="6">
          <label class="check-label" for="c9">
            <div class="check-toggle"></div>
            <span class="check-text">The site shows <strong>photos of your actual team or trucks</strong> (not just stock)</span>
          </label>
        </div>
      </div>

      <div class="checklist-section">
        <div class="cs-title">Clarity &amp; Calls-to-Action</div>
        <div class="check-item">
          <input type="checkbox" id="c10" data-points="10">
          <label class="check-label" for="c10">
            <div class="check-toggle"></div>
            <span class="check-text">The <strong>homepage headline clearly states what you do</strong> and who you serve</span>
          </label>
        </div>
        <div class="check-item">
          <input type="checkbox" id="c11" data-points="8">
          <label class="check-label" for="c11">
            <div class="check-toggle"></div>
            <span class="check-text">There is a <strong>clear primary CTA button</strong> above the fold (Call Now / Book Online)</span>
          </label>
        </div>
        <div class="check-item">
          <input type="checkbox" id="c12" data-points="8">
          <label class="check-label" for="c12">
            <div class="check-toggle"></div>
            <span class="check-text">Service areas / cities you serve are <strong>clearly listed on the site</strong></span>
          </label>
        </div>
      </div>

      <button class="calc-btn" id="calc-btn">Get My Conversion Leak Score</button>
    </div>
  </div>

  <div class="result-panel">
    <div class="rp-header">
      <span class="rp-title">Conversion Leak Score</span>
      <span class="rp-status s-wait" id="rp-status">Waiting for checklist</span>
    </div>
    <div class="rp-body">
      <div class="empty-state" id="empty-state">
        <div class="empty-icon">🔍</div>
        <p class="empty-text">Most contractor websites look fine - but fail on the 3 things that determine whether someone calls: speed, phone visibility, and trust signals. Work through the checklist to see your score.</p>
      </div>
      <div class="result-section" id="results">
        <div class="score-circle-wrap">
          <div class="score-label">Your Conversion Leak Score</div>
          <div class="score-number" id="score-num">0</div>
          <div class="score-sub" id="score-sub">out of 100</div>
          <div class="score-track"><div class="score-fill" id="score-fill" style="width:0%;background:var(--neg)"></div></div>
          <div class="score-range"><span>0 - Critical</span><span>50 - Average</span><span>80+ - Strong</span></div>
        </div>

        <div class="section-title" id="issues-title">Issues found</div>
        <div class="issues-list" id="issues-list"></div>

        <div class="diagnosis" id="diagnosis">
          <div class="dt" id="diag-title">-</div>
          <div class="db" id="diag-body">-</div>
        </div>

        <a href="/apply?service=audit&source=website-audit" class="audit-cta">Get a Full Site + Marketing Audit</a>
        <p class="audit-note">The Revenue Leak Audit includes a detailed website analysis alongside your phone, ads, and competitor benchmarks.</p>

        <ToolShareResult sectionId="share-section" />

        <div class="result-rail">
          <div class="rail-title">Continue your diagnosis</div>
          <div class="rail-grid">
            {suiteTools.map((tool) => (
              <a href={tool.href} class="rail-link">
                <span class="rail-num">{tool.num}</span>
                <span class="rail-name">{tool.name}</span>
              </a>
            ))}
          </div>
          <a href="/apply?service=audit&source=website-audit" class="full-picture">
            <span class="full-picture-label">Full picture</span>
            <span class="full-picture-title">Revenue Leak Audit - $750</span>
            <span class="full-picture-copy">Every leak. Every gap. Every fix. In writing.</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const checkItems = [
  { id: 'c1',  points: 12, label: 'Phone number visible in header',         cat: 'Phone visibility' },
  { id: 'c2',  points: 8,  label: 'Tap-to-call on mobile',                  cat: 'Mobile' },
  { id: 'c3',  points: 6,  label: 'Contact form or booking visible',         cat: 'Contact' },
  { id: 'c4',  points: 10, label: 'Page loads under 3 seconds on mobile',    cat: 'Speed' },
  { id: 'c5',  points: 8,  label: 'Professional mobile experience',          cat: 'Mobile' },
  { id: 'c6',  points: 6,  label: 'No layout shift while loading',           cat: 'Speed' },
  { id: 'c7',  points: 10, label: 'Google reviews visible on homepage',      cat: 'Trust' },
  { id: 'c8',  points: 8,  label: 'License / insurance / certifications shown', cat: 'Trust' },
  { id: 'c9',  points: 6,  label: 'Real team or truck photos (not stock)',   cat: 'Trust' },
  { id: 'c10', points: 10, label: 'Clear headline - what you do, who you serve', cat: 'Clarity' },
  { id: 'c11', points: 8,  label: 'Primary CTA button above the fold',       cat: 'CTA' },
  { id: 'c12', points: 8,  label: 'Service areas listed on site',            cat: 'Clarity' },
];

document.getElementById('calc-btn').addEventListener('click', calculate);

function calculate() {
  let earned = 0;
  const total  = checkItems.reduce((s, i) => s + i.points, 0);
  const passed = [];
  const failed = [];

  checkItems.forEach(item => {
    const el = document.getElementById(item.id);
    if (el && el.checked) {
      earned += item.points;
      passed.push(item);
    } else {
      failed.push(item);
    }
  });

  const score = Math.round((earned / total) * 100);

  window.botTrack?.('tool_calculation', {
    tool_name: 'website-audit',
    score_bucket: score >= 80 ? '80_plus' : score >= 55 ? '55_to_79' : 'under_55',
  });

  const status = document.getElementById('rp-status');
  if (score >= 80) {
    status.textContent = 'Strong conversion setup';
    status.className = 'rp-status s-good';
  } else if (score >= 55) {
    status.textContent = 'Room to improve';
    status.className = 'rp-status s-warn';
  } else {
    status.textContent = 'Significant conversion leaks';
    status.className = 'rp-status s-alert';
  }

  const scoreEl = document.getElementById('score-num');
  scoreEl.textContent = score;
  scoreEl.className = `score-number ${score >= 80 ? 'good' : score >= 55 ? 'warn' : 'bad'}`;
  document.getElementById('score-sub').textContent = `out of 100 - ${failed.length} issue${failed.length !== 1 ? 's' : ''} found`;
  const fillEl = document.getElementById('score-fill');
  fillEl.style.width = score + '%';
  fillEl.style.background = score >= 80 ? 'var(--pos)' : score >= 55 ? '#C9A035' : 'var(--neg)';

  const issuesList = document.getElementById('issues-list');
  const issuesTitle = document.getElementById('issues-title');
  if (failed.length === 0) {
    issuesTitle.textContent = 'All checks passed';
    issuesList.innerHTML = '<div class="issue-item"><span class="issue-ic ok">✓</span>Your site passes all 12 conversion factors. Strong setup.</div>';
  } else {
    issuesTitle.textContent = `${failed.length} conversion leak${failed.length > 1 ? 's' : ''} found`;
    issuesList.innerHTML = failed.map(f =>
      `<div class="issue-item"><span class="issue-ic bad">✕</span>${f.label} <span style="font-family:var(--mono);font-size:9px;color:var(--ink3);margin-left:auto;padding-left:8px">-${f.points}pts</span></div>`
    ).join('') + passed.map(p =>
      `<div class="issue-item"><span class="issue-ic ok">✓</span>${p.label}</div>`
    ).join('');
  }

  const diagEl    = document.getElementById('diagnosis');
  const diagTitle = document.getElementById('diag-title');
  const diagBody  = document.getElementById('diag-body');

  const phoneIssues = failed.filter(f => ['c1','c2','c3'].includes(f.id));
  const speedIssues = failed.filter(f => ['c4','c5','c6'].includes(f.id));

  if (score >= 80) {
    diagEl.className = 'diagnosis good';
    diagTitle.textContent = 'Your website is set up to convert.';
    diagBody.textContent  = 'Most of the common conversion killers are handled. Your biggest opportunity is likely outside the website, in how calls are being handled and followed up on.';
  } else if (phoneIssues.length >= 2) {
    diagEl.className = 'diagnosis';
    diagTitle.textContent = 'Phone visibility is your biggest leak.';
    diagBody.textContent  = 'If someone cannot immediately find your number or tap to call from their phone, they leave. This is the single highest-impact fix on most contractor sites, and it takes an afternoon.';
  } else if (speedIssues.length >= 2) {
    diagEl.className = 'diagnosis';
    diagTitle.textContent = 'Site speed is costing you calls.';
    diagBody.textContent  = 'A site that takes 5+ seconds to load on mobile loses 53% of visitors before they see your number. This is usually a hosting, image size, or plugin issue, not a redesign.';
  } else if (score < 55) {
    diagEl.className = 'diagnosis';
    diagTitle.textContent = 'Multiple conversion leaks working against you.';
    diagBody.textContent  = 'These are not design problems. They are operational problems. Most of the fixes take hours, not weeks. The priority is phone visibility and trust signals first, everything else second.';
  } else {
    diagEl.className = 'diagnosis warn';
    diagTitle.textContent = 'Decent setup with fixable gaps.';
    diagBody.textContent  = 'You are not in a critical situation, but each unchecked item is costing you calls at the margin. The trust signal gaps are typically the easiest high-value fixes.';
  }

  const shareSection = document.getElementById('share-section');
  const toolUrl = window.location.origin + window.location.pathname;
  shareSection.dataset.toolUrl = toolUrl;
  shareSection.dataset.shareText = `My website scores ${score}/100 on conversion factors. Free website audit for HVAC, roofing and plumbing companies: ${toolUrl} via @builtontenth`;
  shareSection.style.display = 'block';

  document.getElementById('empty-state').style.display = 'none';
  document.getElementById('results').classList.add('show');
}
</script>
</ToolLayout>
