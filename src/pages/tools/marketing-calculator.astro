---
import ToolShareResult from '../../components/ToolShareResult.astro';
import ToolLayout from '../../layouts/ToolLayout.astro';

const suiteTools = [
  { num: '01', name: 'Phone Revenue', href: '/tools/phone-calculator' },
  { num: '02', name: 'Estimate Follow-Up', href: '/tools/estimate-follow-up' },
  { num: '03', name: 'Agency Report Card', href: '/tools/agency-report-card' },
  { num: '04', name: 'Revenue Per Tech', href: '/tools/revenue-per-tech' },
  { num: '06', name: 'GBP Scorecard', href: '/tools/gbp-scorecard' },
  { num: '07', name: 'Website Conversion', href: '/tools/website-audit' },
];
---
<ToolLayout
  toolNumber="05"
  toolCount="07"
  toolName="Marketing Cost Calculator"
  slug="marketing-calculator"
  showCrossTool={false}
  headline='What Is Each Booked Job<br><em>Actually Costing You?</em>'
  subheadline="Most HVAC companies track leads. Very few know what it costs to book a real job. Enter your numbers and see your true cost per booked job against stronger HVAC benchmarks."
  metaDescription="HVAC marketing cost calculator. Enter ad spend, lead volume, close rate, and average ticket to see true cost per booked job and benchmark your channel economics."
>


<div class="tool-layout" slot="tool-body">
  <div class="input-panel">
    <div class="ip-header">
      <span class="ip-title">Your Marketing Numbers</span>
      <span class="ip-micro">Benchmarked against stronger HVAC booked-job ranges</span>
    </div>
    <div class="ip-body">
      <div class="field">
        <div class="field-label">
          <span>Primary channel</span>
          <span class="field-hint">Benchmark your main source</span>
        </div>
        <select class="field-select" id="primary-channel">
          <option value="google_ads">Google Ads</option>
          <option value="lsas">LSAs</option>
          <option value="seo_organic">SEO/Organic</option>
          <option value="referrals">Referrals</option>
          <option value="angi_homeadvisor">Angi or HomeAdvisor</option>
          <option value="direct_mail">Direct Mail</option>
          <option value="mixed">Mixed</option>
        </select>
      </div>
      <div class="field">
        <div class="field-label">Monthly marketing spend <span class="field-hint">ads + agency fees combined</span></div>
        <div class="prefix-wrap"><span class="prefix">$</span><input type="number" class="field-input" id="spend" min="0" /></div>
      </div>
      <div class="field">
        <div class="field-label">Inbound calls / leads per month <span class="field-hint">all sources combined</span></div>
        <input type="number" class="field-input" id="leads" min="0" />
      </div>
      <div class="field">
        <div class="field-label">Booking rate <span class="field-hint">% of leads that become booked jobs</span></div>
        <div class="suffix-wrap"><span class="suffix">%</span><input type="number" class="field-input" id="close-rate" min="0" max="100" /></div>
        <div class="bm-hint"><span>HVAC benchmark:</span><span class="bm-val">28-35% average · 50%+ strong</span></div>
      </div>
      <div class="field">
        <div class="field-label">Average job ticket <span class="field-hint">Average revenue per booked job</span></div>
        <div class="prefix-wrap"><span class="prefix">$</span><input type="number" class="field-input" id="ticket" min="0" /></div>
      </div>
      <button class="calc-btn" id="calc-btn">See My True Cost Per Job</button>
    </div>
  </div>

  <div class="result-panel">
    <div class="rp-header">
      <span class="rp-title">Marketing Diagnostic</span>
      <span class="rp-status s-wait" id="rp-status">Waiting for your numbers</span>
    </div>
    <div class="rp-body">
      <div class="empty-state" id="empty-state">
        <div class="empty-icon">📊</div>
        <p class="empty-text"><strong>Most HVAC owners underestimate this by 30-60%.</strong><br><br>Platform dashboards show cost per lead. They do not show what each booked job actually costs once weak booking rates and mixed lead quality are factored in.</p>
      </div>
      <div class="result-section" id="results">
        <div class="main-metric">
          <div class="mm-label">Your true cost per booked job</div>
          <div class="mm-value" id="cost-per-job">$0</div>
          <div class="mm-sub" id="mm-sub">Based on your inputs</div>
        </div>
        <div class="section-title">Full breakdown</div>
        <div class="rows">
          <div class="row"><span class="rk">Monthly spend</span><span class="rv" id="r-spend">-</span></div>
          <div class="row"><span class="rk">Calls/leads per month</span><span class="rv" id="r-leads">-</span></div>
          <div class="row"><span class="rk">Close rate</span><span class="rv" id="r-close">-</span></div>
          <div class="row"><span class="rk">Jobs booked per month</span><span class="rv" id="r-jobs">-</span></div>
          <div class="row"><span class="rk">Cost per lead</span><span class="rv" id="r-cpl">-</span></div>
          <div class="row"><span class="rk">Cost per booked job</span><span class="rv bad" id="r-cpj">-</span></div>
          <div class="row"><span class="rk">Revenue per $1 spent</span><span class="rv" id="r-roi">-</span></div>
        </div>
        <div class="bm-section">
          <div class="section-title">HVAC cost per job vs. benchmark</div>
          <div class="bm-track"><div class="bm-bar" id="bm-bar"></div></div>
          <div class="bm-range"><span>$0</span><span id="bm-mid">Avg: $-</span><span>Top 25%: $-</span><span>Your number</span></div>
        </div>
        <div class="channel-benchmark" id="channel-benchmark" hidden></div>
        <div class="diagnosis" id="diagnosis">
          <div class="dt" id="diag-title">-</div>
          <div class="db" id="diag-body">-</div>
        </div>
        <p class="consequence-line" id="consequence-line">The gap between your number and the stronger HVAC range shows how much waste may be sitting in channel mix, booking rate, and lead quality.</p>
        <div class="divider"></div>
        <a href="/report?source=marketing-calculator" class="btn btn--primary audit-cta">Request your report</a>
        <p class="audit-note">This tool gives one cost view. The full report shows whether local competitors, review strength, and map pack position are making the cost problem worse.</p>

        <ToolShareResult sectionId="share-section" profile="internal" />

        <div class="result-rail">
          <div class="rail-title">Continue your diagnosis</div>
          <div class="rail-grid">
            {suiteTools.map((tool) => (
              <a href={tool.href} class="rail-link">
                <span class="rail-num">{tool.num}</span>
                <span class="rail-name">{tool.name}</span>
              </a>
            ))}
          </div>
          <a href="/report?source=marketing-calculator" class="full-picture">
            <span class="full-picture-label">Next step</span>
            <span class="full-picture-title">HVAC Local Market Report</span>
            <span class="full-picture-copy">See where local visibility and competitor strength are making this cost problem worse.</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const benchmarks = {
  hvac: { avgCPJ: 340, topCPJ: 110, avgROI: 4.2, tradeLabel: 'HVAC' },
};

const channelBenchmarks = {
  google_ads: {
    label: 'Google Ads',
    hvac: [180, 320],
  },
  lsas: {
    label: 'LSAs',
    hvac: [90, 160],
  },
  angi_homeadvisor: {
    label: 'Angi or HomeAdvisor',
    hvac: [280, 520],
  },
  referrals: {
    label: 'Referrals',
    hvac: [0, 40],
  },
  direct_mail: {
    label: 'Direct Mail',
    hvac: [200, 380],
  },
  seo_organic: {
    label: 'SEO/Organic',
    hvac: [60, 140],
  },
  mixed: {
    label: 'Mixed channel',
    hvac: [110, 340],
  },
};

function fmt(n)  { return '$' + Math.round(n).toLocaleString(); }
function fmtN(n) { return Math.round(n).toLocaleString(); }

document.getElementById('calc-btn').addEventListener('click', calculate);
['spend', 'leads', 'close-rate', 'ticket'].forEach((id) => {
  document.getElementById(id).addEventListener('keydown', (event) => {
    if (event.key === 'Enter') calculate();
  });
});

function updateChannelBenchmarkLine(trade, primaryChannel, cpj) {
  const benchmarkEl = document.getElementById('channel-benchmark');
  const channelData = channelBenchmarks[primaryChannel];
  const range = channelData?.[trade];

  if (!channelData || !range) {
    benchmarkEl.hidden = true;
    benchmarkEl.textContent = '';
    return;
  }

  benchmarkEl.hidden = false;
  benchmarkEl.textContent = `${channelData.label} benchmark: stronger HVAC operators typically run ${fmt(range[0])}-${fmt(range[1])} per booked job on this channel.`;

  const toolUrl = window.location.origin + window.location.pathname;
  const shareSection = document.getElementById('share-section');
  const internalSummary = `Our real cost per booked job is ${fmt(cpj)}. Stronger HVAC operators on ${channelData.label} run ${fmt(range[0])}-${fmt(range[1])} per booked job on this channel. ${toolUrl}`;
  shareSection.dataset.toolUrl = toolUrl;
  shareSection.dataset.internalShareText = internalSummary;
  shareSection.dataset.emailSubject = `Marketing cost per booked job: ${fmt(cpj)}`;
  shareSection.dataset.emailBody = internalSummary;
  shareSection.hidden = false;
}

function calculate() {
  const trade          = 'hvac';
  const primaryChannel = document.getElementById('primary-channel').value;
  const spend          = parseFloat(document.getElementById('spend').value)      || 0;
  const leads          = parseFloat(document.getElementById('leads').value)      || 0;
  const closeRate      = parseFloat(document.getElementById('close-rate').value) || 0;
  const ticket         = parseFloat(document.getElementById('ticket').value)     || 0;

  if (!spend || !leads || !closeRate || !ticket) {
    document.getElementById('calc-btn').textContent = 'Please fill in all fields';
    setTimeout(() => document.getElementById('calc-btn').textContent = 'See My True Cost Per Job', 2000);
    return;
  }

  const bm       = benchmarks[trade];
  const cr       = Math.min(closeRate, 100) / 100;
  const jobs     = leads * cr;
  const cpl      = jobs > 0 ? spend / leads : 0;
  const cpj      = jobs > 0 ? spend / jobs  : 0;
  const revenue  = jobs * ticket;
  const roi      = spend > 0 ? revenue / spend : 0;

  window.botTrack?.('tool_calculation', {
    tool_name: 'marketing-calculator',
    trade,
    primary_channel: primaryChannel,
    cpj_bucket: cpj >= bm.avgCPJ ? 'above_average' : 'below_average',
  });

  const status = document.getElementById('rp-status');
  if (cpj > bm.avgCPJ * 1.3) {
    status.textContent = 'Above average cost - leak found';
    status.className = 'rp-status s-alert';
  } else if (cpj > bm.avgCPJ) {
    status.textContent = 'Room to improve';
    status.className = 'rp-status s-warn';
  } else {
    status.textContent = 'Performing well';
    status.className = 'rp-status s-good';
  }

  const cpjEl = document.getElementById('cost-per-job');
  cpjEl.textContent = fmt(cpj);
  cpjEl.className = cpj <= bm.topCPJ ? 'mm-value good' : cpj <= bm.avgCPJ ? 'mm-value warn' : 'mm-value';
  document.getElementById('mm-sub').textContent = `At your current inputs · ${fmtN(jobs)} booked jobs/month`;

  document.getElementById('r-spend').textContent   = fmt(spend) + '/month';
  document.getElementById('r-leads').textContent   = fmtN(leads) + '/month';
  document.getElementById('r-close').textContent   = closeRate + '%';
  document.getElementById('r-jobs').textContent    = fmtN(jobs) + '/month';
  document.getElementById('r-cpl').textContent     = fmt(cpl);
  document.getElementById('r-cpj').textContent     = fmt(cpj);
  document.getElementById('r-cpj').className       = `rv ${cpj > bm.avgCPJ * 1.3 ? 'bad' : cpj > bm.avgCPJ ? 'warn' : 'ok'}`;
  document.getElementById('r-roi').textContent     = '$' + roi.toFixed(2) + ' per $1 spent';
  document.getElementById('r-roi').className       = `rv ${roi >= bm.avgROI ? 'ok' : roi >= bm.avgROI * 0.7 ? 'warn' : 'bad'}`;

  const maxDisplay = bm.avgCPJ * 2;
  const fillPct = Math.min((cpj / maxDisplay) * 100, 100);
  const bmBar = document.getElementById('bm-bar');
  bmBar.style.width = fillPct + '%';
  bmBar.className = `bm-bar ${cpj <= bm.topCPJ ? 'ok' : cpj <= bm.avgCPJ ? 'warn' : ''}`;

  const bmRangeEl = document.querySelector('.bm-range');
  bmRangeEl.innerHTML = `<span>$0</span><span>Avg: ${fmt(bm.avgCPJ)}</span><span>Top 25%: ${fmt(bm.topCPJ)}</span><span>You: ${fmt(cpj)}</span>`;

  const diagEl    = document.getElementById('diagnosis');
  const diagTitle = document.getElementById('diag-title');
  const diagBody  = document.getElementById('diag-body');
  if (cpj <= bm.topCPJ) {
    diagEl.className = 'diagnosis ok';
    diagTitle.textContent = 'You are in the top 25%.';
    diagBody.textContent  = 'Your cost per booked job is strong. The opportunity now is scaling what is working and cutting the channels that are dragging your average up.';
  } else if (cpj <= bm.avgCPJ) {
    diagEl.className = 'diagnosis warn';
    diagTitle.textContent = 'Average, but there is room.';
    diagBody.textContent  = 'You are near the industry average. The gap between average and top 25% is typically a close rate issue or a channel mix problem. Both are fixable without increasing spend.';
  } else {
    diagEl.className = 'diagnosis';
    diagTitle.textContent = `You are paying ${fmt(cpj - bm.avgCPJ)} more per job than average.`;
    diagBody.textContent  = 'This is usually caused by a low close rate losing jobs you are already paying for, one weak channel dragging up the blended average, or agency fees that do not connect to booked jobs.';
  }

  updateChannelBenchmarkLine(trade, primaryChannel, cpj);
  document.getElementById('consequence-line').textContent = `That gap between your current number and the top 25% is ${fmt(Math.max(cpj - bm.topCPJ, 0))} per booked job. The report helps you see whether local visibility is making the paid channel math even worse.`;
  const shareSection = document.getElementById('share-section');
  shareSection.dataset.emailBody = `${shareSection.dataset.internalShareText}\n\n${document.getElementById('consequence-line').textContent}`;

  document.getElementById('empty-state').hidden = true;
  document.getElementById('results').classList.add('show');
}
</script>
</ToolLayout>
