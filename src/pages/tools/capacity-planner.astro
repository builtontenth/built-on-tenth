---
import ToolLayout from '../../layouts/ToolLayout.astro';
---
<ToolLayout
  toolNumber="05"
  toolName="Capacity-to-Demand Planner"
  slug="capacity-planner"
  headline='Are You Buying More Leads<br><em>Than You Can Convert?</em>'
  subheadline="Most companies scale marketing spend before fixing capacity. That's how money gets burned. Enter your team size and production rate - find out exactly how many calls you need and the maximum spend that makes sense."
  metaDescription="Free capacity planner for home service companies. Find out how many leads your team can actually handle before spending more on marketing. Avoid overspending on leads you can't convert."
>

<style>
.tool-layout { display: grid; grid-template-columns: 1fr 480px; gap: 48px; padding-bottom: 80px; align-items: start; }
.input-panel { background: var(--bg2); border: 1px solid var(--rule2); border-radius: 8px; overflow: hidden; }
.ip-header { padding: 18px 24px; border-bottom: 1px solid var(--rule); background: var(--bg3); display: flex; align-items: center; justify-content: space-between; }
.ip-title { font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink3); }
.ip-micro { font-family: var(--mono); font-size: 9px; color: var(--ink3); opacity: 0.7; }
.ip-body { padding: 24px; }
.ip-insight { font-size: 13px; color: var(--ink2); line-height: 1.65; font-weight: 300; margin-bottom: 22px; padding: 12px 14px; background: var(--bg3); border-radius: 4px; border-left: 2px solid var(--teal); }
.field { margin-bottom: 20px; }
.field-label { display: flex; justify-content: space-between; align-items: baseline; font-family: var(--mono); font-size: 9.5px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink3); margin-bottom: 8px; }
.field-hint { font-size: 9px; color: var(--ink3); opacity: 0.65; font-weight: 300; letter-spacing: 0.03em; text-transform: none; }
.field-input { width: 100%; background: var(--bg3); border: 1px solid var(--rule2); border-radius: 4px; padding: 11px 14px; font-family: var(--sans); font-size: 15px; color: var(--ink); outline: none; transition: border-color 0.2s; -moz-appearance: textfield; }
.field-input::-webkit-inner-spin-button, .field-input::-webkit-outer-spin-button { -webkit-appearance: none; }
.field-input:focus { border-color: rgba(0,196,154,0.55); }
.field-input::placeholder { color: var(--ink3); font-size: 13px; }
.prefix-wrap { position: relative; }
.prefix { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); font-family: var(--mono); font-size: 14px; color: var(--ink3); pointer-events: none; }
.prefix + .field-input { padding-left: 26px; }
.suffix-wrap { position: relative; }
.suffix { position: absolute; right: 13px; top: 50%; transform: translateY(-50%); font-family: var(--mono); font-size: 12px; color: var(--ink3); pointer-events: none; }
.bm-hint { margin-top: 6px; font-family: var(--mono); font-size: 9px; color: var(--ink3); padding: 5px 10px; background: var(--bg4); border-radius: 3px; display: flex; justify-content: space-between; }
.bm-val { color: var(--teal); font-weight: 500; }
.calc-btn { width: 100%; margin-top: 4px; padding: 14px; border-radius: 4px; cursor: pointer; font-family: var(--mono); font-size: 11.5px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--bg); background: var(--teal); border: 1.5px solid var(--teal); transition: all 0.2s; }
.calc-btn:hover { background: #00DFB0; transform: translateY(-1px); }

.result-panel { background: var(--bg2); border: 1px solid var(--rule2); border-radius: 8px; overflow: hidden; position: sticky; top: 80px; }
.rp-header { padding: 18px 24px; border-bottom: 1px solid var(--rule); background: var(--bg3); display: flex; align-items: center; justify-content: space-between; }
.rp-title { font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink3); }
.rp-status { font-family: var(--mono); font-size: 9px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 8px; border-radius: 3px; }
.s-wait  { color: var(--ink3); background: var(--bg4); border: 1px solid var(--rule); }
.s-over  { color: #C9A035; background: rgba(201,160,53,0.1); border: 1px solid rgba(201,160,53,0.22); }
.s-under { color: var(--neg); background: rgba(240,64,64,0.1); border: 1px solid rgba(240,64,64,0.22); }
.s-good  { color: var(--pos); background: rgba(34,211,122,0.1); border: 1px solid rgba(34,211,122,0.22); }
.rp-body { padding: 24px; }
.empty-state { text-align: center; padding: 36px 16px; }
.empty-icon { font-size: 32px; opacity: 0.25; margin-bottom: 14px; }
.empty-text { font-size: 13px; color: var(--ink3); line-height: 1.65; font-weight: 300; }
.result-section { display: none; }
.result-section.show { display: block; }
.key-metrics { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--rule); }
.km-card { background: var(--bg3); border: 1px solid var(--rule); border-radius: 4px; padding: 14px; }
.km-label { font-family: var(--mono); font-size: 8.5px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink3); margin-bottom: 6px; }
.km-value { font-family: var(--mono); font-size: 26px; font-weight: 700; letter-spacing: -0.03em; line-height: 1; color: var(--ink); }
.km-value.teal { color: var(--teal); }
.km-value.warn { color: #C9A035; }
.km-value.bad  { color: var(--neg); }
.km-sub  { font-size: 11px; color: var(--ink3); margin-top: 4px; font-weight: 300; }
.section-title { font-family: var(--mono); font-size: 9px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink3); margin-bottom: 10px; }
.rows { display: flex; flex-direction: column; gap: 6px; margin-bottom: 18px; }
.row { display: flex; justify-content: space-between; align-items: center; padding: 8px 10px; background: var(--bg3); border-radius: 3px; }
.rk { font-size: 12.5px; color: var(--ink2); font-weight: 300; }
.rv { font-family: var(--mono); font-size: 12.5px; font-weight: 600; color: var(--ink); }
.rv.good { color: var(--pos); } .rv.warn { color: #C9A035; } .rv.bad { color: var(--neg); }
.utilization-bar { margin-bottom: 18px; }
.ub-label { font-family: var(--mono); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink3); margin-bottom: 8px; display: flex; justify-content: space-between; }
.ub-track { height: 8px; background: var(--bg4); border-radius: 4px; overflow: hidden; }
.ub-fill { height: 100%; border-radius: 4px; transition: width 0.8s var(--ease); }
.diagnosis { background: rgba(240,64,64,0.06); border: 1px solid rgba(240,64,64,0.2); border-radius: 4px; padding: 14px 16px; margin-bottom: 18px; }
.diagnosis.warn { background: rgba(201,160,53,0.06); border-color: rgba(201,160,53,0.22); }
.diagnosis.good { background: rgba(34,211,122,0.06); border-color: rgba(34,211,122,0.2); }
.dt { font-size: 13px; font-weight: 600; color: var(--ink); margin-bottom: 5px; }
.db { font-size: 12px; color: var(--ink2); line-height: 1.62; font-weight: 300; }
.audit-cta { display: block; width: 100%; padding: 13px; border-radius: 4px; cursor: pointer; text-align: center; font-family: var(--mono); font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--bg); background: var(--teal); border: 1.5px solid var(--teal); text-decoration: none; transition: all 0.2s; }
.audit-cta:hover { background: #00DFB0; }
.audit-note { font-size: 11px; color: var(--ink3); text-align: center; margin-top: 10px; font-weight: 300; }
@media (max-width: 960px) { .tool-layout { grid-template-columns: 1fr; } .result-panel { position: static; } }
</style>

<div class="tool-layout" slot="tool-body">
  <div class="input-panel">
    <div class="ip-header">
      <span class="ip-title">Your Team &amp; Production Numbers</span>
      <span class="ip-micro">Capacity-first marketing math</span>
    </div>
    <div class="ip-body">
      <p class="ip-insight">Scaling spend before fixing capacity is how money gets burned. Get the number of leads your team can actually handle - then decide how much to spend on getting them.</p>

      <div class="field">
        <div class="field-label">Number of field technicians <span class="field-hint">techs who run jobs</span></div>
        <input type="number" class="field-input" id="techs" placeholder="e.g. 4" min="1" />
      </div>
      <div class="field">
        <div class="field-label">Jobs per tech per day <span class="field-hint">on a typical busy day</span></div>
        <input type="number" class="field-input" id="jobs-per-day" placeholder="e.g. 3" min="1" />
        <div class="bm-hint"><span>Industry typical:</span><span class="bm-val">HVAC: 3–5 · Roofing: 2–3 · Plumbing: 4–6</span></div>
      </div>
      <div class="field">
        <div class="field-label">Working days per month <span class="field-hint">across your whole team</span></div>
        <input type="number" class="field-input" id="working-days" placeholder="e.g. 22" min="1" max="31" />
      </div>
      <div class="field">
        <div class="field-label">Average job ticket <span class="field-hint">avg revenue per completed job</span></div>
        <div class="prefix-wrap"><span class="prefix">$</span><input type="number" class="field-input" id="avg-ticket" placeholder="e.g. 1800" min="0" /></div>
      </div>
      <div class="field">
        <div class="field-label">Your close rate <span class="field-hint">% of inbound calls that book</span></div>
        <div class="suffix-wrap"><span class="suffix">%</span><input type="number" class="field-input" id="close-rate" placeholder="e.g. 38" min="1" max="100" /></div>
        <div class="bm-hint"><span>Industry average:</span><span class="bm-val">28–38% · Top 25%: 50%+</span></div>
      </div>
      <div class="field">
        <div class="field-label">Target utilization <span class="field-hint">% of capacity you want to run at</span></div>
        <div class="suffix-wrap"><span class="suffix">%</span><input type="number" class="field-input" id="utilization" placeholder="e.g. 80" min="1" max="100" /></div>
        <div class="bm-hint"><span>Recommended:</span><span class="bm-val">75–85% (leaves room for emergencies)</span></div>
      </div>
      <button class="calc-btn" id="calc-btn">Calculate My Capacity Needs</button>
    </div>
  </div>

  <div class="result-panel">
    <div class="rp-header">
      <span class="rp-title">Capacity Plan</span>
      <span class="rp-status s-wait" id="rp-status">Waiting for your numbers</span>
    </div>
    <div class="rp-body">
      <div class="empty-state" id="empty-state">
        <div class="empty-icon">📋</div>
        <p class="empty-text">Most companies scale spend before fixing capacity. That's how money gets burned - you're paying for leads your team can't handle, and calls that came in aren't getting booked. Enter your team numbers to find the right spend ceiling.</p>
      </div>
      <div class="result-section" id="results">
        <div class="key-metrics">
          <div class="km-card">
            <div class="km-label">Calls needed/month</div>
            <div class="km-value teal" id="calls-needed">-</div>
            <div class="km-sub">to hit target utilization</div>
          </div>
          <div class="km-card">
            <div class="km-label">Max marketing spend</div>
            <div class="km-value" id="max-spend">-</div>
            <div class="km-sub">before diminishing returns</div>
          </div>
          <div class="km-card">
            <div class="km-label">Job capacity/month</div>
            <div class="km-value" id="job-capacity">-</div>
            <div class="km-sub">at full team utilization</div>
          </div>
          <div class="km-card">
            <div class="km-label">Revenue potential</div>
            <div class="km-value teal" id="rev-potential">-</div>
            <div class="km-sub">at target utilization</div>
          </div>
        </div>

        <div class="section-title">Breakdown</div>
        <div class="rows">
          <div class="row"><span class="rk">Total monthly job capacity</span><span class="rv" id="r-capacity">-</span></div>
          <div class="row"><span class="rk">Target jobs/month (at utilization)</span><span class="rv" id="r-target-jobs">-</span></div>
          <div class="row"><span class="rk">Calls needed at your close rate</span><span class="rv" id="r-calls-needed">-</span></div>
          <div class="row"><span class="rk">Max useful ad spend</span><span class="rv" id="r-max-spend">-</span></div>
          <div class="row"><span class="rk">Cost per job ceiling</span><span class="rv" id="r-cpj-ceiling">-</span></div>
        </div>

        <div class="utilization-bar">
          <div class="ub-label">
            <span>Utilization target</span>
            <span id="util-label">-</span>
          </div>
          <div class="ub-track"><div class="ub-fill" id="util-fill" style="width:0%"></div></div>
        </div>

        <div class="diagnosis" id="diagnosis">
          <div class="dt" id="diag-title">-</div>
          <div class="db" id="diag-body">-</div>
        </div>

        <a href="/apply?service=audit&source=capacity-planner" class="audit-cta">Get Your Full Revenue Leak Audit</a>
        <p class="audit-note">The audit shows whether your current spend is above or below your capacity ceiling - and which channels are filling jobs vs. burning budget.</p>
      </div>
    </div>
  </div>
</div>

<script>
function fmt(n)  { return '$' + Math.round(n).toLocaleString(); }
function fmtN(n) { return Math.round(n).toLocaleString(); }

document.getElementById('calc-btn').addEventListener('click', calculate);

function calculate() {
  const techs       = parseFloat(document.getElementById('techs').value)        || 0;
  const jobsPerDay  = parseFloat(document.getElementById('jobs-per-day').value) || 0;
  const workDays    = parseFloat(document.getElementById('working-days').value) || 0;
  const avgTicket   = parseFloat(document.getElementById('avg-ticket').value)   || 0;
  const closeRate   = parseFloat(document.getElementById('close-rate').value)   || 0;
  const utilTarget  = parseFloat(document.getElementById('utilization').value)  || 80;

  if (!techs || !jobsPerDay || !workDays || !avgTicket || !closeRate) {
    document.getElementById('calc-btn').textContent = 'Please fill in all fields';
    setTimeout(() => document.getElementById('calc-btn').textContent = 'Calculate My Capacity Needs', 2000);
    return;
  }

  const cr           = Math.min(closeRate, 100) / 100;
  const utilPct      = Math.min(utilTarget, 100) / 100;
  const totalCap     = techs * jobsPerDay * workDays;
  const targetJobs   = totalCap * utilPct;
  const callsNeeded  = targetJobs / cr;
  const revPotential = targetJobs * avgTicket;
  // Max spend: industry standard is max 10% of job revenue
  const maxSpend     = revPotential * 0.10;
  const cpjCeiling   = maxSpend / targetJobs;

  // Status
  const status = document.getElementById('rp-status');
  status.textContent = 'Plan calculated';
  status.className   = 'rp-status s-good';

  // Key metrics
  document.getElementById('calls-needed').textContent  = fmtN(callsNeeded) + '/mo';
  document.getElementById('max-spend').textContent     = fmt(maxSpend) + '/mo';
  document.getElementById('job-capacity').textContent  = fmtN(totalCap) + '/mo';
  document.getElementById('rev-potential').textContent = fmt(revPotential) + '/mo';

  // Breakdown
  document.getElementById('r-capacity').textContent    = fmtN(totalCap) + ' jobs/month';
  document.getElementById('r-target-jobs').textContent = fmtN(targetJobs) + ' jobs/month';
  document.getElementById('r-calls-needed').textContent= fmtN(callsNeeded) + ' calls/month';
  document.getElementById('r-max-spend').textContent   = fmt(maxSpend) + '/month';
  document.getElementById('r-cpj-ceiling').textContent = fmt(cpjCeiling) + ' per booked job';

  // Utilization bar
  document.getElementById('util-label').textContent    = utilTarget + '%';
  const fillEl = document.getElementById('util-fill');
  fillEl.style.width      = Math.min(utilTarget, 100) + '%';
  fillEl.style.background = utilTarget > 90 ? 'var(--neg)' : utilTarget > 80 ? '#C9A035' : 'var(--pos)';

  // Diagnosis
  const diagEl    = document.getElementById('diagnosis');
  const diagTitle = document.getElementById('diag-title');
  const diagBody  = document.getElementById('diag-body');
  if (utilTarget > 90) {
    diagEl.className    = 'diagnosis warn';
    diagTitle.textContent = 'Running too hot - no room for surges.';
    diagBody.textContent  = `At ${utilTarget}% utilization there's no buffer for unexpected demand or emergency calls. Consider targeting 80–85% and using the remaining capacity as your surge reserve.`;
  } else if (cr < 0.30) {
    diagEl.className    = 'diagnosis';
    diagTitle.textContent = 'Low close rate is multiplying your lead costs.';
    diagBody.textContent  = `At ${closeRate}% close rate, you need ${fmtN(callsNeeded)} calls to fill ${fmtN(targetJobs)} jobs. If you raised your close rate to 45%, you'd need ${fmtN(targetJobs / 0.45).toLocaleString()} calls - ${fmtN(callsNeeded - targetJobs / 0.45)} fewer. Fix the close rate before scaling spend.`;
  } else {
    diagEl.className    = 'diagnosis good';
    diagTitle.textContent = `You need ${fmtN(callsNeeded)} calls/month to hit your targets.`;
    diagBody.textContent  = `Your maximum efficient marketing spend is ${fmt(maxSpend)}/month - anything beyond that and you're generating more leads than your team can convert at your current capacity. If you want to grow beyond that, hire first.`;
  }

  document.getElementById('empty-state').style.display = 'none';
  document.getElementById('results').classList.add('show');
}
</script>
</ToolLayout>
