---
import ToolShareResult from '../../components/ToolShareResult.astro';
import ToolLayout from '../../layouts/ToolLayout.astro';

const suiteTools = [
  { num: '01', name: 'Phone Revenue', href: '/tools/phone-calculator' },
  { num: '02', name: 'Estimate Follow-Up', href: '/tools/estimate-follow-up' },
  { num: '03', name: 'Agency Report Card', href: '/tools/agency-report-card' },
  { num: '04', name: 'Revenue Per Tech', href: '/tools/revenue-per-tech' },
  { num: '05', name: 'Marketing Cost', href: '/tools/marketing-calculator' },
  { num: '07', name: 'Website Conversion', href: '/tools/website-audit' },
];
---
<ToolLayout
  toolNumber="06"
  toolCount="07"
  toolName="Google Business Profile Scorecard"
  slug="gbp-scorecard"
  showCrossTool={false}
  headline="How Strong Is Your Google Business Profile?<br><em>Score It in 3 Minutes.</em>"
  subheadline="The map pack is one of the best free lead sources in HVAC. Most companies are giving ground to competitors on basic GBP factors they do not even know about. Score yourself on the same rubric we use for HVAC competitor teardowns."
  metaDescription="HVAC Google Business Profile scorecard. Score your GBP on a 35-point rubric and see where you are giving up map pack ground to stronger competitors."
>


<div class="tool-layout" slot="tool-body">
  <div class="input-panel">
    <div class="ip-header">
      <span class="ip-title">GBP Self-Assessment Rubric</span>
      <span class="ip-micro">35-point scorecard</span>
    </div>
    <div class="ip-body">
      <p class="ip-note">Score yourself based on what is actually live on your profile right now. The value of this tool is not the grade alone. It is seeing which section is giving away the most map pack ground.</p>

      <div class="section">
        <div class="section-title">Profile Basics</div>
        <div class="question">
          <label class="question-label" for="q1">Primary category</label>
          <select class="field-select" id="q1">
            <option value="">Select your current setup</option>
            <option value="3">HVAC contractor or the closest exact HVAC category match</option>
            <option value="1">Close but not exact</option>
            <option value="0">Wrong or missing</option>
          </select>
        </div>
        <div class="question">
          <label class="question-label" for="q2">Business hours</label>
          <select class="field-select" id="q2">
            <option value="">Select your current setup</option>
            <option value="2">All 7 days listed</option>
            <option value="1">5-6 days</option>
            <option value="0">Missing or incomplete</option>
          </select>
        </div>
        <div class="question">
          <label class="question-label" for="q3">Services listed on profile</label>
          <select class="field-select" id="q3">
            <option value="">Select your current setup</option>
            <option value="3">Full service list with individual services</option>
            <option value="2">Partial list</option>
            <option value="0">None listed</option>
          </select>
        </div>
        <div class="question">
          <label class="question-label" for="q4">Business description</label>
          <select class="field-select" id="q4">
            <option value="">Select your current setup</option>
            <option value="3">Specific - mentions trade, city, key services, years in business</option>
            <option value="1">Generic</option>
            <option value="0">Empty</option>
          </select>
        </div>
      </div>

      <div class="section">
        <div class="section-title">Photos and Posts</div>
        <div class="question">
          <label class="question-label" for="q5">Photo count</label>
          <select class="field-select" id="q5">
            <option value="">Select your current setup</option>
            <option value="4">20 or more photos</option>
            <option value="3">10-19</option>
            <option value="2">5-9</option>
            <option value="1">Fewer than 5</option>
          </select>
        </div>
        <div class="question">
          <label class="question-label" for="q6">Most recent Google Post</label>
          <select class="field-select" id="q6">
            <option value="">Select your current setup</option>
            <option value="3">Within last 30 days</option>
            <option value="2">Within 90 days</option>
            <option value="1">Within 6 months</option>
            <option value="0">Older than 6 months or none</option>
          </select>
        </div>
      </div>

      <div class="section">
        <div class="section-title">Reviews</div>
        <div class="question">
          <label class="question-label" for="q7">Total Google review count</label>
          <select class="field-select" id="q7">
            <option value="">Select your current setup</option>
            <option value="5">500 or more</option>
            <option value="4">300-499</option>
            <option value="3">150-299</option>
            <option value="2">50-149</option>
            <option value="1">Fewer than 50</option>
          </select>
        </div>
        <div class="question">
          <label class="question-label" for="q8">Average star rating</label>
          <select class="field-select" id="q8">
            <option value="">Select your current setup</option>
            <option value="3">4.8 or higher</option>
            <option value="2">4.5-4.7</option>
            <option value="1">4.0-4.4</option>
            <option value="0">Below 4.0</option>
          </select>
        </div>
        <div class="question">
          <label class="question-label" for="q9">Reviews per month (velocity)</label>
          <select class="field-select" id="q9">
            <option value="">Select your current setup</option>
            <option value="4">15 or more</option>
            <option value="3">10-14</option>
            <option value="2">5-9</option>
            <option value="1">2-4</option>
            <option value="0">Fewer than 2</option>
          </select>
        </div>
      </div>

      <div class="section">
        <div class="section-title">Engagement</div>
        <div class="question">
          <label class="question-label" for="q10">Owner response rate on reviews</label>
          <select class="field-select" id="q10">
            <option value="">Select your current setup</option>
            <option value="4">Responding to 90%+ of reviews</option>
            <option value="3">70-89%</option>
            <option value="2">50-69%</option>
            <option value="1">Below 50%</option>
            <option value="0">Not responding</option>
          </select>
        </div>
        <div class="question">
          <label class="question-label" for="q11">Q&amp;A section</label>
          <select class="field-select" id="q11">
            <option value="">Select your current setup</option>
            <option value="2">3 or more questions answered</option>
            <option value="1">1-2 answered</option>
            <option value="0">None</option>
          </select>
        </div>
      </div>

      <button class="calc-btn" id="calc-btn">Score My GBP</button>
    </div>
  </div>

  <div class="result-panel">
    <div class="rp-header">
      <span class="rp-title">GBP Scorecard</span>
      <span class="rp-status status-wait" id="rp-status">Waiting for your answers</span>
    </div>
    <div class="rp-body">
      <div class="empty-state" id="empty-state">
        <div class="empty-icon">06</div>
        <p class="empty-text"><strong>Map pack leaders are usually doing the basics better.</strong><br /><br />This 35-point scorecard shows whether your profile is solid, average, or quietly leaking visibility every week.</p>
      </div>

      <div class="result-section" id="results">
        <div class="grade-block">
          <div class="grade-label">Your GBP Score</div>
          <div class="score-line" id="score-line">0/35</div>
          <div class="grade-value" id="grade-value">F</div>
          <div class="verdict" id="grade-verdict">Your Google Business Profile is not set up to compete. Basic work here would move the needle immediately.</div>
        </div>

        <div class="breakdown-title">Section breakdown</div>
        <div class="breakdown-rows">
          <div class="breakdown-row"><span class="breakdown-key">Profile Basics</span><span class="breakdown-value" id="section1-score">0/11</span></div>
          <div class="breakdown-row"><span class="breakdown-key">Photos and Posts</span><span class="breakdown-value" id="section2-score">0/7</span></div>
          <div class="breakdown-row"><span class="breakdown-key">Reviews</span><span class="breakdown-value" id="section3-score">0/12</span></div>
          <div class="breakdown-row"><span class="breakdown-key">Engagement</span><span class="breakdown-value" id="section4-score">0/5</span></div>
        </div>

        <div class="context-title">Benchmark context</div>
        <div class="context-list" id="context-list"></div>

        <p class="psych-line">Map pack position is not just about review count. It is the combination of every factor above, run consistently. The companies ahead of you in your market are not doing anything exotic. They are just doing all of this right.</p>
        <p class="consequence-line" id="consequence-line">The sections below benchmark show where your profile is quietly giving away map pack ground every week.</p>

        <a href="/report?source=gbp-scorecard" class="btn btn--primary tool-cta">
          <span class="tool-cta-title">Request your report</span>
          <span class="tool-cta-copy">This score shows your profile strength. The full report compares you directly against the companies taking calls in your market.</span>
        </a>
        <p class="cta-note">A stronger profile matters because local visibility turns into calls. The report shows the live competitive gap.</p>

        <ToolShareResult sectionId="share-section" profile="mixed" />

        <div class="result-rail">
          <div class="rail-title">Continue your diagnosis</div>
          <div class="rail-grid">
            {suiteTools.map((tool) => (
              <a href={tool.href} class="rail-link">
                <span class="rail-num">{tool.num}</span>
                <span class="rail-name">{tool.name}</span>
              </a>
            ))}
          </div>
          <a href="/report?source=gbp-scorecard" class="full-picture">
            <span class="full-picture-label">Next step</span>
            <span class="full-picture-title">HVAC Local Market Report</span>
            <span class="full-picture-copy">See your profile side by side with the competitors taking more calls in your city.</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const verdicts = {
  A: 'Strong profile. You are competing well in the map pack on the factors you control.',
  'A-': 'Strong profile. You are competing well in the map pack on the factors you control.',
  'B+': 'Solid base with clear gaps. A few improvements could meaningfully move your map pack position.',
  B: 'Solid base with clear gaps. A few improvements could meaningfully move your map pack position.',
  C: 'Average profile in a market where your competitors are pulling ahead on these factors.',
  D: 'Your GBP is giving away map pack ground every week. The gaps are fixable but they compound.',
  F: 'Your Google Business Profile is not set up to compete. Basic work here would move the needle immediately.',
};

document.getElementById('calc-btn').addEventListener('click', calculate);

const questionIds = ['q1', 'q2', 'q3', 'q4', 'q5', 'q6', 'q7', 'q8', 'q9', 'q10', 'q11'];

function getGrade(score) {
  if (score >= 30) return 'A';
  if (score >= 26) return 'A-';
  if (score >= 22) return 'B+';
  if (score >= 18) return 'B';
  if (score >= 13) return 'C';
  if (score >= 8) return 'D';
  return 'F';
}

function setStatus(grade) {
  const status = document.getElementById('rp-status');
  if (grade === 'A' || grade === 'A-') {
    status.textContent = 'Strong profile';
    status.className = 'rp-status status-good';
    return;
  }
  if (grade === 'B+' || grade === 'B' || grade === 'C') {
    status.textContent = 'Map pack gaps found';
    status.className = 'rp-status status-warn';
    return;
  }
  status.textContent = 'Serious GBP gaps';
  status.className = 'rp-status status-alert';
}

function revealShare(score, grade) {
  const shareSection = document.getElementById('share-section');
  const toolUrl = window.location.origin + window.location.pathname;
  const consequenceLine = document.getElementById('consequence-line').textContent;
  const internalSummary = `Our Google Business Profile scored ${score}/35 (${grade}) on the Built on Tenth scorecard. ${toolUrl}`;
  const publicSummary = `Scored my HVAC Google Business Profile on a 35-point scorecard. Got ${score}/35 (${grade}). HVAC GBP scorecard: ${toolUrl} via @builtontenth`;
  shareSection.dataset.toolUrl = toolUrl;
  shareSection.dataset.internalShareText = internalSummary;
  shareSection.dataset.publicShareText = publicSummary;
  shareSection.dataset.emailSubject = `GBP scorecard: ${score}/35 (${grade})`;
  shareSection.dataset.emailBody = `${internalSummary}\n\n${consequenceLine}`;
  shareSection.hidden = false;
}

function calculate() {
  const hasMissingAnswer = questionIds.some((id) => document.getElementById(id).value === '');
  if (hasMissingAnswer) {
    const button = document.getElementById('calc-btn');
    button.textContent = 'Please answer every question';
    window.setTimeout(() => {
      button.textContent = 'Score My GBP';
    }, 2000);
    return;
  }

  const section1 = ['q1', 'q2', 'q3', 'q4'].reduce((sum, id) => sum + parseInt(document.getElementById(id).value, 10), 0);
  const section2 = ['q5', 'q6'].reduce((sum, id) => sum + parseInt(document.getElementById(id).value, 10), 0);
  const section3 = ['q7', 'q8', 'q9'].reduce((sum, id) => sum + parseInt(document.getElementById(id).value, 10), 0);
  const section4 = ['q10', 'q11'].reduce((sum, id) => sum + parseInt(document.getElementById(id).value, 10), 0);
  const total = section1 + section2 + section3 + section4;
  const grade = getGrade(total);

  window.botTrack?.('tool_calculation', {
    tool_name: 'gbp-scorecard',
    grade: grade.toLowerCase().replace('+', 'plus').replace('-', 'minus'),
    score_bucket: total >= 26 ? '26_plus' : total >= 18 ? '18_to_25' : 'under_18',
  });

  setStatus(grade);

  document.getElementById('score-line').textContent = `${total}/35`;
  document.getElementById('grade-value').textContent = grade;
  document.getElementById('grade-verdict').textContent = verdicts[grade];
  document.getElementById('section1-score').textContent = `${section1}/11`;
  document.getElementById('section2-score').textContent = `${section2}/7`;
  document.getElementById('section3-score').textContent = `${section3}/12`;
  document.getElementById('section4-score').textContent = `${section4}/5`;

  const context = [];
  if (section1 < 8) {
    context.push({
      title: 'Profile Basics below 8/11',
      body: 'Dominant companies in top US markets average 9-10 on this section. Primary category, hours, and services are table stakes.',
    });
  }
  if (section2 < 5) {
    context.push({
      title: 'Photos and Posts below 5/7',
      body: 'Companies owning the map pack in competitive markets post at least every 3 weeks and maintain 20+ photos. This is low-cost and consistently underused by mid-size operators.',
    });
  }
  if (section3 < 9) {
    context.push({
      title: 'Reviews below 9/12',
      body: 'Top map pack positions in most mid-size markets require 200+ reviews at 4.7+ with 8-12 new reviews per month. Velocity matters more than total count once you pass 150.',
    });
  }
  if (section4 < 3) {
    context.push({
      title: 'Engagement below 3/5',
      body: 'Owner response rate above 90% is the single most underrated map pack signal. Most companies respond to less than half their reviews.',
    });
  }

  const contextList = document.getElementById('context-list');
  if (context.length === 0) {
    contextList.innerHTML = '<div class="context-item"><strong>No section is below benchmark.</strong><span>Your current profile clears the minimum benchmark lines across all four sections. The next step is comparing this against the top 3 profiles in your market.</span></div>';
  } else {
    contextList.innerHTML = context.map((item) => `<div class="context-item"><strong>${item.title}</strong><span>${item.body}</span></div>`).join('');
  }

  document.getElementById('consequence-line').textContent = context.length === 0
    ? 'You have the basics in place. The next move is comparing your profile against the local competitors taking the most map pack clicks.'
    : 'The sections below benchmark show where your profile is quietly giving away map pack ground every week.';

  revealShare(total, grade);

  document.getElementById('empty-state').hidden = true;
  document.getElementById('results').classList.add('show');
}
</script>
</ToolLayout>
