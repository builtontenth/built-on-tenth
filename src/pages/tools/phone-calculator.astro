---
import ToolShareResult from '../../components/ToolShareResult.astro';
import ToolLayout from '../../layouts/ToolLayout.astro';

const suiteTools = [
  { num: '02', name: 'Estimate Follow-Up', href: '/tools/estimate-follow-up' },
  { num: '03', name: 'Agency Report Card', href: '/tools/agency-report-card' },
  { num: '04', name: 'Revenue Per Tech', href: '/tools/revenue-per-tech' },
  { num: '05', name: 'Marketing Cost', href: '/tools/marketing-calculator' },
  { num: '06', name: 'GBP Scorecard', href: '/tools/gbp-scorecard' },
  { num: '07', name: 'Website Conversion', href: '/tools/website-audit' },
];
---
<ToolLayout
  toolNumber="01"
  toolCount="07"
  toolName="Phone Revenue Calculator"
  slug="phone-calculator"
  showCrossTool={false}
  headline="Missed Calls = Lost Jobs.<br><em>Here's Exactly What It's Costing You.</em>"
  subheadline="Most owners think they answer 90% of calls. The actual average is 68%. Every unanswered call is a job that went to a competitor. Find out the dollar amount walking out your door every month."
  metaDescription="HVAC phone revenue calculator for missed calls. Enter call volume, answer rate, booking rate, and average ticket to estimate monthly and annual lost revenue."
>


<div class="tool-layout" slot="tool-body">
  <div class="input-panel">
    <div class="ip-header">
      <span class="ip-header-title">Your Numbers</span>
      <span class="ip-micro-proof">Based on HVAC call-handling benchmark ranges</span>
    </div>
    <div class="ip-body">
      <div class="field">
        <div class="field-label">
          Monthly inbound calls
          <span class="field-hint">Total calls - answered + missed</span>
        </div>
        <input type="number" class="field-input" id="total-calls" min="0" />
        <div class="benchmark-hint">
          <span>Industry typical range:</span>
          <span class="bh-val">150-600 calls/month</span>
        </div>
      </div>

      <div class="field">
        <div class="field-label">
          Current answer rate
          <span class="field-hint">% of calls someone actually picks up</span>
        </div>
        <div class="suffix-wrap">
          <span class="suffix">%</span>
          <input type="number" class="field-input" id="answer-rate" min="0" max="100" />
        </div>
        <div class="benchmark-hint">
          <span>Industry average:</span>
          <span class="bh-val">68% · Top 25%: 89%+</span>
        </div>
      </div>

      <div class="field">
        <div class="field-label">
          Booking rate (answered calls)
          <span class="field-hint">% of answered calls that book a job</span>
        </div>
        <div class="suffix-wrap">
          <span class="suffix">%</span>
          <input type="number" class="field-input" id="booking-rate" min="0" max="100" />
        </div>
        <div class="benchmark-hint">
          <span>Industry average:</span>
          <span class="bh-val">38% · Top 25%: 58%+</span>
        </div>
      </div>

      <div class="field">
        <div class="field-label">
          Average job value
          <span class="field-hint">Avg ticket for a booked job</span>
        </div>
        <div class="prefix-wrap">
          <span class="prefix">$</span>
          <input type="number" class="field-input" id="avg-ticket" min="0" />
        </div>
      </div>

      <button class="calc-btn" id="calc-btn">Show Me What I'm Losing</button>
    </div>
  </div>

  <div class="result-panel">
    <div class="rp-header">
      <span class="rp-title">Revenue Leak Report</span>
      <span class="rp-status status-waiting" id="rp-status">Waiting for your numbers</span>
    </div>
    <div class="rp-body">
      <div class="empty-state" id="empty-state">
        <div class="empty-icon">📞</div>
        <p class="empty-text">
          <strong>Most owners think they answer 90% of calls.</strong><br><br>
          The actual industry average is 68%. At 300 calls a month, that is 96 calls going unanswered, each one a job that went to a competitor.
        </p>
      </div>

      <div class="result-section" id="results">
        <div class="main-number">
          <div class="mn-label">Annual revenue leaking from missed calls</div>
          <div class="mn-value" id="annual-loss">$0</div>
          <div class="mn-sub" id="monthly-loss-sub">Monthly: $0 · <span id="missed-calls-sub">0 calls missed/month</span></div>
        </div>

        <div class="breakdown">
          <div class="bd-title">Breakdown</div>
          <div class="bd-rows">
            <div class="bd-row"><span class="bd-key">Total calls/month</span><span class="bd-val" id="r-total-calls">-</span></div>
            <div class="bd-row"><span class="bd-key">Calls missed/month</span><span class="bd-val red" id="r-missed">-</span></div>
            <div class="bd-row"><span class="bd-key">Jobs lost to missed calls</span><span class="bd-val red" id="r-lost-jobs">-</span></div>
            <div class="bd-row"><span class="bd-key">Monthly revenue lost</span><span class="bd-val red" id="r-monthly">-</span></div>
            <div class="bd-row"><span class="bd-key">Your answer rate</span><span class="bd-val" id="r-answer-rate">-</span></div>
          </div>
        </div>

        <div class="bm-wrap">
          <div class="bm-label">
            <span>Your answer rate</span>
            <span>Target: 89%+</span>
          </div>
          <div class="bm-track">
            <div class="bm-fill" id="bm-fill">
              <div class="bm-marker"><div class="bm-marker-tip" id="bm-tip">You</div></div>
            </div>
          </div>
          <div class="bm-range"><span>0%</span><span>Industry avg 68%</span><span>Top 25% 89%+</span><span>100%</span></div>
        </div>

        <div class="diagnosis" id="diagnosis">
          <div class="diag-title" id="diag-title">-</div>
          <div class="diag-body" id="diag-body">-</div>
        </div>

        <div class="recovery">
          <div class="rec-title">If you reach 89% answer rate</div>
          <div class="rec-row"><span>Additional jobs booked/month</span><span class="rec-val" id="rec-jobs">-</span></div>
          <div class="rec-row"><span>Additional monthly revenue</span><span class="rec-val" id="rec-monthly">-</span></div>
          <div class="rec-row"><span>Additional annual revenue</span><span class="rec-val" id="rec-annual">-</span></div>
        </div>

        <a href="/report?source=phone-calculator" class="btn btn--primary audit-cta">
          Request your report
        </a>
        <p class="audit-cta-note">This tool shows what missed calls cost. The full report shows where your total call gap is coming from across the market.</p>

        <ToolShareResult sectionId="share-section" profile="mixed" />

        <div class="result-rail">
          <div class="rail-title">Continue your diagnosis</div>
          <div class="rail-grid">
            {suiteTools.map((tool) => (
              <a href={tool.href} class="rail-link">
                <span class="rail-num">{tool.num}</span>
                <span class="rail-name">{tool.name}</span>
              </a>
            ))}
          </div>
          <a href="/report?source=phone-calculator" class="full-picture">
            <span class="full-picture-label">Next step</span>
            <span class="full-picture-title">HVAC Local Market Report</span>
            <span class="full-picture-copy">See the wider market, visibility, and call gap in one written report.</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.getElementById('calc-btn').addEventListener('click', calculate);
['total-calls','answer-rate','booking-rate','avg-ticket'].forEach(id => {
  document.getElementById(id).addEventListener('keydown', e => { if (e.key === 'Enter') calculate(); });
});

function fmt(n) { return '$' + Math.round(n).toLocaleString(); }
function fmtN(n) { return Math.round(n).toLocaleString(); }

function calculate() {
  const totalCalls  = parseFloat(document.getElementById('total-calls').value)  || 0;
  const answerRate  = parseFloat(document.getElementById('answer-rate').value)   || 0;
  const bookingRate = parseFloat(document.getElementById('booking-rate').value)  || 0;
  const avgTicket   = parseFloat(document.getElementById('avg-ticket').value)    || 0;

  if (!totalCalls || !answerRate || !bookingRate || !avgTicket) {
    document.getElementById('calc-btn').textContent = 'Please fill in all fields';
    setTimeout(() => document.getElementById('calc-btn').textContent = 'Show Me What I\'m Losing', 2000);
    return;
  }

  const ar          = Math.min(answerRate, 100) / 100;
  const br          = Math.min(bookingRate, 100) / 100;
  const missedCalls = totalCalls * (1 - ar);
  const lostJobs    = missedCalls * br;
  const monthlyLoss = lostJobs * avgTicket;
  const annualLoss  = monthlyLoss * 12;

  const targetAR    = Math.min(0.89, 1);
  const recMissed   = totalCalls * (1 - targetAR);
  const recJobsGain = (missedCalls - recMissed) * br;
  const recMonthly  = recJobsGain * avgTicket;
  const recAnnual   = recMonthly * 12;

  window.botTrack?.('tool_calculation', {
    tool_name: 'phone-calculator',
    annual_loss_bucket: annualLoss >= 100000 ? '100k_plus' : annualLoss >= 25000 ? '25k_plus' : 'under_25k',
  });

  const status = document.getElementById('rp-status');
  if (annualLoss > 0) {
    status.textContent = 'Revenue leak found';
    status.className = 'rp-status status-alert';
  } else {
    status.textContent = 'Looking good';
    status.className = 'rp-status status-ok';
  }

  document.getElementById('annual-loss').textContent = fmt(annualLoss);
  document.getElementById('annual-loss').className = `mn-value${annualLoss === 0 ? ' ok' : ''}`;
  document.getElementById('monthly-loss-sub').innerHTML = `Monthly: ${fmt(monthlyLoss)} · <span id="missed-calls-sub">${fmtN(missedCalls)} calls missed/month</span>`;

  document.getElementById('r-total-calls').textContent = fmtN(totalCalls) + '/month';
  document.getElementById('r-missed').textContent = fmtN(missedCalls) + '/month';
  document.getElementById('r-lost-jobs').textContent = fmtN(lostJobs) + '/month';
  document.getElementById('r-monthly').textContent = fmt(monthlyLoss);
  document.getElementById('r-answer-rate').textContent = answerRate + '%';

  const fillPct = Math.min(ar * 100, 100);
  document.getElementById('bm-fill').style.width = fillPct + '%';
  document.getElementById('bm-fill').className = `bm-fill${ar >= 0.89 ? ' ok' : ''}`;
  document.getElementById('bm-tip').textContent = 'You: ' + answerRate + '%';

  const diagEl = document.getElementById('diagnosis');
  const diagTitle = document.getElementById('diag-title');
  const diagBody  = document.getElementById('diag-body');
  if (ar >= 0.89) {
    diagEl.className = 'diagnosis good';
    diagTitle.textContent = 'Your answer rate is strong.';
    diagBody.textContent  = 'You are already in the top 25% of HVAC operators on answer rate. The bigger opportunity is likely in booking rate, follow-up, or local visibility.';
  } else if (ar >= 0.75) {
    diagEl.className = 'diagnosis';
    diagTitle.textContent = 'Room to improve - and it\'s costing you.';
    diagBody.textContent  = 'You\'re answering more than average but still missing 1 in 4 calls. A basic voicemail-to-text system and same-day callback protocol typically closes this gap without hiring.';
  } else {
    diagEl.className = 'diagnosis';
    diagTitle.textContent = 'This is your biggest leak.';
    diagBody.textContent  = 'Below 75% is where the most money gets lost. This isn\'t a marketing problem - it\'s an operations problem. More ad spend before fixing this makes the leak worse, not better.';
  }

  document.getElementById('rec-jobs').textContent   = fmtN(recJobsGain) + '/month';
  document.getElementById('rec-monthly').textContent = fmt(recMonthly);
  document.getElementById('rec-annual').textContent  = fmt(recAnnual);

  const shareSection = document.getElementById('share-section');
  const toolUrl = window.location.origin + window.location.pathname;
  const internalSummary = `We are missing ${fmtN(missedCalls)} calls per month. At our current ticket size, that is ${fmt(monthlyLoss)} per month and ${fmt(annualLoss)} per year in lost revenue. ${toolUrl}`;
  const publicSummary = `I'm missing ${fmtN(missedCalls)} calls/month. At my ticket size that's ${fmt(monthlyLoss)}/month - ${fmt(annualLoss)}/year walking out the door before I've spent another dollar on ads. ${toolUrl}`;
  shareSection.dataset.toolUrl = toolUrl;
  shareSection.dataset.internalShareText = internalSummary;
  shareSection.dataset.publicShareText = publicSummary;
  shareSection.dataset.emailSubject = `Phone revenue leak: ${fmt(annualLoss)} per year`;
  shareSection.dataset.emailBody = `${internalSummary}\n\n${diagBody.textContent}`;
  shareSection.hidden = false;

  document.getElementById('empty-state').hidden = true;
  document.getElementById('results').classList.add('show');
}
</script>
</ToolLayout>
