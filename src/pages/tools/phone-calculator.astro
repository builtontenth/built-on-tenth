---
import ToolLayout from '../../layouts/ToolLayout.astro';
---
<ToolLayout
  toolNumber="01"
  toolName="Phone Revenue Calculator"
  slug="phone-calculator"
  headline="Missed Calls = Lost Jobs.<br><em>Here's Exactly What It's Costing You.</em>"
  subheadline="Most owners think they answer 90% of calls. The actual average is 68%. Every unanswered call is a job that went to a competitor. Find out the dollar amount walking out your door every month."
  metaDescription="Free calculator: find out how much revenue you're losing from missed calls. Enter your call volume, answer rate, and average ticket to see the exact monthly and annual cost."
>

<style>
.tool-layout { display: grid; grid-template-columns: 1fr 480px; gap: 48px; align-items: start; padding-bottom: 80px; }

/* Input panel */
.input-panel { background: var(--bg2); border: 1px solid var(--rule2); border-radius: 8px; overflow: hidden; }
.ip-header { padding: 18px 24px; border-bottom: 1px solid var(--rule); background: var(--bg3); display: flex; align-items: center; justify-content: space-between; }
.ip-header-title { font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink3); }
.ip-micro-proof { font-family: var(--mono); font-size: 9px; color: var(--ink3); opacity: 0.7; }
.ip-body { padding: 24px; }

.field { margin-bottom: 20px; }
.field-label { display: flex; justify-content: space-between; align-items: baseline; font-family: var(--mono); font-size: 9.5px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink3); margin-bottom: 8px; }
.field-hint { font-size: 9px; color: var(--ink3); opacity: 0.65; font-weight: 300; letter-spacing: 0.03em; text-transform: none; }
.field-input {
  width: 100%; background: var(--bg3); border: 1px solid var(--rule2); border-radius: 4px;
  padding: 11px 14px; font-family: var(--sans); font-size: 15px; color: var(--ink); outline: none;
  transition: border-color 0.2s; -moz-appearance: textfield;
}
.field-input::-webkit-inner-spin-button, .field-input::-webkit-outer-spin-button { -webkit-appearance: none; }
.field-input:focus { border-color: rgba(0,196,154,0.55); }
.field-input::placeholder { color: var(--ink3); font-size: 13px; }
.prefix-wrap { position: relative; }
.prefix { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); font-family: var(--mono); font-size: 14px; color: var(--ink3); pointer-events: none; }
.prefix + .field-input { padding-left: 26px; }
.suffix-wrap { position: relative; }
.suffix { position: absolute; right: 13px; top: 50%; transform: translateY(-50%); font-family: var(--mono); font-size: 12px; color: var(--ink3); pointer-events: none; }

.benchmark-hint { margin-top: 6px; font-family: var(--mono); font-size: 9px; color: var(--ink3); padding: 5px 10px; background: var(--bg4); border-radius: 3px; display: flex; justify-content: space-between; }
.bh-val { color: var(--teal); font-weight: 500; }

.calc-btn {
  width: 100%; margin-top: 4px; padding: 14px; border-radius: 4px; cursor: pointer;
  font-family: var(--mono); font-size: 11.5px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--bg); background: var(--teal); border: 1.5px solid var(--teal); transition: all 0.2s;
}
.calc-btn:hover { background: #00DFB0; transform: translateY(-1px); }

/* Result panel */
.result-panel { background: var(--bg2); border: 1px solid var(--rule2); border-radius: 8px; overflow: hidden; position: sticky; top: 80px; }
.rp-header { padding: 18px 24px; border-bottom: 1px solid var(--rule); background: var(--bg3); display: flex; align-items: center; justify-content: space-between; }
.rp-title { font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink3); }
.rp-status { font-family: var(--mono); font-size: 9px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 8px; border-radius: 3px; }
.status-waiting { color: var(--ink3); background: var(--bg4); border: 1px solid var(--rule); }
.status-alert   { color: var(--neg); background: rgba(240,64,64,0.1); border: 1px solid rgba(240,64,64,0.22); }
.status-ok      { color: var(--pos); background: rgba(34,211,122,0.1); border: 1px solid rgba(34,211,122,0.22); }
.rp-body { padding: 24px; }

/* Empty state */
.empty-state { text-align: center; padding: 36px 16px; }
.empty-icon { font-size: 32px; opacity: 0.25; margin-bottom: 14px; }
.empty-text { font-size: 13px; color: var(--ink3); line-height: 1.65; font-weight: 300; }
.empty-text strong { color: var(--ink2); font-weight: 500; }

/* Results */
.result-section { display: none; }
.result-section.show { display: block; }

.main-number { margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--rule); }
.mn-label { font-family: var(--mono); font-size: 9.5px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink3); margin-bottom: 6px; }
.mn-value { font-family: var(--mono); font-size: 54px; font-weight: 600; letter-spacing: -0.04em; line-height: 1; color: var(--neg); transition: all 0.4s; }
.mn-value.ok { color: var(--pos); }
.mn-sub { font-size: 12px; color: var(--ink3); margin-top: 6px; font-weight: 300; }

.breakdown { margin-bottom: 18px; }
.bd-title { font-family: var(--mono); font-size: 9px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink3); margin-bottom: 10px; }
.bd-rows { display: flex; flex-direction: column; gap: 6px; }
.bd-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 10px; background: var(--bg3); border-radius: 3px; }
.bd-key { font-size: 12.5px; color: var(--ink2); font-weight: 300; }
.bd-val { font-family: var(--mono); font-size: 12.5px; font-weight: 600; color: var(--ink); }
.bd-val.red { color: var(--neg); }
.bd-val.grn { color: var(--pos); }

/* Benchmark bar */
.bm-wrap { margin-bottom: 18px; }
.bm-label { font-family: var(--mono); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink3); margin-bottom: 8px; display: flex; justify-content: space-between; }
.bm-track { height: 6px; background: var(--bg4); border-radius: 3px; position: relative; margin-bottom: 10px; }
.bm-fill { height: 100%; border-radius: 3px; background: var(--neg); transition: width 0.8s var(--ease); position: relative; }
.bm-fill.ok { background: var(--pos); }
.bm-marker { position: absolute; right: 0; top: -3px; width: 2px; height: 12px; background: var(--teal); }
.bm-marker-tip { position: absolute; right: 4px; top: -18px; font-family: var(--mono); font-size: 8px; color: var(--teal); white-space: nowrap; }
.bm-range { display: flex; justify-content: space-between; font-family: var(--mono); font-size: 8.5px; color: var(--ink3); }

/* Diagnosis */
.diagnosis { background: rgba(240,64,64,0.06); border: 1px solid rgba(240,64,64,0.2); border-radius: 4px; padding: 14px 16px; margin-bottom: 18px; }
.diagnosis.good { background: rgba(34,211,122,0.06); border-color: rgba(34,211,122,0.2); }
.diag-title { font-size: 13px; font-weight: 600; color: var(--ink); margin-bottom: 6px; }
.diag-body { font-size: 12px; color: var(--ink2); line-height: 1.62; font-weight: 300; }

/* Recovery comparison */
.recovery { background: var(--bg3); border: 1px solid var(--rule2); border-radius: 4px; padding: 16px; margin-bottom: 18px; }
.rec-title { font-family: var(--mono); font-size: 9px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--teal); margin-bottom: 12px; }
.rec-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; font-size: 12.5px; color: var(--ink2); }
.rec-row:last-child { margin-bottom: 0; }
.rec-val { font-family: var(--mono); font-size: 13px; font-weight: 600; color: var(--pos); }

.audit-cta { display: block; width: 100%; padding: 13px; border-radius: 4px; cursor: pointer; text-align: center; font-family: var(--mono); font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--bg); background: var(--teal); border: 1.5px solid var(--teal); text-decoration: none; transition: all 0.2s; }
.audit-cta:hover { background: #00DFB0; }
.audit-cta-note { font-size: 11px; color: var(--ink3); text-align: center; margin-top: 10px; font-weight: 300; }

@media (max-width: 960px) {
  .tool-layout { grid-template-columns: 1fr; padding-bottom: 56px; }
  .result-panel { position: static; }
}
</style>

<div class="tool-layout" slot="tool-body">

  <!-- INPUT PANEL -->
  <div class="input-panel">
    <div class="ip-header">
      <span class="ip-header-title">Your Numbers</span>
      <span class="ip-micro-proof">Based on patterns from 200+ home service companies</span>
    </div>
    <div class="ip-body">

      <div class="field">
        <div class="field-label">
          Monthly inbound calls
          <span class="field-hint">total calls - answered + missed</span>
        </div>
        <input type="number" class="field-input" id="total-calls" placeholder="e.g. 350" min="0" />
        <div class="benchmark-hint">
          <span>Industry typical range:</span>
          <span class="bh-val">150 – 600 calls/month</span>
        </div>
      </div>

      <div class="field">
        <div class="field-label">
          Current answer rate
          <span class="field-hint">% of calls someone actually picks up</span>
        </div>
        <div class="suffix-wrap">
          <span class="suffix">%</span>
          <input type="number" class="field-input" id="answer-rate" placeholder="e.g. 72" min="0" max="100" />
        </div>
        <div class="benchmark-hint">
          <span>Industry average:</span>
          <span class="bh-val">68% · Top 25%: 89%+</span>
        </div>
      </div>

      <div class="field">
        <div class="field-label">
          Booking rate (answered calls)
          <span class="field-hint">% of answered calls that book a job</span>
        </div>
        <div class="suffix-wrap">
          <span class="suffix">%</span>
          <input type="number" class="field-input" id="booking-rate" placeholder="e.g. 45" min="0" max="100" />
        </div>
        <div class="benchmark-hint">
          <span>Industry average:</span>
          <span class="bh-val">38% · Top 25%: 58%+</span>
        </div>
      </div>

      <div class="field">
        <div class="field-label">
          Average job value
          <span class="field-hint">avg ticket for a booked job</span>
        </div>
        <div class="prefix-wrap">
          <span class="prefix">$</span>
          <input type="number" class="field-input" id="avg-ticket" placeholder="e.g. 1800" min="0" />
        </div>
      </div>

      <button class="calc-btn" id="calc-btn">Show Me What I'm Losing</button>
    </div>
  </div>

  <!-- RESULT PANEL -->
  <div class="result-panel">
    <div class="rp-header">
      <span class="rp-title">Revenue Leak Report</span>
      <span class="rp-status status-waiting" id="rp-status">Waiting for your numbers</span>
    </div>
    <div class="rp-body">

      <!-- Empty state -->
      <div class="empty-state" id="empty-state">
        <div class="empty-icon">📞</div>
        <p class="empty-text">
          <strong>Most owners think they answer 90% of calls.</strong><br><br>
          The actual industry average is 68%. At 300 calls a month, that's 96 calls going unanswered - each one a job that went to a competitor.
        </p>
      </div>

      <!-- Results (hidden until calculated) -->
      <div class="result-section" id="results">

        <div class="main-number">
          <div class="mn-label">Annual revenue leaking from missed calls</div>
          <div class="mn-value" id="annual-loss">$0</div>
          <div class="mn-sub" id="monthly-loss-sub">Monthly: $0 · <span id="missed-calls-sub">0 calls missed/month</span></div>
        </div>

        <div class="breakdown">
          <div class="bd-title">Breakdown</div>
          <div class="bd-rows">
            <div class="bd-row"><span class="bd-key">Total calls/month</span><span class="bd-val" id="r-total-calls">-</span></div>
            <div class="bd-row"><span class="bd-key">Calls missed/month</span><span class="bd-val red" id="r-missed">-</span></div>
            <div class="bd-row"><span class="bd-key">Jobs lost to missed calls</span><span class="bd-val red" id="r-lost-jobs">-</span></div>
            <div class="bd-row"><span class="bd-key">Monthly revenue lost</span><span class="bd-val red" id="r-monthly">-</span></div>
            <div class="bd-row"><span class="bd-key">Your answer rate</span><span class="bd-val" id="r-answer-rate">-</span></div>
          </div>
        </div>

        <div class="bm-wrap">
          <div class="bm-label">
            <span>Your answer rate</span>
            <span>Target: 89%+</span>
          </div>
          <div class="bm-track">
            <div class="bm-fill" id="bm-fill" style="width:0%">
              <div class="bm-marker"><div class="bm-marker-tip" id="bm-tip">You</div></div>
            </div>
          </div>
          <div class="bm-range"><span>0%</span><span>Industry avg 68%</span><span>Top 25% 89%+</span><span>100%</span></div>
        </div>

        <div class="diagnosis" id="diagnosis">
          <div class="diag-title" id="diag-title">-</div>
          <div class="diag-body" id="diag-body">-</div>
        </div>

        <div class="recovery">
          <div class="rec-title">If you reach 89% answer rate</div>
          <div class="rec-row"><span>Additional jobs booked/month</span><span class="rec-val" id="rec-jobs">-</span></div>
          <div class="rec-row"><span>Additional monthly revenue</span><span class="rec-val" id="rec-monthly">-</span></div>
          <div class="rec-row"><span>Additional annual revenue</span><span class="rec-val" id="rec-annual">-</span></div>
        </div>

        <a href="/apply?service=audit&source=phone-calculator" class="audit-cta">
          See All Your Revenue Leaks - Get Audit
        </a>
        <p class="audit-cta-note">Fixing this alone often outperforms increasing ad spend. The audit shows every leak together.</p>
      </div>

    </div>
  </div>

</div>

<script>
document.getElementById('calc-btn').addEventListener('click', calculate);
['total-calls','answer-rate','booking-rate','avg-ticket'].forEach(id => {
  document.getElementById(id).addEventListener('keydown', e => { if (e.key === 'Enter') calculate(); });
});

function fmt(n) { return '$' + Math.round(n).toLocaleString(); }
function fmtN(n) { return Math.round(n).toLocaleString(); }

function calculate() {
  const totalCalls  = parseFloat(document.getElementById('total-calls').value)  || 0;
  const answerRate  = parseFloat(document.getElementById('answer-rate').value)   || 0;
  const bookingRate = parseFloat(document.getElementById('booking-rate').value)  || 0;
  const avgTicket   = parseFloat(document.getElementById('avg-ticket').value)    || 0;

  if (!totalCalls || !answerRate || !bookingRate || !avgTicket) {
    document.getElementById('calc-btn').textContent = 'Please fill in all fields';
    setTimeout(() => document.getElementById('calc-btn').textContent = 'Show Me What I\'m Losing', 2000);
    return;
  }

  const ar          = Math.min(answerRate, 100) / 100;
  const br          = Math.min(bookingRate, 100) / 100;
  const missedCalls = totalCalls * (1 - ar);
  const lostJobs    = missedCalls * br;
  const monthlyLoss = lostJobs * avgTicket;
  const annualLoss  = monthlyLoss * 12;

  // Recovery to 89%
  const targetAR    = Math.min(0.89, 1);
  const recCallsAns = totalCalls * targetAR;
  const recMissed   = totalCalls * (1 - targetAR);
  const recJobsGain = (missedCalls - recMissed) * br;
  const recMonthly  = recJobsGain * avgTicket;
  const recAnnual   = recMonthly * 12;

  // Update status
  const status = document.getElementById('rp-status');
  if (annualLoss > 0) {
    status.textContent = 'Revenue leak found';
    status.className = 'rp-status status-alert';
  } else {
    status.textContent = 'Looking good';
    status.className = 'rp-status status-ok';
  }

  // Populate results
  document.getElementById('annual-loss').textContent = fmt(annualLoss);
  document.getElementById('annual-loss').className = `mn-value${annualLoss === 0 ? ' ok' : ''}`;
  document.getElementById('monthly-loss-sub').innerHTML = `Monthly: ${fmt(monthlyLoss)} · <span id="missed-calls-sub">${fmtN(missedCalls)} calls missed/month</span>`;

  document.getElementById('r-total-calls').textContent = fmtN(totalCalls) + '/month';
  document.getElementById('r-missed').textContent = fmtN(missedCalls) + '/month';
  document.getElementById('r-lost-jobs').textContent = fmtN(lostJobs) + '/month';
  document.getElementById('r-monthly').textContent = fmt(monthlyLoss);
  document.getElementById('r-answer-rate').textContent = answerRate + '%';

  // Benchmark bar
  const fillPct = Math.min(ar * 100, 100);
  document.getElementById('bm-fill').style.width = fillPct + '%';
  document.getElementById('bm-fill').className = `bm-fill${ar >= 0.89 ? ' ok' : ''}`;
  document.getElementById('bm-tip').textContent = 'You: ' + answerRate + '%';

  // Diagnosis
  const diagEl = document.getElementById('diagnosis');
  const diagTitle = document.getElementById('diag-title');
  const diagBody  = document.getElementById('diag-body');
  if (ar >= 0.89) {
    diagEl.className = 'diagnosis good';
    diagTitle.textContent = 'Your answer rate is strong.';
    diagBody.textContent  = 'You\'re in the top 25% of home service companies. The leak here is minimal - your biggest opportunity is likely in booking rate, follow-up, or marketing channel mix. Use the other tools to find it.';
  } else if (ar >= 0.75) {
    diagEl.className = 'diagnosis';
    diagTitle.textContent = 'Room to improve - and it\'s costing you.';
    diagBody.textContent  = 'You\'re answering more than average but still missing 1 in 4 calls. A basic voicemail-to-text system and same-day callback protocol typically closes this gap without hiring.';
  } else {
    diagEl.className = 'diagnosis';
    diagTitle.textContent = 'This is your biggest leak.';
    diagBody.textContent  = 'Below 75% is where the most money gets lost. This isn\'t a marketing problem - it\'s an operations problem. More ad spend before fixing this makes the leak worse, not better.';
  }

  // Recovery
  document.getElementById('rec-jobs').textContent   = fmtN(recJobsGain) + '/month';
  document.getElementById('rec-monthly').textContent = fmt(recMonthly);
  document.getElementById('rec-annual').textContent  = fmt(recAnnual);

  // Show results
  document.getElementById('empty-state').style.display = 'none';
  document.getElementById('results').classList.add('show');
}
</script>
</ToolLayout>
