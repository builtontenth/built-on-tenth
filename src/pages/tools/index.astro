---
import Layout from '../../layouts/Layout.astro';
import ResponsiveImage from '../../components/ResponsiveImage.astro';

const tools = [
  {
    id: 'phone-calculator',
    icon: '📞',
    badge: 'HVAC Calculator',
    name: 'Phone Revenue Calculator',
    tagline: 'Missed Calls = Lost Jobs',
    desc: "Most owners think they answer 90% of calls. The actual average is 68%. Every unanswered call is a job that went to a competitor. Find out the dollar amount walking out your door every month.",
    cta: 'See your lost revenue',
    img: '/images/brand/core/tool-phone-calculator.png',
    imgAlt: 'Inbound calls being handled at the front desk',
    dataPoints: ['Monthly revenue lost', 'Recovery projection', 'Answer rate benchmark'],
  },
  {
    id: 'estimate-follow-up',
    icon: '📨',
    badge: 'HVAC Calculator',
    name: 'Estimate Follow-Up Calculator',
    tagline: '68% of Estimates Never Get a Follow-Up',
    desc: 'Most owners blame the homeowner for not calling back. The data says otherwise. Enter your estimate volume and see exactly how much revenue is dying in your outbox every year.',
    cta: 'See the follow-up gap',
    img: '/images/brand/core/tool-estimate-follow-up.png',
    imgAlt: 'Sorting stale estimates and follow-up notes',
    dataPoints: ['Annual lost revenue', 'Follow-up benchmark', '50% and 80% what-if lift'],
  },
  {
    id: 'agency-report-card',
    icon: '📋',
    badge: 'HVAC Calculator',
    name: 'Agency Report Card',
    tagline: 'Is Your Agency Measuring the Right Numbers?',
    desc: 'Every agency reports impressions, clicks, and cost per lead. Almost none report the number that actually matters: cost per booked job. Answer 10 questions and get a straight grade.',
    cta: 'Grade your agency',
    img: '/images/brand/core/tool-agency-report-card.png',
    imgAlt: 'Reviewing printed agency reports with skepticism',
    dataPoints: ['Agency accountability grade', '10 yes or no checks', 'No-answer consequence lines'],
  },
  {
    id: 'revenue-per-tech',
    icon: '🛠️',
    badge: 'HVAC Calculator',
    name: 'Revenue Per Technician Benchmarker',
    tagline: 'How Much Revenue Is Each Tech Producing?',
    desc: 'Most owners track total revenue. Very few track revenue per tech, the number that tells you whether your team is running at capacity or leaving jobs on the table. Enter your numbers and see exactly where you stand.',
    cta: 'Benchmark your team',
    img: '/images/brand/core/tool-revenue-per-tech.png',
    imgAlt: 'Reviewing route sheets and team output near trucks',
    dataPoints: ['Revenue per tech', 'Trade benchmarks', 'Whole-team gap'],
  },
  {
    id: 'marketing-calculator',
    icon: '📊',
    badge: 'HVAC Calculator',
    name: 'Marketing Cost Calculator',
    tagline: 'What Does a Booked Job Actually Cost You?',
    desc: "Most HVAC companies track leads. Very few know what it costs to book a real job. Enter your numbers and see your true cost per booked job against stronger HVAC benchmarks.",
    cta: 'Calculate your numbers',
    img: '/images/brand/core/tool-marketing-calculator.png',
    imgAlt: 'Comparing marketing spend to booked jobs',
    dataPoints: ['Cost per booked job', 'Channel benchmark line', 'ROI by channel'],
  },
  {
    id: 'gbp-scorecard',
    icon: '📍',
    badge: 'HVAC Calculator',
    name: 'GBP Scorecard',
    tagline: 'How Strong Is Your Google Business Profile?',
    desc: 'The map pack is one of the best free lead sources in HVAC. Most companies are giving ground to competitors on basic GBP factors they do not even know about. Score yourself on the same rubric we use for HVAC competitor teardowns.',
    cta: 'Score your GBP',
    img: '/images/brand/core/tool-gbp-scorecard.png',
    imgAlt: 'Reviewing local reputation and competitor notes',
    dataPoints: ['35-point scorecard', 'Section breakdown', 'Map pack benchmark context'],
  },
  {
    id: 'website-audit',
    icon: '🔍',
    badge: 'HVAC Calculator',
    name: 'Website Conversion Scorecard',
    tagline: 'Would a homeowner actually call after visiting your site?',
    desc: 'Most HVAC websites look fine, but fail in 3 critical places: speed, mobile experience, and call friction. Answer 12 quick questions about your site and get a Conversion Leak Score with specific fixes.',
    cta: 'Audit your website',
    img: '/images/brand/core/tool-website-audit.png',
    imgAlt: 'Reviewing website issues in a real work setting',
    dataPoints: ['Conversion leak score', 'Issue list', 'Website fix priorities'],
  },
];
---
<Layout
  title="HVAC Calculators | Missed Calls, GBP, Marketing Cost & Website Conversion | Built on Tenth"
  description="HVAC calculators and scorecards for missed calls, booked-job cost, estimate follow-up, Google Business Profile strength, and website conversion leaks."
  active="tools"
>
  <div class="insights-page tools-page">
    <div class="insights-shell">
      <section class="insights-hero">
        <div class="insights-hero__copy">
          <h1>HVAC calculators for owners who want <em>the number first.</em></h1>
          <p>
            Fast calculators and scorecards built to show where calls, revenue, and visibility are leaking before you buy the full report.
          </p>
        </div>
      </section>

      <div class="stories-grid stories-grid--tools">
        {tools.map((tool, index) => (
          <a
            href={`/tools/${tool.id}`}
            class={`editorial-card story-card${index === 0 ? ' story-card--lead' : ''}`}
          >
            <div class={`editorial-media ${index === 0 ? 'editorial-media--landscape' : 'editorial-media--compact'}`}>
              <ResponsiveImage
                src={tool.img}
                alt={tool.imgAlt}
                widths={index === 0 ? [720, 960, 1280] : [480, 720, 960]}
                sizes={index === 0 ? '(max-width: 1040px) 100vw, 38vw' : '(max-width: 820px) 100vw, 33vw'}
              />
            </div>
            <div class="editorial-body story-card__body tool-story-card__body">
              <div class="editorial-meta">
                <span>{tool.badge}</span>
              </div>
              <h3 class={`editorial-title ${index === 0 ? 'editorial-title--lg' : 'editorial-title--md'}`}>
                {tool.name}
              </h3>
              <p class="editorial-copy">{tool.desc}</p>
              <div class="story-card__footer">
                <span class="editorial-cta">{tool.cta}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="cta-card cta-card--report">
        <div class="cta-card__inner">
          <h2 class="cta-card__title">Want the full market gap in one report?</h2>
          <p class="cta-card__body">The HVAC Local Market Report shows who is outranking you, what they are doing differently, and what that gap is likely costing you in missed calls.</p>
          <div class="cta-card__actions">
            <a href="/report" class="btn btn--primary">Request your report</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
