---
import Layout from '../../layouts/Layout.astro';

const tools = [
  {
    id: 'phone-calculator',
    icon: '📞',
    badge: 'Free Tool',
    name: 'Phone Revenue Calculator',
    tagline: 'Missed Calls = Lost Jobs',
    desc: "Most owners think they answer 90% of calls. The actual average is 68%. Every unanswered call is a job that went to a competitor. Find out the dollar amount walking out your door every month.",
    cta: 'See your lost revenue',
    img: '/images/brand/core/core-tools-phone-calculator.png',
    imgAlt: 'Inbound calls being handled at the front desk',
    dataPoints: ['Monthly revenue lost', 'Recovery projection', 'Answer rate benchmark'],
  },
  {
    id: 'estimate-follow-up',
    icon: '📨',
    badge: 'Free Tool',
    name: 'Estimate Follow-Up Calculator',
    tagline: '68% of Estimates Never Get a Follow-Up',
    desc: 'Most owners blame the homeowner for not calling back. The data says otherwise. Enter your estimate volume and see exactly how much revenue is dying in your outbox every year.',
    cta: 'See the follow-up gap',
    img: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=600&q=75',
    imgAlt: 'Business owner reviewing estimate and pipeline data',
    dataPoints: ['Annual lost revenue', 'Follow-up benchmark', '50% and 80% what-if lift'],
  },
  {
    id: 'agency-report-card',
    icon: '📋',
    badge: 'Free Tool',
    name: 'Agency Report Card',
    tagline: 'Is Your Agency Measuring the Right Numbers?',
    desc: 'Every agency reports impressions, clicks, and cost per lead. Almost none report the number that actually matters: cost per booked job. Answer 10 questions and get a straight grade.',
    cta: 'Grade your agency',
    img: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&q=75',
    imgAlt: 'Marketing reporting dashboards on a laptop screen',
    dataPoints: ['Agency accountability grade', '10 yes or no checks', 'No-answer consequence lines'],
  },
  {
    id: 'revenue-per-tech',
    icon: '🛠️',
    badge: 'Free Tool',
    name: 'Revenue Per Technician Benchmarker',
    tagline: 'How Much Revenue Is Each Tech Producing?',
    desc: 'Most owners track total revenue. Very few track revenue per tech, the number that tells you whether your team is running at capacity or leaving jobs on the table. Enter your numbers and see exactly where you stand.',
    cta: 'Benchmark your team',
    img: 'https://images.unsplash.com/photo-1530124566582-a618bc2615dc?w=600&q=75',
    imgAlt: 'Home service crew with work vans',
    dataPoints: ['Revenue per tech', 'Trade benchmarks', 'Whole-team gap'],
  },
  {
    id: 'marketing-calculator',
    icon: '📊',
    badge: 'Free Tool',
    name: 'Marketing Cost Calculator',
    tagline: 'What Does a Booked Job Actually Cost You?',
    desc: "Most companies track leads. Very few know what it costs to book a real job. Enter your numbers and see your true cost per booked job, benchmarked against the top 25% in your trade.",
    cta: 'Calculate your numbers',
    img: '/images/brand/core/core-tools-marketing-calculator.png',
    imgAlt: 'Comparing marketing spend to booked jobs',
    dataPoints: ['Cost per booked job', 'Channel benchmark line', 'ROI by channel'],
  },
  {
    id: 'gbp-scorecard',
    icon: '📍',
    badge: 'Free Tool',
    name: 'GBP Scorecard',
    tagline: 'How Strong Is Your Google Business Profile?',
    desc: 'The map pack is the best free lead source in home services. Most companies are giving ground to competitors on basic GBP factors they do not even know about. Score yourself on the same rubric we use for competitor teardowns.',
    cta: 'Score your GBP',
    img: 'https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=600&q=75',
    imgAlt: 'Local search performance and business profile analysis',
    dataPoints: ['35-point scorecard', 'Section breakdown', 'Map pack benchmark context'],
  },
  {
    id: 'website-audit',
    icon: '🔍',
    badge: 'Free Tool',
    name: 'Website Conversion Audit',
    tagline: 'Would a homeowner actually call after visiting your site?',
    desc: 'Most contractor websites look fine, but fail in 3 critical places: speed, mobile experience, and call friction. Answer 12 quick questions about your site and get a Conversion Leak Score with specific fixes.',
    cta: 'Audit your website',
    img: '/images/brand/core/core-tools-website-audit.png',
    imgAlt: 'Reviewing website issues in a real work setting',
    dataPoints: ['Conversion leak score', 'Issue list', 'Website fix priorities'],
  },
];
---
<Layout
  title="Free Tools for HVAC, Roofing & Plumbing Companies | Built on Tenth"
  description="Seven free calculators and audits for home service business owners. See your biggest revenue leaks, benchmark your operation, and find the gaps your current reporting misses. No email required."
  active="tools"
>

<style>
.tools-hero { padding: 140px 48px 80px; position: relative; overflow: hidden; }
.tools-hero-glow {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 60% 60% at 20% 50%, rgba(0,196,154,0.06) 0%, transparent 60%);
}
.tools-hero-inner { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; }
.tools-hero h1 { font-family: var(--serif); font-size: clamp(38px, 5vw, 62px); font-weight: 400; line-height: 1.08; letter-spacing: -0.02em; margin-bottom: 22px; }
.tools-hero h1 em { font-style: italic; color: var(--teal); }
.tools-hero-sub { font-size: 17px; color: var(--ink2); line-height: 1.74; font-weight: 300; max-width: 580px; margin-bottom: 36px; }
.tools-hero-note {
  display: inline-flex; align-items: center; gap: 10px;
  font-family: var(--mono); font-size: 11px; font-weight: 400; letter-spacing: 0.06em;
  color: var(--ink3); background: var(--bg3); border: 1px solid var(--rule2);
  padding: 8px 16px; border-radius: 3px;
}
.tools-hero-note::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--pos); flex-shrink: 0; }

/* Tool list - alternating layout */
.tool-list { display: flex; flex-direction: column; gap: 1px; background: var(--rule); border: 1px solid var(--rule); border-radius: 6px; overflow: hidden; margin-top: 48px; }
.tool-item {
  background: var(--bg2);
  display: grid;
  grid-template-columns: 280px 1fr;
  transition: background 0.25s;
}
.tool-item:hover { background: var(--bg3); }
.tool-item:nth-child(even) { direction: rtl; }
.tool-item:nth-child(even) > * { direction: ltr; }

.tool-img-col { position: relative; overflow: hidden; background: var(--bg3); min-height: 260px; }
.tool-img-col img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(10%) brightness(0.94); transition: transform 0.6s var(--ease), filter 0.4s; display: block; }
.tool-item:hover .tool-img-col img { transform: scale(1.05); filter: grayscale(0%) brightness(1); }
.tool-img-col::before { content: ''; position: absolute; inset: 0; z-index: 1; background: rgba(0,196,154,0.025); pointer-events: none; }
.tool-img-col::after {
  content: ''; position: absolute; inset: 0; z-index: 2; pointer-events: none;
  background: linear-gradient(to right, transparent 68%, rgba(9,12,11,0.22) 100%);
}
.tool-item:nth-child(even) .tool-img-col::after {
  background: linear-gradient(to left, transparent 68%, rgba(9,12,11,0.22) 100%);
}

.tool-body { padding: 36px 40px; display: flex; flex-direction: column; justify-content: center; }
.tool-badge-row { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
.tool-num { font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: 0.12em; color: var(--ink3); }
.tool-name { font-family: var(--serif); font-size: 24px; font-weight: 400; line-height: 1.2; margin-bottom: 8px; }
.tool-tagline { font-family: var(--sans); font-size: 14.5px; font-weight: 500; color: var(--teal); margin-bottom: 12px; }
.tool-desc { font-size: 14px; color: var(--ink2); line-height: 1.7; font-weight: 300; margin-bottom: 18px; max-width: 480px; }
.tool-data-points { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 24px; }
.tdp { font-family: var(--mono); font-size: 9.5px; font-weight: 500; letter-spacing: 0.08em; color: var(--ink3); background: var(--bg4); border: 1px solid var(--rule); padding: 4px 10px; border-radius: 3px; }
.tool-cta-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 46px;
  width: fit-content;
  padding: 0 18px;
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--teal);
  text-decoration: none;
  border: 1px solid rgba(0,196,154,0.32);
  background: rgba(0,196,154,0.06);
  border-radius: 4px;
  transition: background 0.2s, border-color 0.2s, transform 0.2s, color 0.2s;
}
.tool-item:hover .tool-cta-link {
  background: rgba(0,196,154,0.12);
  border-color: rgba(0,196,154,0.48);
  color: var(--ink);
  transform: translateY(-1px);
}

/* Bottom CTA */
.tools-cta { text-align: center; padding: 96px 48px; position: relative; overflow: hidden; }
.tools-cta-glow { position: absolute; inset: 0; background: radial-gradient(ellipse 55% 55% at 50% 50%, rgba(0,196,154,0.06) 0%, transparent 65%); }
.tools-cta-inner { position: relative; z-index: 1; max-width: 520px; margin: 0 auto; }
.tools-cta h2 { font-family: var(--serif); font-size: clamp(28px, 4vw, 44px); font-weight: 400; letter-spacing: -0.02em; margin-bottom: 16px; }
.tools-cta h2 em { font-style: italic; color: var(--teal); }
.tools-cta p { font-size: 15px; color: var(--ink2); line-height: 1.7; margin-bottom: 30px; font-weight: 300; }

@media (max-width: 960px) {
  .tools-hero { padding: 100px 20px 60px; }
  .tools-hero h1 { font-size: clamp(28px, 8vw, 44px); }
  .tool-item, .tool-item:nth-child(even) { grid-template-columns: 1fr; direction: ltr; }
  .tool-img-col { min-height: 180px; }
  .tool-img-col::after, .tool-item:nth-child(even) .tool-img-col::after { background: linear-gradient(to bottom, transparent 40%, var(--bg2) 100%); }
  .tool-body { padding: 24px 20px; }
  .tool-cta-link { width: 100%; }
  .tools-cta { padding: 64px 20px; }
  .tools-cta h2 { font-size: clamp(24px, 7vw, 36px); }
}
</style>

<!-- HERO -->
<div class="tools-hero">
  <div class="tools-hero-glow"></div>
  <div class="tools-hero-inner">
    <div class="dispatch-label">Free Tools</div>
    <h1>See your numbers.<br><em>Find the leaks.</em></h1>
    <p class="tools-hero-sub">Seven calculators and audits built specifically for HVAC, roofing, and plumbing companies. Start with the fastest leak, then keep going until you know which gap is costing the most. Most owners find $50K-$200K in recoverable leaks on the first pass.</p>
    <span class="tools-hero-note">Results show instantly - email required only for the full detailed report</span>
  </div>
</div>

<!-- TOOLS LIST -->
<div class="wrap alt">
  <div class="inner">
    <div class="rule-label"><span class="section-tag">All 7 Tools</span></div>
    <p class="tools-hero-sub" style="max-width:760px;margin:20px 0 0;">Start here: Phone Revenue shows you the fastest leak. Estimate Follow-Up shows you the second one. Agency Report Card tells you whether your marketing setup is built to find either.</p>
    <div class="tool-list">
      {tools.map((tool, i) => (
        <div class="tool-item reveal">
          <div class="tool-img-col">
            <img src={tool.img} alt={tool.imgAlt} loading="lazy" onerror="this.setAttribute('data-failed','1')" />
            <div class="img-fb">{tool.icon}</div>
          </div>
          <div class="tool-body">
            <div class="tool-badge-row">
              <span class="badge-green">{tool.badge}</span>
              <span class="tool-num">{String(i + 1).padStart(2, '0')} of 07</span>
            </div>
            <div class="tool-name">{tool.name}</div>
            <div class="tool-tagline">{tool.tagline}</div>
            <p class="tool-desc">{tool.desc}</p>
            <div class="tool-data-points">
              {tool.dataPoints.map(d => <span class="tdp">{d}</span>)}
            </div>
            <a href={`/tools/${tool.id}`} class="tool-cta-link">{tool.cta}</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- BOTTOM CTA -->
<div class="tools-cta">
  <div class="tools-cta-glow"></div>
  <div class="tools-cta-inner">
    <div class="dispatch-label" style="justify-content:center;margin-bottom:16px">Want the full picture?</div>
    <h2>See everything in <em>one audit.</em></h2>
    <p>The free tools show individual leaks. The Revenue Leak Audit covers everything - your full marketing system, competitor benchmarks, phone performance, and website - with every finding shown in annual dollars.</p>
    <a href="/apply" class="cta-primary">Get a Revenue Leak Audit ($750)</a>
  </div>
</div>

</Layout>
