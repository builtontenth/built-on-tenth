---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Request Your HVAC Local Market Report | Built on Tenth"
  description="Order the HVAC Local Market Report by sharing your business, city, and Google Business Profile. Fixed fee: $200. Delivered in 48 hours with no call or sales pitch."
  active=""
>


<div class="page-shell apply-page">
  <div class="page-wrap">
    <div class="apply-grid">

      <div class="apply-copy">
        <div>
          <h1 class="section-title">Order your <em>HVAC Local Market Report.</em></h1>
          <p class="section-copy">This is the intake form for the report. Fixed fee: $200. Submit your market details once, and the written report is delivered within 48 hours. No calls. No pitch deck. No pressure.</p>
        </div>

        <div class="apply-promise">
          <h2>Simple written order</h2>
          <p>You give us your company, service area, and what you want to understand about your local visibility gap. From there, the work moves straight into delivery.</p>
        </div>

        <div class="surface-card next-steps-card">
          <div class="section-label">What happens next</div>
          <div class="next-steps">
            <div class="ns-item">
              <div class="ns-num">01</div>
              <div>
                <div class="ns-title">We review your market details</div>
                <div class="ns-desc">We look at your company, service area, and local search context so the report starts with the right scope.</div>
              </div>
            </div>
            <div class="ns-item">
              <div class="ns-num">02</div>
              <div>
                <div class="ns-title">We confirm anything missing by email</div>
                <div class="ns-desc">If anything is unclear, we keep it in writing and keep it simple so delivery stays on track.</div>
              </div>
            </div>
            <div class="ns-item">
              <div class="ns-num">03</div>
              <div>
                <div class="ns-title">The work starts immediately</div>
                <div class="ns-desc">No logins, no calls, and no internal data dump. Once submitted, the report moves into production.</div>
              </div>
            </div>
            <div class="ns-item">
              <div class="ns-num">04</div>
              <div>
                <div class="ns-title">You get a written report</div>
                <div class="ns-desc">A documented local market report with the gap, the likely impact, and what deserves attention first.</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="surface-card surface-card--strong apply-form-card">
        <div id="form-content">
          <div class="form-h">Request your report.</div>
          <p class="form-sub">Fixed fee: $200. Delivered within 48 hours.</p>

          <div class="field-row">
            <div class="field">
              <label for="name">Your Name</label>
              <input type="text" id="name" />
            </div>
            <div class="field">
              <label for="company">Company Name</label>
              <input type="text" id="company" />
            </div>
          </div>

          <div class="field-row">
            <div class="field">
              <label for="location">City, State</label>
              <input type="text" id="location" />
            </div>
            <div class="field">
              <label for="website">Website</label>
              <input type="url" id="website" />
            </div>
          </div>

          <div class="field">
            <label for="email">Email Address</label>
            <input type="email" id="email" />
          </div>

          <div class="field">
            <label for="service">What are you looking for?</label>
            <select id="service">
              <option value="report">HVAC Local Market Report</option>
              <option value="unsure">Not sure yet - want guidance</option>
            </select>
          </div>

          <div class="field">
            <label for="spend">Monthly Marketing Spend (approx.)</label>
            <select id="spend">
              <option value="" disabled selected>Select a range</option>
              <option value="under3k">Under $3,000/month</option>
              <option value="3-6k">$3,000–$6,000/month</option>
              <option value="6-10k">$6,000–$10,000/month</option>
              <option value="10-15k">$10,000–$15,000/month</option>
              <option value="over15k">Over $15,000/month</option>
            </select>
          </div>

          <div class="field">
            <label for="question">What's the main thing you're trying to figure out? <span class="field-note">(optional)</span></label>
            <textarea id="question"></textarea>
          </div>

          <button class="btn btn--primary form-cta" id="submit-btn">Request your report</button>
          <p class="form-note">Everything handled in writing. Fixed fee: $200. Delivered within 48 hours.</p>
        </div>

        <div class="form-success" id="form-success" hidden>
          <div class="form-success-icon">✓</div>
          <h3>Got it. We’ll be in touch.</h3>
          <p>Your request is in. We’ll use the details you provided to complete the HVAC Local Market Report and deliver it within 48 hours.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const serviceSelect = document.getElementById('service');
  const params = new URLSearchParams(window.location.search);
  const requestedService = params.get('service');
  if (requestedService && serviceSelect?.querySelector(`option[value="${requestedService}"]`)) {
    serviceSelect.value = requestedService;
  }

  document.getElementById('submit-btn').addEventListener('click', async () => {
    const email    = document.getElementById('email').value.trim();
    const name     = document.getElementById('name').value.trim();
    const company  = document.getElementById('company').value.trim();
    const location = document.getElementById('location').value.trim();
    const website  = document.getElementById('website').value.trim();
    const service  = document.getElementById('service').value;
    const spend    = document.getElementById('spend').value;
    const question = document.getElementById('question').value.trim();
    const btn      = document.getElementById('submit-btn');

    // Validate required fields
    let valid = true;
    const nameInput = document.getElementById('name');
    const emailInput = document.getElementById('email');

    [nameInput, emailInput].forEach((field) => field?.classList.remove('field-control--error'));

    if (!name) {
      nameInput?.classList.add('field-control--error');
      valid = false;
    }

    if (!email.includes('@')) {
      emailInput?.classList.add('field-control--error');
      valid = false;
    }

    if (!valid) return;

    btn.textContent = 'Sending...';
    btn.disabled = true;

    try {
      const res = await fetch('/api/apply', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, company, location, website, email, service, spend, question }),
      });
      const data = await res.json();
      if (data.success) {
        window.botTrack?.('audit_application_submit', {
          service_interest: service || 'unknown',
          spend_range: spend || 'unknown',
        });
        document.getElementById('form-content').hidden = true;
        document.getElementById('form-success').hidden = false;
        document.getElementById('form-success').classList.add('show');
      } else {
        btn.textContent = 'Try again';
        btn.disabled = false;
      }
    } catch {
      btn.textContent = 'Try again';
      btn.disabled = false;
    }
  });
</script>
</Layout>
