---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="HVAC Market Insights Email Updates | New Research in Your Inbox | Built on Tenth"
  description="Get an email whenever a new HVAC Market Insights article is published. No fixed schedule, no filler, and no generic roundup."
  active="newsletter"
>


<!-- HERO -->
<div class="page-shell">
<div class="nl-hero page-hero page-hero--center">
  <div class="nl-hero-bg"></div>
  <div class="nl-hero-glow"></div>
  <div class="page-wrap page-hero__inner">
    <div class="nl-hero-inner page-hero__inner--narrow cta-card cta-card--capture">
    <div class="cta-card__inner">
      <h1 class="cta-card__title">Get every new HVAC Market Insights article <em>in your inbox.</em></h1>
      <p class="nl-hero-sub cta-card__body">There is no weekly schedule and no content calendar to fill. When a new HVAC Market Insights article is published, subscribers get it. Benchmarks, operator lessons, and market breakdowns only when there is something worth sending.</p>
      <div class="nl-form-wrap cta-card__actions">
        <div class="capture-form capture-form--centered">
          <input type="email" class="capture-input" id="nl-email" />
          <button class="btn btn--primary capture-button capture-button--pointer" id="nl-submit">Get email updates</button>
        </div>
      </div>
      <p class="nl-note cta-card__meta">No fixed schedule. Unsubscribe anytime. We do not share your email.</p>
    </div>
  </div>
  </div>
</div>

<!-- WHAT YOU GET -->
<div class="nl-value">
  <div class="page-wrap nl-value-inner">
    <div class="nlv-card">
      <div class="nlv-kicker">Immediate delivery</div>
      <div class="nlv-title">Every new article lands in your inbox automatically.</div>
      <div class="nlv-body">You do not need to remember to check the site. When a new HVAC Market Insights piece goes live, subscribers get it right away.</div>
    </div>
    <div class="nlv-card">
      <div class="nlv-kicker">Useful by design</div>
      <div class="nlv-title">Built for owners who care about calls, booked jobs, and what to fix next.</div>
      <div class="nlv-body">Expect market gaps, answer rates, booked-job cost, review velocity, service agreements, and the numbers that actually change decisions.</div>
    </div>
    <div class="nlv-card">
      <div class="nlv-kicker">No filler</div>
      <div class="nlv-title">No schedule to feed. No generic roundup to ignore.</div>
      <div class="nlv-body">This is not a weekly newsletter. If there is nothing new worth your time, nothing gets sent. That keeps the signal clean and the inbox friction low.</div>
    </div>
  </div>
</div>

 </div>

<script>
  async function submitEmail(email, btn, inp, source) {
    btn.textContent = 'Subscribing...';
    btn.disabled = true;
    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source }),
      });
      const data = await res.json();
      if (data.success) {
        btn.textContent = "You're in \u2713";
        btn.classList.add('capture-button--success');
        inp.disabled = true;
        inp.classList.remove('capture-input--error');
        window.botTrack?.('newsletter_signup', { signup_source: source || 'newsletter-page' });
      } else {
        btn.textContent = 'Try again';
        btn.disabled = false;
        btn.classList.remove('capture-button--success');
        inp.classList.add('capture-input--error');
      }
    } catch {
      btn.textContent = 'Try again';
      btn.disabled = false;
      btn.classList.remove('capture-button--success');
    }
  }

  function setupForm(inputId, btnId, source) {
    const btn = document.getElementById(btnId);
    const inp = document.getElementById(inputId);
    if (!btn || !inp) return;
    btn.addEventListener('click', () => {
      if (!inp.value.includes('@')) {
        inp.classList.add('capture-input--error');
        inp.focus();
        return;
      }
      inp.classList.remove('capture-input--error');
      submitEmail(inp.value.trim(), btn, inp, source || 'newsletter-page');
    });
    inp.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && inp.value.includes('@')) {
        submitEmail(inp.value.trim(), btn, inp, source || 'newsletter-page');
      }
    });
  }

  setupForm('nl-email', 'nl-submit', 'newsletter-hero');
</script>
</Layout>
