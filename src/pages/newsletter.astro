---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="The Weekly Growth Report - Free Newsletter | Built on Tenth"
  description="One growth insight every Tuesday. Real data from analyzing hundreds of HVAC, roofing, and plumbing companies. Free. Written for owners."
  active="newsletter"
>

<style>
.nl-hero {
  padding: 140px 48px 80px; position: relative; overflow: hidden; text-align: center;
}
.nl-hero-bg {
  position: absolute; inset: 0;
  background-image: url('https://images.unsplash.com/photo-1512314889357-e157c22f938d?w=1400&q=55');
  background-size: cover; background-position: center; opacity: 0.05; filter: grayscale(50%);
}
.nl-hero-glow {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 65% 65% at 50% 50%, rgba(0,196,154,0.08) 0%, transparent 65%);
}
.nl-hero-inner { position: relative; z-index: 1; max-width: 620px; margin: 0 auto; }
.nl-hero h1 { font-family: var(--serif); font-size: clamp(40px, 6vw, 68px); font-weight: 400; line-height: 1.06; letter-spacing: -0.02em; margin-bottom: 22px; }
.nl-hero h1 em { font-style: italic; color: var(--teal); }
.nl-hero-sub { font-size: 17px; color: var(--ink2); line-height: 1.74; font-weight: 300; margin-bottom: 40px; }

.nl-form-wrap { display: flex; gap: 10px; max-width: 440px; margin: 0 auto 14px; }
.nl-input {
  flex: 1; background: var(--bg2); border: 1px solid var(--rule2);
  border-radius: 4px; padding: 14px 18px;
  font-family: var(--sans); font-size: 14px; color: var(--ink);
  outline: none; transition: border-color 0.2s;
}
.nl-input::placeholder { color: var(--ink3); }
.nl-input:focus { border-color: rgba(0,196,154,0.5); }
.nl-note { font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; color: var(--ink2); }

/* What you get */
.nl-value { border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); background: var(--bg2); }
.nl-value-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); }
.nlv-card { padding: 36px 32px; border-right: 1px solid var(--rule); }
.nlv-card:last-child { border-right: none; }
.nlv-icon { font-size: 22px; margin-bottom: 14px; }
.nlv-title { font-family: var(--sans); font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.nlv-body { font-size: 13.5px; color: var(--ink2); line-height: 1.65; font-weight: 300; }

/* Recent issues */
.issues-grid { display: flex; flex-direction: column; gap: 1px; margin-top: 48px; background: var(--rule); border: 1px solid var(--rule); border-radius: 6px; overflow: hidden; }
.issue-card { background: var(--bg2); padding: 32px 36px; display: grid; grid-template-columns: 80px 1fr; gap: 28px; align-items: start; transition: background 0.25s; cursor: default; }
.issue-card:hover { background: var(--bg3); }
.issue-num { font-family: var(--mono); font-size: 11px; font-weight: 500; letter-spacing: 0.1em; color: var(--teal); padding-top: 4px; }
.issue-tag { font-family: var(--mono); font-size: 9px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink3); margin-bottom: 8px; }
.issue-title { font-family: var(--serif); font-size: 20px; font-weight: 400; line-height: 1.28; margin-bottom: 10px; }
.issue-preview { font-size: 13.5px; color: var(--ink2); line-height: 1.65; font-weight: 300; }
.issue-data { display: flex; gap: 20px; margin-top: 14px; flex-wrap: wrap; }
.id-pill { font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: 0.08em; color: var(--teal); background: var(--teal3); border: 1px solid var(--teal4); padding: 3px 8px; border-radius: 3px; }

/* Bottom signup */
.nl-bottom { text-align: center; padding: 96px 48px; position: relative; overflow: hidden; }
.nl-bottom-glow { position: absolute; inset: 0; background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(0,196,154,0.06) 0%, transparent 65%); }
.nl-bottom-inner { position: relative; z-index: 1; max-width: 480px; margin: 0 auto; }
.nl-bottom h2 { font-family: var(--serif); font-size: clamp(28px, 3.5vw, 42px); font-weight: 400; letter-spacing: -0.02em; margin-bottom: 16px; }
.nl-bottom h2 em { font-style: italic; color: var(--teal); }
.nl-bottom p { font-size: 15px; color: var(--ink2); line-height: 1.7; margin-bottom: 30px; font-weight: 300; }

@media (max-width: 960px) {
  .nl-hero { padding: 100px 20px 60px; }
  .nl-hero h1 { font-size: clamp(32px, 9vw, 52px); }
  .nl-value-inner { grid-template-columns: 1fr; }
  .nlv-card { border-right: none; border-bottom: 1px solid var(--rule); }
  .nlv-card:last-child { border-bottom: none; }
  .issue-card { grid-template-columns: 1fr; gap: 12px; padding: 24px 20px; }
  .nl-form-wrap { flex-direction: column; max-width: 100% !important; }
  .nl-input { width: 100%; }
  .nl-bottom { padding: 64px 20px; }
  /* Override inline 2-col grid on recent issues header */
  .inner > div[style*="grid-template-columns"] {
    grid-template-columns: 1fr !important;
    gap: 16px !important;
  }
}
</style>

<!-- HERO -->
<div class="nl-hero">
  <div class="nl-hero-bg"></div>
  <div class="nl-hero-glow"></div>
  <div class="nl-hero-inner">
    <div class="dispatch-label" style="justify-content:center;margin-bottom:20px">Free · Every Tuesday</div>
    <h1>The Weekly<br><em>Growth Report</em></h1>
    <p class="nl-hero-sub">One thing every Tuesday, a specific tactic, benchmark, or finding from companies doing $1M–$5M in your trade. What they spend on ads, how they answer calls, what their close rate looks like. Short. Useful. Written for owners who'd rather know their numbers than guess.</p>
    <div class="nl-form-wrap">
      <input type="email" class="nl-input" placeholder="your@email.com" id="nl-email" />
      <button class="cta-primary" style="cursor:pointer;white-space:nowrap" id="nl-submit">Subscribe Free</button>
    </div>
    <p class="nl-note">Unsubscribe anytime. We don't share your email.</p>
  </div>
</div>

<!-- WHAT YOU GET -->
<div class="nl-value">
  <div class="nl-value-inner">
    <div class="nlv-card">
      <div class="nlv-icon">📊</div>
      <div class="nlv-title">Real benchmarks from real companies</div>
      <div class="nlv-body">Not industry surveys or guesswork. Actual data from analyzing hundreds of HVAC, roofing, and plumbing companies: answer rates, cost per booked job, close rates, Google Ad spend, by trade and market size.</div>
    </div>
    <div class="nlv-card">
      <div class="nlv-icon">🔧</div>
      <div class="nlv-title">One specific thing you can use this week</div>
      <div class="nlv-body">Each issue is built around one tactic, finding, or system. Not a 20-minute read. Not a vague strategy framework. Something you can hand to your front desk, show to your agency, or implement yourself in a few hours.</div>
    </div>
    <div class="nlv-card">
      <div class="nlv-icon">📋</div>
      <div class="nlv-title">Contractor-first language</div>
      <div class="nlv-body">We write like a contractor who figured out growth systems, not a marketer. You'll see "calls" not "leads," "book jobs" not "convert," "average ticket" not "AOV." If it won't pass the 6am truck test, we don't publish it.</div>
    </div>
  </div>
</div>

<!-- RECENT ISSUES -->
<div class="wrap">
  <div class="inner">
    <div class="rule-label"><span class="section-tag">Recent Issues</span></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:end;margin-bottom:8px">
      <h2 class="sec-h">What you get<br><em>every Tuesday</em></h2>
      <p class="sec-p" style="max-width:100%">Each issue covers one topic in depth. Specific numbers, specific actions, specific dollar amounts. Here's what's gone out recently.</p>
    </div>

    <div class="issues-grid">
      <div class="issue-card reveal">
        <div class="issue-num">Issue #03</div>
        <div>
          <div class="issue-tag">Google Ads · HVAC</div>
          <div class="issue-title">The $4,200/Month Google Ads Mistake 44% of HVAC Companies Make</div>
          <p class="issue-preview">Nearly half of HVAC companies spending on Google Ads have zero conversion tracking installed - which means zero visibility into which campaigns are producing booked jobs vs. burning cash. Here's what it costs, and the 15-minute fix any owner can do without touching the campaign settings.</p>
          <div class="issue-data">
            <span class="id-pill">44% have zero tracking</span>
            <span class="id-pill">15-min fix</span>
            <span class="id-pill">Avg $2,800/mo wasted</span>
          </div>
        </div>
      </div>
      <div class="issue-card reveal">
        <div class="issue-num">Issue #02</div>
        <div>
          <div class="issue-tag">Close Rate · All Trades</div>
          <div class="issue-title">Your Close Rate Isn't 35%. It's Probably 22%.</div>
          <p class="issue-preview">Most owners overestimate their close rate by 10–15 percentage points because they're tracking the wrong thing. They count "submitted estimates" instead of "answered calls." Here's how to find the real number - and what the top 25% of companies in your trade actually close at.</p>
          <div class="issue-data">
            <span class="id-pill">Industry avg: 22–28%</span>
            <span class="id-pill">Top 25%: 38–45%</span>
          </div>
        </div>
      </div>
      <div class="issue-card reveal">
        <div class="issue-num">Issue #01</div>
        <div>
          <div class="issue-tag">Estimate Follow-Up · All Trades</div>
          <div class="issue-title">The Follow-Up Sequence That Recovered $47K in Lost Estimates</div>
          <p class="issue-preview">68% of estimates sent to homeowners never receive a follow-up call. One roofing company changed that with a 3-touch text and email sequence - and recovered $47,000 in jobs that had gone cold. Here's the exact sequence, word for word.</p>
          <div class="issue-data">
            <span class="id-pill">68% never followed up</span>
            <span class="id-pill">$47K recovered</span>
            <span class="id-pill">3-touch sequence</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- BOTTOM SIGNUP -->
<div class="nl-bottom">
  <div class="nl-bottom-glow"></div>
  <div class="nl-bottom-inner">
    <h2>Get the next issue<br><em>this Tuesday.</em></h2>
    <p>Join owners who want real numbers, not agency reports. One email a week. Unsubscribe anytime.</p>
    <div class="nl-form-wrap" style="max-width:400px;margin:0 auto 14px">
      <input type="email" class="nl-input" placeholder="your@email.com" id="nl-email-2" />
      <button class="cta-primary" style="cursor:pointer;white-space:nowrap" id="nl-submit-2">Subscribe Free</button>
    </div>
    <p class="nl-note">We don't share your email. No spam.</p>
  </div>
</div>

<script>
  async function submitEmail(email, btn, inp, source) {
    btn.textContent = 'Subscribing...';
    btn.disabled = true;
    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source }),
      });
      const data = await res.json();
      if (data.success) {
        btn.textContent = "You're in \u2713";
        btn.style.background = '#22D37A';
        btn.style.borderColor = '#22D37A';
        inp.disabled = true;
      } else {
        btn.textContent = 'Try again';
        btn.disabled = false;
        inp.style.borderColor = 'rgba(240,64,64,0.55)';
      }
    } catch {
      btn.textContent = 'Try again';
      btn.disabled = false;
    }
  }

  function setupForm(inputId, btnId, source) {
    const btn = document.getElementById(btnId);
    const inp = document.getElementById(inputId);
    if (!btn || !inp) return;
    btn.addEventListener('click', () => {
      if (!inp.value.includes('@')) {
        inp.style.borderColor = 'rgba(240,64,64,0.55)';
        inp.focus();
        return;
      }
      submitEmail(inp.value.trim(), btn, inp, source || 'newsletter-page');
    });
    inp.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && inp.value.includes('@')) {
        submitEmail(inp.value.trim(), btn, inp, source || 'newsletter-page');
      }
    });
  }

  setupForm('nl-email', 'nl-submit', 'newsletter-hero');
  setupForm('nl-email-2', 'nl-submit-2', 'newsletter-bottom');
</script>
</Layout>
