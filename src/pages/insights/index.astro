---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ResponsiveImage from '../../components/ResponsiveImage.astro';

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(date);

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const hvacPosts = allPosts.filter((post) => post.data.trade.includes('HVAC'));
const otherTradePosts = allPosts.filter((post) => !post.data.trade.includes('HVAC'));

const heroImagePositions: Record<string, string> = {
  'how-hvac-service-agreements-add-200k-annual-revenue': '72% center',
  'how-much-should-hvac-company-spend-on-marketing-2026': '72% center',
  'how-to-set-up-google-local-service-ads-hvac': '62% center',
  'hvac-cost-per-lead-by-channel-2026': '72% center',
  'four-numbers-hvac-owner-marketing': '56% center',
  'what-to-ask-hvac-marketing-agency-before-signing': '58% center',
  'servicetitan-roi-audit-hvac': '64% center',
};

---
<Layout
  title="HVAC Market Insights | Benchmarks, Research & Operator Lessons | Built on Tenth"
  description="HVAC market insights, benchmarks, and operator lessons for owners who want useful numbers, clearer decisions, and research worth finishing."
  active="insights"
>
  

  <div class="insights-page">
    <div class="insights-shell">
      <section class="insights-hero">
        <div class="insights-hero__copy">
          <h1>Visual, useful research for operators who want <em>numbers worth reading.</em></h1>
          <p>
            Deep HVAC articles, benchmarks, and operating lessons designed for faster
            scanning, easier reading, and more confident clicks.
          </p>
        </div>
      </section>

      <div class="section-intro">
        <div class="section-intro__copy">
          <h2>Start with HVAC.</h2>
          <p>The newest HVAC research comes first. Older roofing and plumbing articles stay lower down for reference without getting in the way of the main reading path.</p>
        </div>
      </div>

      <div class="stories-grid">
        {hvacPosts.map((article, index) => (
          <a
            href={`/insights/${article.slug}`}
            class={`editorial-card story-card${index === 0 ? ' story-card--lead' : ''}`}
          >
            <div class={`editorial-media ${index === 0 ? 'editorial-media--landscape' : 'editorial-media--compact'}`}>
              <ResponsiveImage
                src={article.data.heroImage}
                alt={article.data.heroImageAlt}
                widths={index === 0 ? [720, 960, 1280] : [480, 720, 960]}
                sizes={index === 0 ? '(max-width: 1040px) 100vw, 38vw' : '(max-width: 820px) 100vw, 33vw'}
                position={heroImagePositions[article.slug] ?? 'center'}
                fit="cover"
              />
            </div>
            <div class="editorial-body story-card__body">
              <div class="editorial-meta">
                <span>{article.data.category}</span>
                <span>{formatDate(article.data.pubDate)}</span>
                <span>{article.data.readTime} min</span>
              </div>
              <h3 class={`editorial-title ${index === 0 ? 'editorial-title--lg' : 'editorial-title--md'}`}>
                {article.data.title}
              </h3>
              <p class="editorial-copy">{article.data.preview ?? article.data.description}</p>
              <div class="editorial-pills">
                {article.data.pills.map((pill) => <span class="editorial-pill">{pill}</span>)}
              </div>
              <div class="story-card__footer">
                <span class="editorial-cta">Read article</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      {otherTradePosts.length > 0 && (
        <>
          <div class="section-intro section-intro--other-trades">
            <div class="section-intro__copy">
              <h2>Older roofing and plumbing articles stay below the HVAC library.</h2>
              <p>They remain available, but HVAC stays prioritized at the top while the brand stays focused on one trade.</p>
            </div>
          </div>

          <div class="stories-grid stories-grid--other">
            {otherTradePosts.map((article) => (
              <a href={`/insights/${article.slug}`} class="editorial-card story-card">
                <div class="editorial-media editorial-media--compact">
                  <ResponsiveImage
                    src={article.data.heroImage}
                    alt={article.data.heroImageAlt}
                    widths={[480, 720, 960]}
                    sizes="(max-width: 820px) 100vw, 33vw"
                    position={heroImagePositions[article.slug] ?? 'center'}
                    fit="cover"
                  />
                </div>
                <div class="editorial-body story-card__body">
                  <div class="editorial-meta">
                    <span>{article.data.trade.join(' / ')} · {article.data.category}</span>
                    <span>{formatDate(article.data.pubDate)}</span>
                    <span>{article.data.readTime} min</span>
                  </div>
                  <h3 class="editorial-title editorial-title--md">{article.data.title}</h3>
                  <p class="editorial-copy">{article.data.preview ?? article.data.description}</p>
                  <div class="editorial-pills">
                    {article.data.pills.map((pill) => <span class="editorial-pill">{pill}</span>)}
                  </div>
                  <div class="story-card__footer">
                    <span class="editorial-cta">Read article</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </>
      )}

      <div class="cta-card cta-card--capture">
        <div class="cta-card__inner">
          <h2 class="cta-card__title">Get new HVAC Market Insights posts in your inbox.</h2>
          <p class="cta-card__body">Whenever a new article is published, subscribers get it. No weekly schedule. No filler. Just new research worth reading.</p>
          <div class="capture-form cta-card__actions">
            <input type="email" class="capture-input" id="insights-email" />
            <button class="btn btn--primary capture-button" id="insights-submit">Get email updates</button>
          </div>
          <p class="cta-card__meta">Built for operators who want useful numbers, not content calendars.</p>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    document.getElementById('insights-submit').addEventListener('click', async () => {
      const inp = document.getElementById('insights-email');
      const btn = document.getElementById('insights-submit');
      if (!inp.value.includes('@')) {
        inp.classList.add('capture-input--error');
        inp.focus();
        return;
      }
      inp.classList.remove('capture-input--error');
      btn.textContent = 'Subscribing...';
      btn.disabled = true;
      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: inp.value.trim(), source: 'insights-page' }),
        });
        const data = await res.json();
        if (data.success) {
          btn.textContent = 'Subscribed';
          btn.classList.add('capture-button--success');
          inp.disabled = true;
          window.botTrack?.('newsletter_signup', { signup_source: 'insights-page' });
        } else {
          btn.textContent = 'Try again';
          btn.disabled = false;
          btn.classList.remove('capture-button--success');
        }
      } catch {
        btn.textContent = 'Try again';
        btn.disabled = false;
        btn.classList.remove('capture-button--success');
      }
    });
  </script>
</Layout>
