---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(date);

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const initialFeatured = allPosts.find((post) => post.data.featured) || allPosts[0] || null;
const initialSecondary = initialFeatured
  ? allPosts.filter((post) => post.slug !== initialFeatured.slug)
  : [];

const postsForClient = allPosts.map((post) => ({
  slug: post.slug,
  title: post.data.title,
  description: post.data.preview ?? post.data.description,
  date: formatDate(post.data.pubDate),
  pubDate: post.data.pubDate.toISOString(),
  readTime: post.data.readTime,
  img: post.data.heroImage,
  imgAlt: post.data.heroImageAlt,
  category: post.data.category,
  trade: post.data.trade,
  pills: post.data.pills,
  featured: post.data.featured,
}));
---
<Layout
  title="Insights - Growth Research for HVAC, Roofing & Plumbing | Built on Tenth"
  description="Research, benchmarks, and analysis from studying hundreds of home service companies. What the most profitable HVAC, roofing, and plumbing operators do differently."
  active="insights"
>

<style is:global>
.insights-hero { padding: 140px 48px 80px; position: relative; overflow: hidden; }
.insights-hero-glow { position: absolute; inset: 0; background: radial-gradient(ellipse 60% 60% at 20% 50%, rgba(0,196,154,0.05) 0%, transparent 60%); }
.insights-hero-inner { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: end; }
.insights-hero h1 { font-family: var(--serif); font-size: clamp(34px, 5vw, 58px); font-weight: 400; line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 20px; }
.insights-hero h1 em { font-style: italic; color: var(--teal); }
.pillar-tabs { display: flex; gap: 8px; flex-wrap: wrap; }
.pt { font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink3); background: var(--bg3); border: 1px solid var(--rule2); padding: 7px 14px; border-radius: 3px; text-decoration: none; transition: all 0.2s; }
.pt:hover, .pt.active { color: var(--teal); border-color: var(--teal4); background: var(--teal3); }
.filter-state { margin-top: 14px; font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink3); }
.featured-article { display: grid; grid-template-columns: 1fr 380px; gap: 0; background: var(--bg2); border: 1px solid var(--rule2); border-radius: 6px; overflow: hidden; text-decoration: none; color: inherit; transition: border-color 0.25s, transform 0.25s; margin-bottom: 1px; }
.featured-article:hover { border-color: rgba(0,196,154,0.35); transform: translateY(-2px); }
.fa-body { padding: 40px; display: flex; flex-direction: column; justify-content: space-between; }
.fa-meta { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; flex-wrap: wrap; }
.fa-trade { font-family: var(--mono); font-size: 9.5px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--teal); }
.fa-date, .fa-read { font-family: var(--mono); font-size: 9.5px; color: var(--ink3); letter-spacing: 0.06em; }
.fa-title { font-family: var(--serif); font-size: clamp(22px, 3vw, 30px); font-weight: 400; line-height: 1.22; margin-bottom: 16px; }
.fa-preview { font-size: 14.5px; color: var(--ink2); line-height: 1.72; font-weight: 300; margin-bottom: 20px; flex: 1; }
.fa-pills { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 24px; }
.fa-pill { font-family: var(--mono); font-size: 9.5px; font-weight: 500; letter-spacing: 0.08em; color: var(--ink3); background: var(--bg4); border: 1px solid var(--rule); padding: 4px 10px; border-radius: 3px; }
.fa-cta { font-family: var(--mono); font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--teal); display: flex; align-items: center; gap: 6px; transition: gap 0.2s; }
.featured-article:hover .fa-cta { gap: 10px; }
.fa-img { position: relative; overflow: hidden; background: var(--bg3); min-height: 320px; }
.fa-img img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(10%) brightness(0.92); transition: transform 0.6s var(--ease); display: block; }
.featured-article:hover .fa-img img { transform: scale(1.04); }
.fa-img::before { content: ''; position: absolute; inset: 0; z-index: 1; background: rgba(0,196,154,0.025); pointer-events: none; }
.fa-img-badge { position: absolute; top: 16px; left: 16px; z-index: 2; font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--bg); background: var(--teal); padding: 4px 10px; border-radius: 3px; }
.articles-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--rule); border: 1px solid var(--rule); border-radius: 6px; overflow: hidden; }
.article-card { background: var(--bg2); display: flex; flex-direction: column; text-decoration: none; color: inherit; transition: background 0.25s; overflow: hidden; }
.article-card:hover { background: var(--bg3); }
.ac-img { width: 100%; height: 200px; overflow: hidden; position: relative; background: var(--bg3); }
.ac-img img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(10%) brightness(0.92); transition: transform 0.5s var(--ease); display: block; }
.article-card:hover .ac-img img { transform: scale(1.04); }
.ac-img::before { content: ''; position: absolute; inset: 0; z-index: 1; background: rgba(0,196,154,0.025); pointer-events: none; }
.ac-body { padding: 28px; display: flex; flex-direction: column; flex: 1; }
.ac-meta { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; flex-wrap: wrap; }
.ac-trade { font-family: var(--mono); font-size: 9.5px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--teal); }
.ac-date { font-family: var(--mono); font-size: 9.5px; color: var(--ink3); letter-spacing: 0.06em; }
.ac-title { font-family: var(--serif); font-size: 20px; font-weight: 400; line-height: 1.28; margin-bottom: 12px; }
.ac-preview { font-size: 13.5px; color: var(--ink2); line-height: 1.65; font-weight: 300; margin-bottom: 16px; flex: 1; }
.ac-pills { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 18px; }
.ac-pill { font-family: var(--mono); font-size: 9px; font-weight: 500; color: var(--ink3); background: var(--bg4); border: 1px solid var(--rule); padding: 3px 8px; border-radius: 3px; }
.ac-read { font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--teal); display: flex; align-items: center; gap: 5px; transition: gap 0.2s; }
.article-card:hover .ac-read { gap: 8px; }
.empty-state { background: var(--bg2); border: 1px solid var(--rule2); border-radius: 6px; padding: 40px; }
.empty-state h2 { font-family: var(--serif); font-size: 28px; font-weight: 400; margin-bottom: 12px; }
.empty-state p { font-size: 14.5px; color: var(--ink2); line-height: 1.72; font-weight: 300; max-width: 620px; }
.nl-prompt { background: rgba(0,196,154,0.04); border: 1px solid rgba(0,196,154,0.22); border-radius: 6px; padding: 28px 32px; margin-top: 36px; display: flex; align-items: center; justify-content: space-between; gap: 24px; }
.nl-prompt-text h3 { font-family: var(--serif); font-size: 19px; font-weight: 400; margin-bottom: 5px; }
.nl-prompt-text p { font-size: 13.5px; color: var(--ink2); font-weight: 300; line-height: 1.6; }
.nl-prompt-form { display: flex; gap: 10px; flex-shrink: 0; }
.nl-prompt-input { background: var(--bg3); border: 1px solid var(--rule2); border-radius: 4px; padding: 11px 16px; font-family: var(--sans); font-size: 13.5px; color: var(--ink); outline: none; transition: border-color 0.2s; width: 220px; }
.nl-prompt-input::placeholder { color: var(--ink3); }
.nl-prompt-input:focus { border-color: rgba(0,196,154,0.5); }
@media (max-width: 960px) {
  .insights-hero { padding: 100px 20px 60px; }
  .insights-hero-inner { grid-template-columns: 1fr; gap: 28px; }
  .featured-article { grid-template-columns: 1fr; }
  .fa-img { min-height: 220px; order: -1; }
  .fa-body { padding: 24px 20px; }
  .articles-grid { grid-template-columns: 1fr; }
  .empty-state { padding: 28px 24px; }
  .nl-prompt { flex-direction: column; align-items: flex-start; }
  .nl-prompt-form { flex-direction: column; width: 100%; }
  .nl-prompt-input { width: 100%; }
}
</style>

<div class="insights-hero">
  <div class="insights-hero-glow"></div>
  <div class="insights-hero-inner">
    <div>
      <div class="dispatch-label">Research &amp; Analysis</div>
      <h1>What the most profitable companies<br><em>actually do differently.</em></h1>
      <p class="sec-p">Every article is built on data from analyzing real HVAC, roofing, and plumbing companies. No opinion pieces. No generic advice. Just patterns from the numbers.</p>
    </div>
    <div>
      <p style="font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink3);margin-bottom:14px">Filter by trade</p>
      <div class="pillar-tabs">
        <a href="/insights#published-research" class="pt active" data-trade="All" aria-current="page">All</a>
        <a href="/insights?trade=HVAC#published-research" class="pt" data-trade="HVAC">HVAC</a>
        <a href="/insights?trade=Roofing#published-research" class="pt" data-trade="Roofing">Roofing</a>
        <a href="/insights?trade=Plumbing#published-research" class="pt" data-trade="Plumbing">Plumbing</a>
      </div>
      <p class="filter-state" id="filter-state">Showing all published research ({allPosts.length} articles)</p>
    </div>
  </div>
</div>

<div class="wrap" id="published-research">
  <div class="inner">
    <div class="rule-label"><span class="section-tag">Published Research</span></div>

    <div id="featured-slot">
      {initialFeatured ? (
        <a href={`/insights/${initialFeatured.slug}`} class="featured-article reveal">
          <div class="fa-body">
            <div>
              <div class="fa-meta">
                <span class="fa-trade">{initialFeatured.data.trade.join(' / ')} · {initialFeatured.data.category}</span>
                <span class="fa-date">{formatDate(initialFeatured.data.pubDate)}</span>
                <span class="fa-read">{initialFeatured.data.readTime} min read</span>
              </div>
              <div class="fa-title">{initialFeatured.data.title}</div>
              <p class="fa-preview">{initialFeatured.data.preview ?? initialFeatured.data.description}</p>
              <div class="fa-pills">
                {initialFeatured.data.pills.map((pill) => <span class="fa-pill">{pill}</span>)}
              </div>
            </div>
            <span class="fa-cta">Read Article</span>
          </div>
          <div class="fa-img">
            <span class="fa-img-badge">Featured</span>
            <img src={initialFeatured.data.heroImage} alt={initialFeatured.data.heroImageAlt} loading="lazy" />
          </div>
        </a>
      ) : (
        <div class="empty-state">
          <h2>No published research yet.</h2>
          <p>New articles will appear here automatically as soon as they are added to the blog collection.</p>
        </div>
      )}
    </div>

    <div class="articles-grid" id="articles-grid" style={initialSecondary.length > 0 ? 'margin-top:1px' : 'display:none'}>
      {initialSecondary.map((article) => (
        <a href={`/insights/${article.slug}`} class="article-card reveal">
          <div class="ac-img">
            <img src={article.data.heroImage} alt={article.data.heroImageAlt} loading="lazy" />
          </div>
          <div class="ac-body">
            <div class="ac-meta">
              <span class="ac-trade">{article.data.trade.join(' / ')} · {article.data.category}</span>
              <span class="ac-date">{formatDate(article.data.pubDate)}</span>
            </div>
            <div class="ac-title">{article.data.title}</div>
            <p class="ac-preview">{article.data.preview ?? article.data.description}</p>
            <div class="ac-pills">
              {article.data.pills.map((pill) => <span class="ac-pill">{pill}</span>)}
            </div>
            <span class="ac-read">Read Article</span>
          </div>
        </a>
      ))}
    </div>

    <div class="nl-prompt">
      <div class="nl-prompt-text">
        <h3>Get every article the day it publishes.</h3>
        <p>Subscribe to the Weekly Growth Report. Real numbers from home service companies, like where close rate, answer rate, and cost per booked job actually land. Free every Tuesday.</p>
      </div>
      <div class="nl-prompt-form">
        <input type="email" class="nl-prompt-input" placeholder="your@email.com" id="insights-email" />
        <button class="cta-filled" style="cursor:pointer;white-space:nowrap" id="insights-submit">Subscribe Free</button>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ posts: postsForClient }}>
  const featuredSlot = document.getElementById('featured-slot');
  const articlesGrid = document.getElementById('articles-grid');
  const filterState = document.getElementById('filter-state');
  const filterLinks = [...document.querySelectorAll('.pt')];
  const validTrades = ['All', 'HVAC', 'Roofing', 'Plumbing'];

  const escapeHtml = (value) =>
    String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

  const featuredMarkup = (post) => `
    <a href="/insights/${post.slug}" class="featured-article reveal on">
      <div class="fa-body">
        <div>
          <div class="fa-meta">
            <span class="fa-trade">${escapeHtml(post.trade.join(' / '))} · ${escapeHtml(post.category)}</span>
            <span class="fa-date">${escapeHtml(post.date)}</span>
            <span class="fa-read">${escapeHtml(post.readTime)} min read</span>
          </div>
          <div class="fa-title">${escapeHtml(post.title)}</div>
          <p class="fa-preview">${escapeHtml(post.description)}</p>
          <div class="fa-pills">
            ${post.pills.map((pill) => `<span class="fa-pill">${escapeHtml(pill)}</span>`).join('')}
          </div>
        </div>
        <span class="fa-cta">Read Article</span>
      </div>
      <div class="fa-img">
        ${post.featured ? '<span class="fa-img-badge">Featured</span>' : ''}
        <img src="${escapeHtml(post.img)}" alt="${escapeHtml(post.imgAlt)}" loading="lazy" />
      </div>
    </a>
  `;

  const cardMarkup = (post) => `
    <a href="/insights/${post.slug}" class="article-card reveal on">
      <div class="ac-img">
        <img src="${escapeHtml(post.img)}" alt="${escapeHtml(post.imgAlt)}" loading="lazy" />
      </div>
      <div class="ac-body">
        <div class="ac-meta">
          <span class="ac-trade">${escapeHtml(post.trade.join(' / '))} · ${escapeHtml(post.category)}</span>
          <span class="ac-date">${escapeHtml(post.date)}</span>
        </div>
        <div class="ac-title">${escapeHtml(post.title)}</div>
        <p class="ac-preview">${escapeHtml(post.description)}</p>
        <div class="ac-pills">
          ${post.pills.map((pill) => `<span class="ac-pill">${escapeHtml(pill)}</span>`).join('')}
        </div>
        <span class="ac-read">Read Article</span>
      </div>
    </a>
  `;

  const emptyMarkup = (trade) => `
    <div class="empty-state">
      <h2>No published ${escapeHtml(trade.toLowerCase())} research yet.</h2>
      <p>We are still building out ${escapeHtml(trade.toLowerCase())} research. Subscribe below and we will send the next one when it goes live.</p>
    </div>
  `;

  const getActiveTrade = () => {
    const currentTrade = new URL(window.location.href).searchParams.get('trade');
    return validTrades.includes(currentTrade || '') ? currentTrade : 'All';
  };

  const applyFilter = () => {
    const activeTrade = getActiveTrade();
    const filteredPosts = activeTrade === 'All'
      ? posts
      : posts.filter((post) => post.trade.includes(activeTrade));

    const featuredPost = filteredPosts.find((post) => post.featured) || filteredPosts[0] || null;
    const secondaryPosts = featuredPost
      ? filteredPosts.filter((post) => post.slug !== featuredPost.slug)
      : [];

    filterLinks.forEach((link) => {
      const isActive = link.dataset.trade === activeTrade;
      link.classList.toggle('active', isActive);
      if (isActive) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });

    const count = filteredPosts.length;
    filterState.textContent = activeTrade === 'All'
      ? `Showing all published research (${count} article${count === 1 ? '' : 's'})`
      : `Showing ${activeTrade} research (${count} published article${count === 1 ? '' : 's'})`;

    featuredSlot.innerHTML = featuredPost ? featuredMarkup(featuredPost) : emptyMarkup(activeTrade);

    if (secondaryPosts.length > 0) {
      articlesGrid.style.display = 'grid';
      articlesGrid.style.marginTop = '1px';
      articlesGrid.innerHTML = secondaryPosts.map(cardMarkup).join('');
    } else {
      articlesGrid.style.display = 'none';
      articlesGrid.innerHTML = '';
    }
  };

  filterLinks.forEach((link) => {
    link.addEventListener('click', (event) => {
      event.preventDefault();
      const url = new URL(link.href, window.location.origin);
      window.history.pushState({}, '', `${url.pathname}${url.search}${url.hash}`);
      applyFilter();
      if (url.hash) {
        document.querySelector(url.hash)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  window.addEventListener('popstate', applyFilter);
  applyFilter();

  document.getElementById('insights-submit').addEventListener('click', async () => {
    const inp = document.getElementById('insights-email');
    const btn = document.getElementById('insights-submit');
    if (!inp.value.includes('@')) {
      inp.style.borderColor = 'rgba(240,64,64,0.55)';
      inp.focus();
      return;
    }
    btn.textContent = 'Subscribing...';
    btn.disabled = true;
    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: inp.value.trim(), source: 'insights-page' }),
      });
      const data = await res.json();
      if (data.success) {
        btn.textContent = 'Subscribed';
        btn.style.background = '#22D37A';
        inp.disabled = true;
      } else {
        btn.textContent = 'Try again';
        btn.disabled = false;
      }
    } catch {
      btn.textContent = 'Try again';
      btn.disabled = false;
    }
  });
</script>
</Layout>
