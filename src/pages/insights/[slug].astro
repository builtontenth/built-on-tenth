---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await post.render();
const { title, description, pubDate, author, category, trade, heroImage, heroImageAlt, readTime, seoKeywords } = post.data;

const formattedDate = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const tradeLabels = trade.join(', ');
---

<Base title={`${title} | Built on Tenth`} description={description} solidNav={true}>

<style>
  /* ── Hero ── */
  .article-hero { background: var(--navy); padding: 5rem 2.5rem 0; }
  .article-hero-inner { max-width: 820px; margin: 0 auto; }
  .article-meta { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
  .article-category {
    background: rgba(245,158,11,0.15); color: var(--amber);
    padding: 0.3rem 0.85rem; border-radius: 20px;
    font-size: 0.72rem; font-weight: 700; font-family: var(--font-display);
    letter-spacing: 0.08em; text-transform: uppercase;
  }
  .article-trade {
    background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.6);
    padding: 0.3rem 0.85rem; border-radius: 20px;
    font-size: 0.72rem; font-weight: 600; font-family: var(--font-display);
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  .article-hero h1 {
    font-family: var(--font-display); font-size: clamp(1.9rem, 3.5vw, 2.9rem);
    font-weight: 800; color: #fff; line-height: 1.18; margin-bottom: 1.25rem;
  }
  .article-byline {
    display: flex; align-items: center; gap: 1.5rem;
    padding-bottom: 2rem; border-bottom: 1px solid rgba(255,255,255,0.08); flex-wrap: wrap;
  }
  .article-byline span { font-size: 0.82rem; color: rgba(255,255,255,0.5); }
  .article-byline strong { color: rgba(255,255,255,0.8); }
  .hero-img-wrap { max-width: 820px; margin: 0 auto; position: relative; top: 2.5rem; }
  .hero-img-wrap img { width: 100%; height: 420px; object-fit: cover; border-radius: 12px; display: block; }

  /* ── Layout ── */
  .article-body { background: var(--cream); padding: 5rem 2.5rem 4rem; }
  .article-body-inner {
    max-width: 820px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 260px; gap: 4rem; align-items: start;
  }

  /* ── Prose — every selector scoped to .prose ── */
  .prose {
    font-family: var(--font-body); font-size: 1.05rem;
    line-height: 1.8; color: var(--text-dark);
  }
  .prose :global(p) { margin-bottom: 1.5rem; }
  .prose :global(h2) {
    font-family: var(--font-display); font-size: 1.55rem; font-weight: 800;
    color: var(--navy); margin: 2.5rem 0 1rem; line-height: 1.25;
    scroll-margin-top: 5rem;
  }
  .prose :global(h3) {
    font-family: var(--font-display); font-size: 1.15rem; font-weight: 700;
    color: var(--navy); margin: 2rem 0 0.75rem;
  }
  .prose :global(strong) { color: var(--navy); font-weight: 700; }
  .prose :global(em) { font-style: italic; }
  .prose :global(hr) { border: none; border-top: 2px solid var(--warm-gray); margin: 2.5rem 0; }
  .prose :global(ul), .prose :global(ol) { margin: 1rem 0 1.5rem 1.5rem; }
  .prose :global(li) { margin-bottom: 0.5rem; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--amber); padding: 1rem 1.5rem;
    margin: 1.5rem 0; background: rgba(245,158,11,0.04);
    border-radius: 0 8px 8px 0;
  }

  /* Tables */
  .prose :global(table) {
    width: 100%; border-collapse: collapse;
    margin: 1.5rem 0 2rem; font-size: 0.88rem;
    border-radius: 8px; overflow: hidden;
    box-shadow: 0 1px 8px rgba(0,0,0,0.08);
    display: table;
  }
  .prose :global(thead) { background: var(--navy); }
  .prose :global(th) {
    background: var(--navy); color: #fff; padding: 0.75rem 1rem;
    text-align: left; font-family: var(--font-display); font-weight: 600;
    font-size: 0.78rem; letter-spacing: 0.04em; text-transform: uppercase;
  }
  .prose :global(td) {
    padding: 0.7rem 1rem; border-bottom: 1px solid var(--warm-gray);
    color: var(--text-dark); vertical-align: top;
  }
  .prose :global(tr:last-child td) { border-bottom: none; }
  .prose :global(tr:nth-child(even) td) { background: rgba(0,0,0,0.025); }

  /* Images — markdown wraps img in <p>, so target p that contains only img */
  .prose :global(p):has(> img) {
    margin-bottom: 0.5rem;
  }
  .prose :global(p > img) {
    width: 100%; border-radius: 10px;
    display: block; margin: 1.5rem 0 0;
  }
  /* Caption: the em immediately after an image paragraph */
  .prose :global(p):has(> img) + :global(p > em) {
    display: block; font-size: 0.8rem; color: var(--text-light);
    margin-top: -0.25rem; margin-bottom: 1.75rem; font-style: italic;
  }

  /* ── FAQ Accordion — auto-applied to ## Frequently Asked Questions section ── */
  .faq-accordion { margin: 0; }
  .faq-accordion-item { border-bottom: 1px solid var(--warm-gray); }
  .faq-accordion-q {
    padding: 1.25rem 0; cursor: pointer;
    display: flex; justify-content: space-between; align-items: center;
    font-family: var(--font-display); font-weight: 700; font-size: 0.95rem;
    color: var(--navy); list-style: none; gap: 1rem;
  }
  .faq-accordion-q::after {
    content: '+'; font-size: 1.3rem; color: var(--amber);
    transition: transform 0.3s; flex-shrink: 0; line-height: 1;
  }
  .faq-accordion-q.open::after { transform: rotate(45deg); }
  .faq-accordion-a {
    max-height: 0; overflow: hidden; transition: max-height 0.4s ease;
  }
  .faq-accordion-a-inner {
    padding: 0 0 1.25rem; font-size: 0.92rem;
    color: var(--text-mid); line-height: 1.7;
  }

  /* ── Sidebar ── */
  .article-sidebar { position: sticky; top: 2rem; }
  .sidebar-card { background: var(--navy); border-radius: 12px; padding: 1.75rem; margin-bottom: 1.5rem; }
  .sidebar-card h4 {
    font-family: var(--font-display); font-size: 0.85rem; font-weight: 700;
    color: var(--amber); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem;
  }
  .sidebar-card p { font-size: 0.88rem; color: rgba(255,255,255,0.65); line-height: 1.6; margin-bottom: 1rem; }
  .sidebar-cta {
    display: block; background: var(--amber); color: var(--navy);
    text-align: center; padding: 0.85rem 1rem; border-radius: 8px;
    font-family: var(--font-display); font-weight: 700; font-size: 0.85rem;
    text-decoration: none; transition: all 0.2s;
  }
  .sidebar-cta:hover { background: var(--amber-light); }
  .sidebar-toc { background: #fff; border: 1px solid var(--warm-gray); border-radius: 12px; padding: 1.5rem; }
  .sidebar-toc h4 {
    font-family: var(--font-display); font-size: 0.8rem; font-weight: 700;
    color: var(--navy); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1rem;
  }
  .sidebar-toc a {
    display: block; font-size: 0.82rem; color: var(--text-mid); text-decoration: none;
    padding: 0.35rem 0; border-bottom: 1px solid var(--warm-gray); line-height: 1.4; transition: color 0.2s;
  }
  .sidebar-toc a:last-child { border-bottom: none; }
  .sidebar-toc a:hover { color: var(--amber); }

  /* ── Article footer ── */
  .article-footer { background: #fff; border-top: 1px solid var(--warm-gray); padding: 3rem 2.5rem; }
  .article-footer-inner { max-width: 820px; margin: 0 auto; }
  .article-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
  .article-tag {
    background: var(--cream); border: 1px solid var(--warm-gray); color: var(--text-mid);
    padding: 0.3rem 0.8rem; border-radius: 20px; font-size: 0.75rem;
    font-family: var(--font-display); font-weight: 600;
  }
  .article-newsletter { background: var(--navy); border-radius: 16px; padding: 2.5rem; text-align: center; }
  .article-newsletter h3 {
    font-family: var(--font-display); font-size: 1.3rem; font-weight: 800; color: #fff; margin-bottom: 0.75rem;
  }
  .article-newsletter p { font-size: 0.92rem; color: rgba(255,255,255,0.65); margin-bottom: 1.5rem; }
  .nl-inline-form { display: flex; gap: 0.75rem; max-width: 420px; margin: 0 auto; }
  .nl-inline-form input {
    flex: 1; padding: 0.85rem 1rem; border: 1.5px solid rgba(255,255,255,0.15);
    border-radius: 8px; background: rgba(255,255,255,0.08); color: #fff;
    font-family: var(--font-body); font-size: 0.9rem; outline: none;
  }
  .nl-inline-form input::placeholder { color: rgba(255,255,255,0.35); }
  .nl-inline-form input:focus { border-color: var(--amber); }
  .nl-inline-form button {
    padding: 0.85rem 1.25rem; background: var(--amber); color: var(--navy);
    border: none; border-radius: 8px; font-family: var(--font-display);
    font-weight: 700; font-size: 0.85rem; cursor: pointer; white-space: nowrap; transition: all 0.2s;
  }
  .nl-inline-form button:hover { background: var(--amber-light); }
  .nl-note-small { font-size: 0.72rem; color: rgba(255,255,255,0.35); margin-top: 0.75rem; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .article-body-inner { grid-template-columns: 1fr; }
    .article-sidebar { position: static; }
    .hero-img-wrap img { height: 260px; }
    .article-hero { padding: 4rem 1.5rem 0; }
    .article-body { padding: 4rem 1.5rem 3rem; }
    .nl-inline-form { flex-direction: column; }
    .article-footer { padding: 2.5rem 1.5rem; }
  }
</style>

<!-- Hero -->
<div class="article-hero">
  <div class="article-hero-inner">
    <div class="article-meta">
      <span class="article-category">{category}</span>
      <span class="article-trade">{tradeLabels}</span>
    </div>
    <h1>{title}</h1>
    <div class="article-byline">
      <span>By <strong>{author}</strong></span>
      <span>{formattedDate}</span>
      <span>{readTime} min read</span>
    </div>
  </div>
  <div class="hero-img-wrap">
    <img src={heroImage} alt={heroImageAlt} loading="eager" />
  </div>
</div>

<!-- Body -->
<div class="article-body">
  <div class="article-body-inner">

    <article class="prose">
      <Content />
    </article>

    <aside class="article-sidebar">
      <div class="sidebar-card">
        <h4>Free Tool</h4>
        <p>Calculate your real cost per booked job and see how you rank against HVAC industry benchmarks.</p>
        <a href="/tools/marketing-calculator" class="sidebar-cta">Run the Calculator →</a>
      </div>
      <div class="sidebar-toc">
        <h4>In This Article</h4>
        <a href="#the-number-everyone-gets-wrong">The Number Everyone Gets Wrong</a>
        <a href="#what-the-data-shows-hvac-marketing-spend-by-revenue">HVAC Spend by Revenue Level</a>
        <a href="#the-budget-formula-do-this-in-10-minutes">The Budget Formula</a>
        <a href="#the-3-places-hvac-companies-leak-marketing-budget">3 Budget Leak Points</a>
        <a href="#what-good-looks-like-at-different-revenue-levels">Benchmarks by Revenue</a>
        <a href="#the-real-answer-to-how-much-should-i-spend">The Real Answer</a>
        <a href="#frequently-asked-questions">FAQ</a>
        <a href="#what-to-do-this-week">What To Do This Week</a>
      </div>
    </aside>

  </div>
</div>

<!-- Footer -->
<div class="article-footer">
  <div class="article-footer-inner">
    <div class="article-tags">
      {seoKeywords.map(kw => (
        <span class="article-tag">{kw}</span>
      ))}
    </div>
    <div class="article-newsletter">
      <h3>Get the next insight on Tuesday</h3>
      <p>One data-backed growth finding every week. Built for HVAC, roofing, and plumbing owners who want to know their numbers.</p>
      <form class="nl-inline-form" id="article-nl-form">
        <input type="email" id="article-nl-email" placeholder="Enter your email" required />
        <button type="submit" id="article-nl-btn">Subscribe Free</button>
      </form>
      <p class="nl-note-small">Free. Every Tuesday. Unsubscribe anytime.</p>
    </div>
  </div>
</div>

<script>
  // FAQ Accordion — auto-converts ## Frequently Asked Questions section
  (function() {
    const prose = document.querySelector('.prose');
    if (!prose) return;
    const headings = prose.querySelectorAll('h2');
    let faqHeading = null;
    headings.forEach(h => { if (h.textContent.toLowerCase().includes('frequently asked')) faqHeading = h; });
    if (!faqHeading) return;

    const container = document.createElement('div');
    container.className = 'faq-accordion';

    // Collect all p elements after the FAQ heading until next h2
    let el = faqHeading.nextElementSibling;
    const items = [];
    let currentQ = null;
    let currentA = [];

    while (el && el.tagName !== 'H2') {
      const next = el.nextElementSibling;
      if (el.tagName === 'P') {
        const strong = el.querySelector('strong');
        if (strong && el.textContent.trim().startsWith(strong.textContent.trim())) {
          // This is a question paragraph
          if (currentQ) items.push({ q: currentQ, a: currentA.join('') });
          currentQ = strong.textContent.trim();
          // Rest of p after strong is part of answer
          const rest = el.innerHTML.replace(`<strong>${strong.textContent}</strong>`, '').trim();
          currentA = rest ? [`<p>${rest}</p>`] : [];
        } else if (currentQ) {
          currentA.push(`<p>${el.innerHTML}</p>`);
        }
      }
      el.parentNode.removeChild(el);
      el = next;
    }
    if (currentQ) items.push({ q: currentQ, a: currentA.join('') });

    items.forEach(item => {
      const div = document.createElement('div');
      div.className = 'faq-accordion-item';
      div.innerHTML = `
        <div class="faq-accordion-q">${item.q}</div>
        <div class="faq-accordion-a"><div class="faq-accordion-a-inner">${item.a}</div></div>
      `;
      const q = div.querySelector('.faq-accordion-q');
      const a = div.querySelector('.faq-accordion-a') as HTMLElement;
      q.addEventListener('click', () => {
        const isOpen = q.classList.toggle('open');
        a.style.maxHeight = isOpen ? a.scrollHeight + 'px' : '0';
      });
      container.appendChild(div);
    });

    faqHeading.insertAdjacentElement('afterend', container);
  })();
    e.preventDefault();
    const email = (document.getElementById('article-nl-email') as HTMLInputElement).value;
    const btn = document.getElementById('article-nl-btn')!;
    btn.textContent = 'Subscribing...';
    (btn as HTMLButtonElement).disabled = true;
    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });
      if (res.ok) {
        btn.textContent = "You're in! ✓";
        (btn as HTMLButtonElement).style.background = '#10b981';
        (btn as HTMLButtonElement).style.color = '#fff';
        (document.getElementById('article-nl-email') as HTMLInputElement).disabled = true;
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ event: 'newsletter_signup', form_location: 'article_footer' });
      } else {
        btn.textContent = 'Subscribe Free';
        (btn as HTMLButtonElement).disabled = false;
      }
    } catch {
      btn.textContent = 'Subscribe Free';
      (btn as HTMLButtonElement).disabled = false;
    }
  });
</script>

</Base>
