---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  }).format(date);

const title = post.data.title;
const description = post.data.description;
const heroImage = post.data.heroImage;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString().slice(0, 10),
  author: { '@type': 'Organization', name: post.data.author },
  publisher: { '@type': 'Organization', name: 'Built on Tenth' },
  image: post.data.heroImage,
  mainEntityOfPage: `https://www.builtontenth.com/insights/${post.slug}`,
  ...(post.data.seoKeywords ? { keywords: post.data.seoKeywords.join(', ') } : {}),
};
---
<Layout title={`${title} | Built on Tenth`} description={description} active="insights" ogImage={heroImage}>

<style>
.article-hero {
  padding: 120px 48px 64px;
  position: relative;
  overflow: hidden;
}
.ah-bg {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center 35%;
  opacity: 0.12;
  filter: grayscale(40%);
}
.ah-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(9,12,11,0.3) 0%, var(--bg) 90%);
}
.ah-inner {
  position: relative;
  z-index: 1;
  max-width: 780px;
  margin: 0 auto;
}
.ah-meta {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 24px;
  flex-wrap: wrap;
}
.ah-cat {
  font-family: var(--mono);
  font-size: 9.5px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--teal);
  background: var(--teal3);
  border: 1px solid var(--teal4);
  padding: 4px 10px;
  border-radius: 3px;
}
.ah-trade {
  font-family: var(--mono);
  font-size: 9.5px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink3);
  background: var(--bg3);
  border: 1px solid var(--rule);
  padding: 4px 10px;
  border-radius: 3px;
}
.ah-date,
.ah-read {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--ink3);
}
.article-h1 {
  font-family: var(--serif);
  font-size: clamp(30px, 5vw, 52px);
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-bottom: 20px;
}
.article-lede {
  font-size: 18px;
  color: var(--ink2);
  line-height: 1.7;
  font-weight: 300;
  margin-bottom: 32px;
}
.ah-author {
  display: flex;
  align-items: center;
  gap: 12px;
  padding-top: 20px;
  border-top: 1px solid var(--rule);
  font-size: 13px;
  color: var(--ink2);
  font-weight: 300;
}
.ah-author strong {
  color: var(--ink);
  font-weight: 500;
}
.back-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--mono);
  font-size: 10.5px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink3);
  text-decoration: none;
  margin-bottom: 28px;
  transition: color 0.2s;
}
.back-link:hover { color: var(--teal); }
.article-body {
  max-width: 780px;
  margin: 0 auto;
  padding: 56px 48px 96px;
}
:global(.article-content h2) {
  font-family: var(--serif);
  font-size: clamp(22px, 3vw, 30px);
  font-weight: 400;
  line-height: 1.2;
  margin: 52px 0 16px;
  color: var(--ink);
}
:global(.article-content h3) {
  font-family: var(--serif);
  font-size: clamp(18px, 2.5vw, 22px);
  font-weight: 400;
  line-height: 1.25;
  margin: 36px 0 12px;
  color: var(--ink);
}
:global(.article-content p) {
  font-size: 16px;
  color: var(--ink2);
  line-height: 1.82;
  margin-bottom: 22px;
  font-weight: 300;
}
:global(.article-content strong) {
  color: var(--ink);
  font-weight: 600;
}
:global(.article-content a) {
  color: var(--teal);
  text-decoration: none;
  border-bottom: 1px solid var(--teal4);
  transition: border-color 0.2s;
}
:global(.article-content a:hover) { border-bottom-color: var(--teal); }
:global(.article-content ul),
:global(.article-content ol) {
  padding-left: 0;
  list-style: none;
  margin-bottom: 24px;
}
:global(.article-content ul li),
:global(.article-content ol li) {
  font-size: 16px;
  color: var(--ink2);
  line-height: 1.75;
  font-weight: 300;
  padding: 6px 0 6px 22px;
  position: relative;
  border-bottom: 1px solid var(--rule);
}
:global(.article-content ul li:last-child),
:global(.article-content ol li:last-child) {
  border-bottom: none;
}
:global(.article-content ul li::before) {
  content: '';
  position: absolute;
  left: 0;
  top: 15px;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--teal);
}
:global(.article-content ol) { counter-reset: ol-counter; }
:global(.article-content ol li::before) {
  content: counter(ol-counter);
  counter-increment: ol-counter;
  position: absolute;
  left: 0;
  color: var(--teal);
  font-family: var(--mono);
  font-size: 12px;
  font-weight: 600;
}
:global(.article-content hr) {
  border: none;
  border-top: 1px solid var(--rule);
  margin: 52px 0 36px;
}
:global(.article-content blockquote) {
  margin: 32px 0;
  padding: 18px 24px;
  border-left: 3px solid var(--teal);
  background: rgba(0,196,154,0.05);
  border-radius: 4px;
}
:global(.article-content blockquote p:last-child) {
  margin-bottom: 0;
}
:global(.article-content p:has(> img)) {
  width: 100%;
  border-radius: 5px;
  overflow: hidden;
  margin: 36px 0 12px;
  position: relative;
  background: var(--bg3);
  border: 1px solid var(--rule);
}
:global(.article-content p > img) {
  width: 100%;
  height: 380px;
  object-fit: cover;
  filter: grayscale(15%) brightness(0.82);
  display: block;
}
:global(.article-content p:has(> img) + p:has(> em:only-child)) {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--ink3);
  padding: 10px 14px;
  border: 1px solid var(--rule);
  border-top: none;
  border-radius: 0 0 5px 5px;
  margin-top: -12px;
  margin-bottom: 28px;
  letter-spacing: 0.04em;
  background: var(--bg3);
}
:global(.article-content p:has(> img) + p:has(> em:only-child) em) {
  font-style: normal;
}
:global(.article-content table) {
  width: 100%;
  border-collapse: collapse;
  font-size: 13.5px;
  margin: 32px 0;
  border: 1px solid var(--rule);
  border-radius: 5px;
  table-layout: fixed;
}
:global(.article-content thead) {
  background: var(--bg3);
}
:global(.article-content th) {
  font-family: var(--mono);
  font-size: 9.5px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink3);
  padding: 12px 16px;
  text-align: left;
  border-bottom: 1px solid var(--rule2);
  white-space: nowrap;
}
:global(.article-content td) {
  padding: 11px 16px;
  color: var(--ink2);
  border-bottom: 1px solid var(--rule);
  font-weight: 300;
  line-height: 1.5;
  white-space: normal;
  overflow-wrap: anywhere;
}
:global(.article-content tr:last-child td) {
  border-bottom: none;
}
:global(.article-content tr:nth-child(even) td) {
  background: rgba(226,221,208,0.02);
}
.article-cta {
  margin-top: 64px;
  background: var(--bg2);
  border: 1px solid rgba(0,196,154,0.25);
  border-radius: 6px;
  padding: 36px 40px;
  text-align: center;
}
.article-cta h3 {
  font-family: var(--serif);
  font-size: 24px;
  font-weight: 400;
  margin-bottom: 12px;
}
.article-cta h3 em {
  font-style: italic;
  color: var(--teal);
}
.article-cta p {
  font-size: 14px;
  color: var(--ink2);
  line-height: 1.7;
  margin: 0 auto 24px;
  font-weight: 300;
  max-width: 480px;
}
.article-cta-btns {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
}
.article-cta .cta-primary {
  color: var(--bg);
  border-bottom: none;
}
.article-cta .cta-secondary {
  color: var(--ink2);
  border-bottom: none;
}
@media (max-width: 960px) {
  .article-hero { padding: 100px 20px 48px; }
  .article-body { padding: 40px 20px 72px; }
  :global(.article-content p > img) { height: 220px; }
  :global(.article-content table) {
    display: block;
    border: none;
    margin: 28px 0;
  }
  :global(.article-content thead) {
    display: none;
  }
  :global(.article-content tbody) {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  :global(.article-content tr) {
    display: grid;
    gap: 0;
    border: 1px solid var(--rule);
    border-radius: 5px;
    overflow: hidden;
    background: var(--bg2);
  }
  :global(.article-content td) {
    display: grid;
    grid-template-columns: minmax(0, 110px) minmax(0, 1fr);
    gap: 12px;
    align-items: start;
    padding: 10px 12px;
    white-space: normal;
  }
  :global(.article-content td::before) {
    content: attr(data-label);
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink3);
  }
  .article-cta { padding: 28px 24px; }
  .article-cta-btns { flex-direction: column; gap: 10px; }
  .article-cta-btns a { justify-content: center; }
}
</style>

<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
<div class="article-hero">
  <div class="ah-bg" style={`background-image: url('${heroImage}')`}></div>
  <div class="ah-overlay"></div>
  <div class="ah-inner">
    <a href="/insights" class="back-link">All Insights</a>
    <div class="ah-meta">
      <span class="ah-cat">{post.data.category}</span>
      {post.data.trade.map((trade) => <span class="ah-trade">{trade}</span>)}
      <span class="ah-date">{formatDate(post.data.pubDate)}</span>
      <span class="ah-read">{post.data.readTime} min read</span>
    </div>
    <h1 class="article-h1">{title}</h1>
    <p class="article-lede">{description}</p>
    <div class="ah-author">
      <div><strong>{post.data.author}</strong> · Revenue intelligence for home service companies</div>
    </div>
  </div>
</div>

<div class="article-body">
  <article class="article-content">
    <Content />
  </article>

  <div class="article-cta">
    <h3>Take the next step with the <em>right tool.</em></h3>
    <p>Use the matching free tool to benchmark your numbers, or go straight to a full audit if you want the full picture in writing.</p>
    <div class="article-cta-btns">
      <a href={post.data.primaryCtaHref} class="cta-primary">{post.data.primaryCtaLabel}</a>
      <a href={post.data.secondaryCtaHref} class="cta-secondary">{post.data.secondaryCtaLabel}</a>
    </div>
  </div>
</div>
<script is:inline>
  document.querySelectorAll('.article-content table').forEach((table) => {
    const headers = [...table.querySelectorAll('thead th')].map((th) => th.textContent?.trim() || '');
    if (!headers.length) return;
    table.querySelectorAll('tbody tr').forEach((row) => {
      [...row.children].forEach((cell, index) => {
        if (cell instanceof HTMLElement) {
          cell.dataset.label = headers[index] || '';
        }
      });
    });
  });
</script>
</Layout>
