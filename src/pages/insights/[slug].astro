---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ResponsiveImage from '../../components/ResponsiveImage.astro';
import MarkdownImage from '../../components/MarkdownImage.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const allPosts = await getCollection('blog');
const SITE = 'https://www.builtontenth.com';
const AUTHOR_URL = `${SITE}/about`;
const modifiedDate = post.data.updatedDate ?? post.data.pubDate;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  }).format(date);

const title = post.data.title;
const description = post.data.metaDescription ?? post.data.description;
const heroImage = post.data.heroImage;
const canonicalUrl = `${SITE}/insights/${post.slug}`;
const heroImagePositions: Record<string, string> = {
  'how-hvac-service-agreements-add-200k-annual-revenue': '72% center',
  'how-much-should-hvac-company-spend-on-marketing-2026': '72% center',
  'how-to-set-up-google-local-service-ads-hvac': '62% center',
  'hvac-cost-per-lead-by-channel-2026': '72% center',
  'four-numbers-hvac-owner-marketing': '56% center',
  'what-to-ask-hvac-marketing-agency-before-signing': '58% center',
  'servicetitan-roi-audit-hvac': '64% center',
};
const heroImagePosition = heroImagePositions[post.slug] ?? 'center';
const currentIsHvac = post.data.trade.includes('HVAC');

const relatedPosts = allPosts
  .filter((candidate) => candidate.slug !== post.slug)
  .map((candidate) => {
    const sharedTrades = candidate.data.trade.filter((trade) => post.data.trade.includes(trade)).length;
    const sameCategory = candidate.data.category === post.data.category ? 1 : 0;
    const candidateIsHvac = candidate.data.trade.includes('HVAC');
    const samePrimaryTrade = candidate.data.trade[0] === post.data.trade[0] ? 1 : 0;
    const hvacPriority = currentIsHvac && candidateIsHvac ? 4 : 0;
    const crossTradePenalty = currentIsHvac && !candidateIsHvac ? -2 : 0;
    const score = sharedTrades * 3 + sameCategory * 2 + samePrimaryTrade + hvacPriority + crossTradePenalty;
    return { candidate, score };
  })
  .filter(({ score }) => score > 0)
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;
    return b.candidate.data.pubDate.getTime() - a.candidate.data.pubDate.getTime();
  })
  .slice(0, currentIsHvac ? 3 : 2)
  .map(({ candidate }) => candidate);

const toolLibrary = {
  '/tools/phone-calculator': {
    href: '/tools/phone-calculator',
    label: 'Phone Revenue Calculator',
    description: 'Quantify what missed calls and weak answer rate are costing per month.',
    img: '/images/brand/core/tool-phone-calculator.png',
    imgAlt: 'Inbound calls being handled at the front desk',
  },
  '/tools/marketing-calculator': {
    href: '/tools/marketing-calculator',
    label: 'Marketing Cost Calculator',
    description: 'Benchmark true cost per booked job against stronger operators.',
    img: '/images/brand/core/tool-marketing-calculator.png',
    imgAlt: 'Comparing marketing spend to booked jobs',
  },
  '/tools/agency-report-card': {
    href: '/tools/agency-report-card',
    label: 'Agency Report Card',
    description: 'Grade whether your agency is measuring booked jobs or hiding behind vanity metrics.',
    img: '/images/brand/core/tool-agency-report-card.png',
    imgAlt: 'Reviewing printed agency reports with skepticism',
  },
  '/tools/website-audit': {
    href: '/tools/website-audit',
    label: 'Website Conversion Scorecard',
    description: 'Check for mobile, speed, trust, and phone-visibility leaks.',
    img: '/images/brand/core/tool-website-audit.png',
    imgAlt: 'Reviewing website issues in a real work setting',
  },
  '/tools/revenue-per-tech': {
    href: '/tools/revenue-per-tech',
    label: 'Revenue Per Technician Benchmarker',
    description: 'See whether your team output is below benchmark and how big the gap is.',
    img: '/images/brand/core/tool-revenue-per-tech.png',
    imgAlt: 'Reviewing route sheets and team output near trucks',
  },
  '/tools/estimate-follow-up': {
    href: '/tools/estimate-follow-up',
    label: 'Estimate Follow-Up Calculator',
    description: 'Measure how much revenue is leaking from quotes that never get chased.',
    img: '/images/brand/core/tool-estimate-follow-up.png',
    imgAlt: 'Sorting stale estimates and follow-up notes',
  },
  '/tools/gbp-scorecard': {
    href: '/tools/gbp-scorecard',
    label: 'GBP Scorecard',
    description: 'Score your Google Business Profile against the local map pack baseline.',
    img: '/images/brand/core/tool-gbp-scorecard.png',
    imgAlt: 'Reviewing local reputation and competitor notes',
  },
};

const hvacToolFallbacks = ['/tools/marketing-calculator', '/tools/phone-calculator'];

const toolPaths = currentIsHvac
  ? [post.data.primaryCtaHref, ...hvacToolFallbacks].filter(
      (path, index, paths) => path in toolLibrary && paths.indexOf(path) === index
    )
  : [];

const recommendedTools = toolPaths.map((path) => toolLibrary[path as keyof typeof toolLibrary]).slice(0, 2);

const markdownComponents = {
  img: MarkdownImage,
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description,
  datePublished: post.data.pubDate.toISOString().slice(0, 10),
  dateModified: modifiedDate.toISOString().slice(0, 10),
  author: {
    '@type': 'Person',
    name: post.data.author,
    url: AUTHOR_URL,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Built on Tenth',
    url: SITE,
  },
  image: post.data.heroImage,
  mainEntityOfPage: canonicalUrl,
  ...(post.data.seoKeywords ? { keywords: post.data.seoKeywords.join(', ') } : {}),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE },
    { '@type': 'ListItem', position: 2, name: 'HVAC Market Insights', item: `${SITE}/insights` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: canonicalUrl },
  ],
};
---
<Layout
  title={post.data.seoTitle ?? `${title} | Built on Tenth`}
  description={description}
  active="insights"
  ogImage={heroImage}
  ogType="article"
  publishedTime={post.data.pubDate.toISOString()}
>
  

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="article-page">
    <div class="article-shell">
      <section class="article-hero">
        <div class="article-hero__inner">
          <a href="/insights" class="back-link">All HVAC Market Insights</a>

          <div class="article-meta">
            <span class="article-pill">{post.data.category}</span>
            {post.data.trade.map((trade) => <span class="article-pill article-pill--muted">{trade}</span>)}
            <span class="article-pill article-pill--muted">{formatDate(post.data.pubDate)}</span>
            <span class="article-pill article-pill--muted">{post.data.readTime} min read</span>
          </div>

          <h1 class="article-title">{title}</h1>
          <p class="article-lede">{description}</p>

          <div class="article-author">
            <strong><a href="/about">{post.data.author}</a></strong>
            <span>Independent HVAC market insights and local visibility analysis</span>
            {modifiedDate.getTime() !== post.data.pubDate.getTime() && (
              <span>Updated {formatDate(modifiedDate)}</span>
            )}
          </div>
        </div>

        <figure class="article-hero__media">
          <div class="article-hero__media-frame">
            <ResponsiveImage
              src={heroImage}
              alt={post.data.heroImageAlt}
              widths={[640, 960, 1280, 1600]}
              sizes="(max-width: 960px) 100vw, 960px"
              priority={true}
              position={heroImagePosition}
            />
          </div>
          <figcaption class="article-hero__caption">{post.data.heroImageAlt}</figcaption>
        </figure>
      </section>

      <div class="article-layout">
        <aside class="article-rail">
          <div class="rail-card">
            <span class="rail-label">Why read this</span>
            <h3>Built for operators who want a useful answer fast.</h3>
            <ul class="rail-list">
              <li>Real numbers and practical benchmarks</li>
              <li>Clear language instead of consultant filler</li>
              <li>A direct next step if the article exposes a leak</li>
            </ul>
          </div>

          <div class="rail-card">
            <span class="rail-label">Next action</span>
            <h3>Turn the insight into a number.</h3>
            <p>If this article surfaced a leak, use the matching tool or go straight to the full report for a market-level answer.</p>
            <div class="rail-card__action">
              <a href={post.data.primaryCtaHref} class="rail-btn">{post.data.primaryCtaLabel}</a>
            </div>
          </div>
        </aside>

        <main class="article-main">
          <article class="article-content">
            <Content components={markdownComponents} />
          </article>

          <div class="article-cta">
            <h3>Take the next step while the gap is still clear.</h3>
            <p>Use the matching free tool to benchmark your numbers, or go straight to a full written report if you want the market picture instead of one isolated metric.</p>
            <div class="article-cta-btns">
              <a href={post.data.primaryCtaHref} class="btn btn--primary">{post.data.primaryCtaLabel}</a>
              <a href={post.data.secondaryCtaHref} class="btn btn--ghost">{post.data.secondaryCtaLabel}</a>
            </div>
          </div>

          {relatedPosts.length > 0 && (
            <section class="article-related">
              <div class="article-related-head">
                <div>
                  <span>Related insights</span>
                  <h3>Keep reading without losing the thread.</h3>
                </div>
              </div>
              <div class="article-related-grid">
                {relatedPosts.map((related) => (
                  <a href={`/insights/${related.slug}`} class="editorial-card article-related-card">
                    <div class="editorial-media editorial-media--landscape">
                      <ResponsiveImage
                        src={related.data.heroImage}
                        alt={related.data.heroImageAlt}
                        widths={[480, 720, 960]}
                        sizes="(max-width: 1100px) 100vw, 33vw"
                        position={heroImagePositions[related.slug] ?? 'center'}
                        fit="cover"
                      />
                    </div>
                    <div class="editorial-body">
                      <div class="editorial-title editorial-title--md">{related.data.title}</div>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          )}

          {recommendedTools.length > 0 && (
            <section class="article-related">
              <div class="article-related-head">
                <div>
                  <span>Recommended tools</span>
                  <h3>Useful next clicks if you want a faster benchmark.</h3>
                </div>
              </div>
              <div class="article-related-grid">
                {recommendedTools.map((tool) => (
                  <a href={tool.href} class="editorial-card article-related-card article-related-card--tool">
                    <div class="editorial-media editorial-media--landscape">
                      <ResponsiveImage
                        src={tool.img}
                        alt={tool.imgAlt}
                        widths={[480, 720, 960]}
                        sizes="(max-width: 1100px) 100vw, 33vw"
                        fit="cover"
                      />
                    </div>
                    <div class="editorial-body">
                      <div class="editorial-title editorial-title--md">{tool.label}</div>
                      <p class="editorial-copy">{tool.description}</p>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          )}
        </main>
      </div>
    </div>
  </div>

  <script is:inline>
    document.querySelectorAll('.article-content table').forEach((table) => {
      const headers = [...table.querySelectorAll('thead th')].map((th) => th.textContent?.trim() || '');
      if (!headers.length) return;
      table.querySelectorAll('tbody tr').forEach((row) => {
        [...row.children].forEach((cell, index) => {
          if (cell instanceof HTMLElement) {
            cell.dataset.label = headers[index] || '';
          }
        });
      });
    });
  </script>
</Layout>
