---
import Layout from '../layouts/Layout.astro';
import ResponsiveImage from '../components/ResponsiveImage.astro';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Built on Tenth',
  url: 'https://www.builtontenth.com',
  description:
    'Revenue intelligence for HVAC, roofing, and plumbing companies. Independent research, benchmarks, tools, and revenue leak audits for home service operators.',
  founder: {
    '@type': 'Person',
    name: 'Tanvir Hossain',
    url: 'https://www.builtontenth.com/about',
  },
  areaServed: 'United States',
  sameAs: ['https://www.linkedin.com/in/fortanvir/'],
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Tanvir Hossain',
  url: 'https://www.builtontenth.com/about',
  image: 'https://www.builtontenth.com/tanvir.png',
  jobTitle: 'Founder',
  worksFor: {
    '@type': 'Organization',
    name: 'Built on Tenth',
    url: 'https://www.builtontenth.com',
  },
  sameAs: ['https://www.linkedin.com/in/fortanvir/'],
};
---
<Layout
  title="About Built on Tenth - Revenue Intelligence for Home Service Companies"
  description="Who we are, why we exist, and how we work. No agency incentives. No retainers. Just independent research for HVAC, roofing, and plumbing operators."
  active="about"
>

<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

<style>
.about-hero {
  padding: 140px 48px 80px; position: relative; overflow: hidden;
}
.about-hero-glow {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 60% 70% at 15% 50%, rgba(0,196,154,0.06) 0%, transparent 60%);
}
.about-hero-inner {
  position: relative; z-index: 1; max-width: 1200px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 380px; gap: 80px; align-items: start;
}
.about-hero h1 {
  font-family: var(--serif); font-size: clamp(38px, 5vw, 62px);
  font-weight: 400; line-height: 1.08; letter-spacing: -0.02em; margin-bottom: 24px;
}
.about-hero h1 em { font-style: italic; color: var(--teal); }
.about-hero-sub {
  font-size: 17px; color: var(--ink2); line-height: 1.74;
  font-weight: 300; margin-bottom: 36px; max-width: 560px;
}
.about-hero-badges { display: flex; gap: 10px; flex-wrap: wrap; }
.about-badge {
  font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--ink3); background: var(--bg3); border: 1px solid var(--rule2);
  padding: 6px 12px; border-radius: 3px;
}

/* Founder card */
.founder-card {
  background: var(--bg2); border: 1px solid var(--rule2); border-radius: 8px; overflow: hidden;
}
.founder-img { width: 100%; height: 420px; overflow: hidden; position: relative; background: var(--bg3); }
.founder-img img { width: 100%; height: 100%; object-fit: contain; object-position: center top; }
.founder-body { padding: 24px 24px 28px; }
.founder-name {
  font-family: var(--serif); font-size: 22px; font-weight: 400; margin-bottom: 4px;
}
.founder-title {
  font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--teal); margin-bottom: 16px;
}
.founder-bio { font-size: 13.5px; color: var(--ink2); line-height: 1.7; font-weight: 300; margin-bottom: 18px; }
.founder-link {
  font-family: var(--mono); font-size: 10.5px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--teal); text-decoration: none; display: flex; align-items: center; gap: 6px; transition: gap 0.2s;
}
.founder-link:hover { gap: 10px; }

/* Stats row */
.about-stats { border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); background: var(--bg2); }
.about-stats-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); }
.as-card { padding: 32px; border-right: 1px solid var(--rule); text-align: center; }
.as-card:last-child { border-right: none; }
.as-n { font-family: var(--mono); font-size: 36px; font-weight: 600; color: var(--teal); letter-spacing: -0.03em; line-height: 1; margin-bottom: 6px; }
.as-l { font-size: 12.5px; color: var(--ink2); line-height: 1.5; font-weight: 300; }

/* Why we exist */
.why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
.pull-quote {
  font-family: var(--serif); font-size: clamp(20px, 2.5vw, 26px); font-style: italic;
  color: var(--ink); line-height: 1.5; border-left: 2px solid var(--teal); padding-left: 24px;
  margin: 32px 0;
}

/* Methodology */
.method-steps { display: flex; flex-direction: column; gap: 0; margin-top: 48px; }
.method-step { display: grid; grid-template-columns: 60px 1fr; gap: 24px; align-items: start; padding: 32px 0; border-bottom: 1px solid var(--rule); }
.method-step:last-child { border-bottom: none; }
.ms-num {
  font-family: var(--mono); font-size: 32px; font-weight: 600; letter-spacing: -0.03em;
  color: var(--bg3); -webkit-text-stroke: 1.5px var(--rule2); line-height: 1; padding-top: 4px;
}
.ms-title { font-family: var(--serif); font-size: 20px; font-weight: 400; margin-bottom: 10px; }
.ms-body { font-size: 14px; color: var(--ink2); line-height: 1.72; font-weight: 300; }

/* What we are / aren't */
.are-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 48px; }
.are-card { border-radius: 5px; padding: 24px 26px; }
.are-card.is-not { background: var(--bg3); border: 1px solid var(--rule); }
.are-card.is-this { background: rgba(0,196,154,0.05); border: 1px solid rgba(0,196,154,0.22); }
.are-tag {
  font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
  margin-bottom: 12px; display: flex; align-items: center; gap: 6px;
}
.are-tag.not { color: var(--neg); }
.are-tag.yes { color: var(--pos); }
.are-title { font-family: var(--serif); font-size: 18px; font-weight: 400; margin-bottom: 10px; }
.are-body { font-size: 13.5px; color: var(--ink2); line-height: 1.65; font-weight: 300; }

/* Who it's for */
.icp-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--rule); border: 1px solid var(--rule); border-radius: 6px; overflow: hidden; margin-top: 48px; }
.icp-card { background: var(--bg2); padding: 32px 28px; transition: background 0.25s; }
.icp-card:hover { background: var(--bg3); }
.icp-icon { font-size: 26px; margin-bottom: 16px; }
.icp-title { font-family: var(--sans); font-size: 15px; font-weight: 600; margin-bottom: 10px; }
.icp-body { font-size: 13.5px; color: var(--ink2); line-height: 1.65; font-weight: 300; }

/* ICP profile box */
.icp-profile {
  background: var(--bg3); border: 1px solid var(--rule2); border-radius: 6px;
  padding: 32px 36px; margin-top: 24px;
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
}
.icp-p-item {}
.icp-p-label { font-family: var(--mono); font-size: 9.5px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink3); margin-bottom: 5px; }
.icp-p-val { font-size: 13.5px; color: var(--ink); font-weight: 500; line-height: 1.45; }

/* Bottom CTA */
.about-cta { text-align: center; padding: 112px 48px; position: relative; overflow: hidden; }
.about-cta-glow { position: absolute; inset: 0; background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(0,196,154,0.07) 0%, transparent 65%); }
.about-cta-inner { position: relative; z-index: 1; max-width: 520px; margin: 0 auto; }
.about-cta h2 { font-family: var(--serif); font-size: clamp(30px, 4vw, 48px); font-weight: 400; line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 18px; }
.about-cta h2 em { font-style: italic; color: var(--teal); }
.about-cta p { font-size: 16px; color: var(--ink2); line-height: 1.72; margin-bottom: 36px; font-weight: 300; }
.about-cta-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

/* Founder image container - better crop */
.founder-card { display: flex; flex-direction: column; }
.founder-img { background: linear-gradient(135deg, var(--bg3), var(--bg4)); }
.founder-img img { object-position: center top; }

@media (max-width: 1100px) {
  .about-hero-inner { grid-template-columns: 1fr; }
  .founder-card { max-width: 480px; }
}
@media (max-width: 960px) {
  .about-hero { padding: 100px 20px 60px; }
  .about-hero h1 { font-size: clamp(28px, 8vw, 46px); }
  .about-hero-badges { gap: 8px; }
  .founder-card { max-width: 100%; }
  .founder-img { height: 360px; }
  .why-grid { grid-template-columns: 1fr; gap: 32px; }
  .why-grid img { display: none; }
  .about-stats-inner { grid-template-columns: 1fr 1fr; }
  .as-card:nth-child(2) { border-right: none; }
  .as-card:nth-child(1), .as-card:nth-child(2) { border-bottom: 1px solid var(--rule); }
  .are-grid { grid-template-columns: 1fr; }
  .icp-grid { grid-template-columns: 1fr; }
  .icp-profile { grid-template-columns: 1fr 1fr; }
  .about-cta { padding: 72px 20px; }
  .about-cta-btns { flex-direction: column; gap: 10px; }
  .about-cta-btns a { justify-content: center; }
  .method-step { grid-template-columns: 44px 1fr; gap: 16px; }
  .pull-quote { font-size: 18px; }
}
@media (max-width: 600px) {
  .about-stats-inner { grid-template-columns: 1fr; }
  .as-card { border-right: none; border-bottom: 1px solid var(--rule); }
  .as-card:last-child { border-bottom: none; }
  .icp-profile { grid-template-columns: 1fr; }
}
</style>

<!-- HERO -->
<div class="about-hero">
  <div class="about-hero-glow"></div>
  <div class="about-hero-inner">
    <div>
      <div class="dispatch-label">About Built on Tenth</div>
      <h1>We study how HVAC, roofing, and plumbing companies <em>actually grow.</em></h1>
      <p class="about-hero-sub">Built on Tenth is a revenue intelligence operation. We analyze the marketing systems, competitive positioning, and phone conversion performance of home service companies across the US, and publish everything we find. No agency incentives. No retainers. No reason to recommend more ad spend.</p>
      <div class="about-hero-badges">
        <span class="about-badge">Independent research</span>
        <span class="about-badge">No ad spend incentive</span>
        <span class="about-badge">Written delivery only</span>
        <span class="about-badge">3 trades · 15+ markets</span>
      </div>
    </div>
    <div class="founder-card">
      <div class="founder-img">
        <ResponsiveImage src="/tanvir.png" alt="Tanvir Hossain - Founder, Built on Tenth" widths={[320, 480, 640]} sizes="(max-width: 1100px) 100vw, 380px" />
        <div class="img-fb">👤</div>
      </div>
      <div class="founder-body">
        <div class="founder-name">Tanvir Hossain</div>
        <div class="founder-title">Founder, Built on Tenth</div>
        <p class="founder-bio">After analyzing hundreds of HVAC, roofing, and plumbing companies, their Google presence, ad strategies, phone systems, and competitive positions, the pattern became clear. The top performers weren't spending more. They were measuring differently, handling calls better, and following up where everyone else gave up.</p>
        <a href="https://www.linkedin.com/in/fortanvir/" target="_blank" rel="noopener" class="founder-link">Connect on LinkedIn</a>
      </div>
    </div>
  </div>
</div>

<!-- STATS BAR -->
<div class="about-stats">
  <div class="about-stats-inner">
    <div class="as-card"><div class="as-n">3</div><div class="as-l">trades covered: HVAC,<br>Roofing, Plumbing</div></div>
    <div class="as-card"><div class="as-n">15+</div><div class="as-l">US markets<br>researched</div></div>
    <div class="as-card"><div class="as-n">$0</div><div class="as-l">incentive to upsell<br>more ad spend</div></div>
    <div class="as-card"><div class="as-n">100%</div><div class="as-l">written delivery,<br>no calls required</div></div>
  </div>
</div>

<!-- WHY WE EXIST -->
<div class="wrap alt">
  <div class="inner">
    <div class="rule-label"><span class="section-tag">Why We Exist</span></div>
    <div class="why-grid">
      <div class="reveal">
        <h2 class="sec-h">Most home service owners are flying blind on <em>marketing spend.</em></h2>
        <p class="sec-p">They write checks - $5,000 to $15,000 every month - to agencies, lead platforms, and ad networks. In return they get click reports, impression counts, and quality scores. But nobody tells them their cost per booked job. Nobody shows them which channel is producing and which is burning cash.</p>
        <p class="sec-p" style="margin-top:16px">Agencies have a financial incentive to recommend more spend. Lead platforms charge per call regardless of whether those calls book. And most software vendors define success as more activity - not more revenue.</p>
        <div class="pull-quote">"The companies losing the most money on marketing aren't being scammed. They just don't have the data to see what's happening. That's the problem we're solving."</div>
        <p class="sec-p">Built on Tenth sits outside that incentive structure. We don't run ads, don't manage campaigns, and don't take referral fees. Our only product is analysis - which means our only incentive is getting the analysis right.</p>
      </div>
      <div class="reveal">
        <ResponsiveImage src="/images/brand/core/core-about-why-we-exist.png" alt="Home service contractor at work" widths={[480, 640, 960]} sizes="(max-width: 960px) 100vw, 50vw" style="width:100%;height:420px;border-radius:6px;border:1px solid var(--rule2);filter:none" />
      </div>
    </div>
  </div>
</div>

<!-- METHODOLOGY -->
<div class="wrap">
  <div class="inner">
    <div class="rule-label"><span class="section-tag">How We Work</span></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:end">
      <h2 class="sec-h">The research <em>methodology</em></h2>
      <p class="sec-p" style="max-width:100%">Each audit follows the same five-step process. Built over hundreds of company analyses. Refined to surface the gaps that actually cost contractors money.</p>
    </div>
    <div class="method-steps">
      <div class="method-step reveal">
        <div class="ms-num">01</div>
        <div>
          <div class="ms-title">Competitive market analysis</div>
          <p class="ms-body">For every company we study, we map the full competitive landscape - Google Business Profile performance, review velocity, ad visibility, and organic ranking across their actual service markets. We benchmark against the top 5–7 performers in that same geography. Most owners have never seen this comparison. It's usually the first shock.</p>
        </div>
      </div>
      <div class="method-step reveal">
        <div class="ms-num">02</div>
        <div>
          <div class="ms-title">Revenue leak identification</div>
          <p class="ms-body">We translate every gap into a dollar figure. Not "your phone answer rate is low" - but "at your call volume and average ticket, a 66% answer rate costs you an estimated $84,000/month in missed revenue." Every finding gets a number attached. No vague recommendations.</p>
        </div>
      </div>
      <div class="method-step reveal">
        <div class="ms-num">03</div>
        <div>
          <div class="ms-title">Pattern recognition across companies</div>
          <p class="ms-body">Individual audits feed into broader benchmarks. When we've analyzed 50 roofing companies' phone systems, we can tell you exactly what the top quartile does differently - and what it's worth in revenue. That research gets published free. That's what keeps this independent.</p>
        </div>
      </div>
      <div class="method-step reveal">
        <div class="ms-num">04</div>
        <div>
          <div class="ms-title">System design, not just diagnosis</div>
          <p class="ms-body">For clients who engage for a full audit, findings become blueprints. Phone scripts, follow-up sequences, tracking dashboards, channel allocation - every recommendation comes with an implementation path. Not just a problem description.</p>
        </div>
      </div>
      <div class="method-step reveal">
        <div class="ms-num">05</div>
        <div>
          <div class="ms-title">Written delivery, always</div>
          <p class="ms-body">Every piece of work - from free tools to full audits - is delivered in writing. No calls, no presentations, no slide decks that gather dust. Documentation you can reference, share with your team, and act on at your pace.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- WHAT WE ARE / AREN'T -->
<div class="wrap alt">
  <div class="inner">
    <div class="rule-label"><span class="section-tag">What We Are - And Aren't</span></div>
    <h2 class="sec-h" style="margin-bottom:10px">Understanding this distinction <em>matters.</em></h2>
    <p class="sec-p">It affects whose advice you can trust - and whose advice is shaped by what they're selling.</p>
    <div class="are-grid">
      <div class="are-card is-not reveal">
        <div class="are-tag not">✕ Not This</div>
        <div class="are-title">A marketing agency</div>
        <div class="are-body">Agencies run your ads, manage your campaigns, and take a percentage of spend. They benefit when you spend more. The incentive structure points toward more activity, not more booked jobs.</div>
      </div>
      <div class="are-card is-this reveal">
        <div class="are-tag yes">✓ This</div>
        <div class="are-title">An independent research operation</div>
        <div class="are-body">We study what works, publish the findings, and charge only for the analysis itself. Zero incentive to recommend more spend - ever. Our reputation depends entirely on being right.</div>
      </div>
      <div class="are-card is-not reveal">
        <div class="are-tag not">✕ Not This</div>
        <div class="are-title">A coaching or consulting program</div>
        <div class="are-body">No monthly retainers, no mastermind groups, no recurring fees. No calls where you pay to have someone tell you things you already know.</div>
      </div>
      <div class="are-card is-this reveal">
        <div class="are-tag yes">✓ This</div>
        <div class="are-title">A data-driven audit service</div>
        <div class="are-body">Fixed-scope engagements with clear deliverables. A 15–25 page written report in 7 days. You know exactly what you're getting before you pay anything.</div>
      </div>
      <div class="are-card is-not reveal">
        <div class="are-tag not">✕ Not This</div>
        <div class="are-title">A lead generation platform</div>
        <div class="are-body">We don't sell leads, take referral fees, or have financial relationships with the vendors we mention in our research. No conflicts of interest.</div>
      </div>
      <div class="are-card is-this reveal">
        <div class="are-tag yes">✓ This</div>
        <div class="are-title">A benchmark and intelligence publisher</div>
        <div class="are-body">Free tools, free benchmarks, free research - published every week. The goal is to raise the baseline for the entire industry, not just the companies who pay us.</div>
      </div>
    </div>
  </div>
</div>

<!-- WHO IT'S FOR -->
<div class="wrap">
  <div class="inner">
    <div class="rule-label"><span class="section-tag">Who This Is For</span></div>
    <h2 class="sec-h" style="margin-bottom:10px">Built for <em>operators,</em> not marketers.</h2>
    <p class="sec-p">We write and work for home service business owners - people who run real operations with real trucks, real technicians, and real overhead. Not marketing departments.</p>
    <div class="icp-grid">
      <div class="icp-card reveal">
        <div class="icp-icon">🔧</div>
        <div class="icp-title">HVAC Companies</div>
        <div class="icp-body">Residential and commercial HVAC operators dealing with high seasonality, competitive Google Ads markets, and the shift from repair-focused to replacement-focused revenue. If you're spending $5K+ on ads and don't know your cost per installed unit, this is for you.</div>
      </div>
      <div class="icp-card reveal">
        <div class="icp-icon">🏠</div>
        <div class="icp-title">Roofing Companies</div>
        <div class="icp-body">Retail and storm roofing operators navigating Angi leads, insurance work, and the challenge of building inbound demand in a category dominated by price shoppers. The ones who grow fastest are the ones who stop buying calls and start owning their Google presence.</div>
      </div>
      <div class="icp-card reveal">
        <div class="icp-icon">💧</div>
        <div class="icp-title">Plumbing Companies</div>
        <div class="icp-body">Plumbing operators at the $1M–$5M revenue level trying to reduce dependency on referrals and build a predictable, trackable marketing system. The data shows most plumbers have the strongest close rates of any trade - and the worst lead source tracking.</div>
      </div>
    </div>
    <div class="icp-profile">
      <div class="icp-p-item"><div class="icp-p-label">Annual Revenue</div><div class="icp-p-val">$1M–$5M</div></div>
      <div class="icp-p-item"><div class="icp-p-label">Team Size</div><div class="icp-p-val">5–30 employees</div></div>
      <div class="icp-p-item"><div class="icp-p-label">Monthly Marketing Spend</div><div class="icp-p-val">$3K–$15K/month</div></div>
      <div class="icp-p-item"><div class="icp-p-label">Market</div><div class="icp-p-val">United States</div></div>
      <div class="icp-p-item"><div class="icp-p-label">Main Problem</div><div class="icp-p-val">Can't prove what's working</div></div>
      <div class="icp-p-item"><div class="icp-p-label">Prior History</div><div class="icp-p-val">Burned by agencies before</div></div>
      <div class="icp-p-item"><div class="icp-p-label">Communication Preference</div><div class="icp-p-val">Written, not calls</div></div>
      <div class="icp-p-item"><div class="icp-p-label">What They Want</div><div class="icp-p-val">Data, not pitches</div></div>
    </div>
  </div>
</div>

<!-- BOTTOM CTA -->
<div class="about-cta">
  <div class="about-cta-glow"></div>
  <div class="about-cta-inner">
    <div class="dispatch-label" style="justify-content:center;margin-bottom:20px">See where your revenue is going</div>
    <h2>Start with the free tools - or go straight to an <em>audit.</em></h2>
    <p>The tools take 2 minutes and show you the gaps without any commitment. The audit takes 7 days and shows you the full picture in dollars.</p>
    <div class="about-cta-btns">
      <a href="/apply" class="cta-primary">Get a Revenue Leak Audit ($750)</a>
      <a href="/tools" class="cta-secondary">Try the Free Tools First</a>
    </div>
  </div>
</div>

</Layout>
