---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Built on Tenth - Revenue Intelligence for HVAC, Roofing &amp; Plumbing"
  description="We study how the most profitable home service companies grow - marketing spend, phone conversion, lead sources. Free tools, free research, and full revenue audits starting at $750."
  active=""
>

<style>
/* ════════════════════════════════════════
   TOKENS
════════════════════════════════════════ */
:root {
  --bg:      #090C0B;
  --bg2:     #0E1412;
  --bg3:     #141C18;
  --bg4:     #1A2420;
  --rule:    rgba(226,221,208,0.09);
  --rule2:   rgba(226,221,208,0.16);
  --ink:     #E2DDD0;
  --ink2:    rgba(226,221,208,0.88);
  --ink3:    rgba(226,221,208,0.62);
  --teal:    #00C49A;
  --teal2:   rgba(0,196,154,0.12);
  --teal3:   rgba(0,196,154,0.06);
  --teal4:   rgba(0,196,154,0.28);
  --pos:     #22D37A;
  --neg:     #F04040;
  --serif:   'DM Serif Display', Georgia, serif;
  --mono:    'IBM Plex Mono', 'Courier New', monospace;
  --sans:    'IBM Plex Sans', system-ui, sans-serif;
  --ease:    cubic-bezier(0.22, 1, 0.36, 1);
  --ease2:   cubic-bezier(0.16, 1, 0.3, 1);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--ink);
  font-family: var(--sans);
  font-size: 16px;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* ════════════════════════════════════════
   GRAIN OVERLAY - adds texture, kills "screen" flatness
════════════════════════════════════════ */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 9999;
  pointer-events: none;
  opacity: 0.028;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  background-size: 160px;
}

/* ════════════════════════════════════════
   NAV
════════════════════════════════════════ */
#nav {
  position: fixed;
  inset: 0 0 auto;
  z-index: 1000;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 48px;
  transition: background 0.4s var(--ease), border-color 0.4s;
  border-bottom: 1px solid transparent;
}
#nav.scrolled {
  background: rgba(9,12,11,0.92);
  backdrop-filter: blur(24px) saturate(1.6);
  -webkit-backdrop-filter: blur(24px) saturate(1.6);
  border-bottom-color: var(--rule);
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}
.nav-logo-mark {
  width: 28px; height: 28px;
  border: 1.5px solid var(--teal4);
  border-radius: 4px;
  display: flex; align-items: center; justify-content: center;
  position: relative;
}
.nav-logo-mark::after {
  content: '';
  width: 8px; height: 8px;
  border-radius: 2px;
  background: var(--teal);
}
.nav-logo-text {
  font-family: var(--mono);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink);
}
.nav-links {
  display: flex;
  align-items: center;
  gap: 38px;
  list-style: none;
}
.nav-links a {
  font-family: var(--sans);
  font-size: 13.5px;
  font-weight: 400;
  letter-spacing: 0.01em;
  color: var(--ink3);
  text-decoration: none;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--ink); }
.nav-right { display: flex; gap: 10px; align-items: center; }
.nav-btn-ghost {
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 400;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink3);
  background: transparent;
  border: 1px solid var(--rule2);
  border-radius: 4px;
  padding: 8px 16px;
  text-decoration: none;
  transition: all 0.2s;
}
.nav-btn-ghost:hover { color: var(--ink); border-color: var(--rule2); background: rgba(226,221,208,0.04); }
.nav-btn-teal {
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--bg);
  background: var(--teal);
  border: 1px solid var(--teal);
  border-radius: 4px;
  padding: 8px 18px;
  text-decoration: none;
  transition: all 0.2s;
}
.nav-btn-teal:hover { background: #00DFB0; transform: translateY(-1px); }

/* ════════════════════════════════════════
   HERO - Asymmetric split layout
════════════════════════════════════════ */
.hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 480px;
  gap: 0;
  align-items: center;
  padding: 100px 48px 80px;
  position: relative;
  overflow: hidden;
}

/* Faint construction photo behind left column */
.hero-photo {
  position: absolute;
  inset: 0;
  background-image: url('https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=1600&q=60');
  background-size: cover;
  background-position: center 40%;
  opacity: 0.06;
  filter: grayscale(60%);
}
/* Directional gradient: photo only bleeds left side */
.hero-fog {
  position: absolute;
  inset: 0;
  background: linear-gradient(to right, rgba(9,12,11,0.2) 0%, rgba(9,12,11,0.7) 50%, var(--bg) 72%);
}
/* Subtle dot grid pattern */
.hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(rgba(226,221,208,0.045) 1px, transparent 1px);
  background-size: 32px 32px;
  -webkit-mask-image: radial-gradient(ellipse 75% 85% at 30% 50%, black 10%, transparent 75%);
  mask-image: radial-gradient(ellipse 75% 85% at 30% 50%, black 10%, transparent 75%);
}
/* Top teal glow */
.hero-glow {
  position: absolute;
  top: -200px; left: -100px;
  width: 700px; height: 700px;
  background: radial-gradient(ellipse at center, rgba(0,196,154,0.06) 0%, transparent 65%);
  pointer-events: none;
}

.hero-left {
  position: relative;
  z-index: 1;
  padding-right: 48px;
  text-align: left;
}

/* Monospace label above headline */
.dispatch-label {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--mono);
  font-size: 10.5px;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: 28px;
  animation: fadeUp 0.8s var(--ease) both;
}
.dispatch-label::before {
  content: '';
  width: 20px; height: 1.5px;
  background: var(--teal);
  flex-shrink: 0;
}

.hero-h {
  font-family: var(--serif);
  font-size: clamp(40px, 5.2vw, 68px);
  font-weight: 400;
  line-height: 1.07;
  letter-spacing: -0.01em;
  margin-bottom: 28px;
  text-align: left;
  animation: fadeUp 0.8s 0.08s var(--ease) both;
}
/* "Leaking Revenue" in italic serif - the magazine-style editorial moment */
.hero-h em {
  font-style: italic;
  color: var(--teal);
}
/* no indent - clean left alignment */
.hero-h .indent { display: block; }

.hero-body {
  font-family: var(--sans);
  font-size: 17px;
  color: var(--ink2);
  line-height: 1.74;
  max-width: 520px;
  font-weight: 300;
  margin-bottom: 40px;
  text-align: left;
  animation: fadeUp 0.8s 0.16s var(--ease) both;
}

.hero-ctas {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  margin-bottom: 56px;
  animation: fadeUp 0.8s 0.24s var(--ease) both;
}
.cta-primary,
.cta-secondary,
.cta-ghost,
.cta-filled,
.svc-btn,
.ac-cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  border-radius: 4px;
  min-height: 50px;
  padding: 0 22px;
  line-height: 1.25;
  text-align: center;
  transition: all 0.2s var(--ease);
}
.cta-primary {
  color: var(--bg);
  background: var(--teal);
  border: 1.5px solid var(--teal);
}
.cta-primary:hover { background: #00DFB0; transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,196,154,0.25); }
.cta-secondary {
  color: var(--ink2);
  background: transparent;
  border: 1.5px solid var(--rule2);
}
.cta-secondary:hover { color: var(--ink); border-color: rgba(226,221,208,0.3); background: rgba(226,221,208,0.04); transform: translateY(-2px); }

/* Stat row below CTAs */
.hero-stats {
  display: flex;
  gap: 0;
  border-top: 1px solid var(--rule);
  padding-top: 32px;
  animation: fadeUp 0.8s 0.32s var(--ease) both;
}
.hero-stat {
  padding-right: 36px;
  margin-right: 36px;
  border-right: 1px solid var(--rule);
}
.hero-stat:last-child { border-right: none; margin-right: 0; }
.hs-n {
  font-family: var(--mono);
  font-size: 26px;
  font-weight: 600;
  letter-spacing: -0.02em;
  color: var(--ink);
  line-height: 1;
  margin-bottom: 5px;
}
.hs-n.teal { color: var(--teal); }
.hs-l { font-size: 12px; color: var(--ink3); line-height: 1.45; font-weight: 300; }

/* ═══ AUDIT SNAPSHOT CARD (hero right side) ═══ */
.hero-right {
  position: relative;
  z-index: 1;
  animation: fadeUp 0.8s 0.18s var(--ease) both;
}
.audit-card {
  background: var(--bg2);
  border: 1px solid var(--rule2);
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 24px 64px rgba(0,0,0,0.45), 0 0 60px rgba(0,196,154,0.05);
}
/* Clean header bar - no mac dots, just a label */
.ac-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg3);
  border-bottom: 1px solid var(--rule);
  padding: 14px 20px;
}
.ac-header-label {
  font-family: var(--sans);
  font-size: 12px;
  font-weight: 600;
  color: var(--ink2);
  letter-spacing: 0.01em;
}
.ac-header-badge {
  font-family: var(--mono);
  font-size: 9.5px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--neg);
  background: rgba(240,64,64,0.1);
  border: 1px solid rgba(240,64,64,0.22);
  padding: 3px 9px;
  border-radius: 3px;
}
.ac-body { padding: 20px 20px 24px; }

/* Company row */
.ac-company {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding-bottom: 14px;
  margin-bottom: 16px;
  border-bottom: 1px solid var(--rule);
}
.ac-co-name {
  font-family: var(--sans);
  font-size: 14px;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 2px;
}
.ac-co-rev {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--ink3);
  letter-spacing: 0.04em;
}
.ac-co-status {
  text-align: right;
}
.ac-co-status-label {
  font-size: 10.5px;
  color: var(--ink3);
  margin-bottom: 3px;
  font-family: var(--mono);
  letter-spacing: 0.06em;
  text-transform: uppercase;
}
.ac-co-status-val {
  font-family: var(--mono);
  font-size: 12px;
  font-weight: 600;
  color: var(--neg);
}

/* Individual findings */
.ac-findings { display: flex; flex-direction: column; gap: 12px; margin-bottom: 18px; }
.ac-finding {
  display: grid;
  grid-template-columns: 62px 1fr;
  gap: 10px;
  align-items: start;
}
.ac-badge {
  font-family: var(--sans);
  font-size: 9.5px;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  padding: 4px 0;
  border-radius: 3px;
  text-align: center;
  white-space: nowrap;
}
.ac-badge.bad  { background: rgba(240,64,64,0.12);  color: #F07070; border: 1px solid rgba(240,64,64,0.22); }
.ac-badge.warn { background: rgba(212,169,64,0.12); color: #C9A035; border: 1px solid rgba(212,169,64,0.22); }
.ac-badge.ok   { background: rgba(34,211,122,0.1);  color: var(--pos);  border: 1px solid rgba(34,211,122,0.2); }

.ac-finding-body {}
.ac-finding-title { font-family: var(--sans); font-size: 12.5px; font-weight: 500; color: var(--ink); margin-bottom: 3px; line-height: 1.35; }
.ac-finding-data {
  font-family: var(--mono);
  font-size: 10.5px;
  color: var(--ink3);
  letter-spacing: 0.02em;
}
.ac-bar-wrap { height: 2px; background: rgba(226,221,208,0.08); border-radius: 1px; margin-top: 5px; overflow: hidden; }
.ac-bar-fill { height: 100%; border-radius: 1px; width: 0; transition: width 1.2s var(--ease2) 0.6s; }

/* Total row */
.ac-total {
  border-top: 1px solid var(--rule);
  padding-top: 16px;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}
.ac-total-label {
  font-family: var(--sans);
  font-size: 11.5px;
  font-weight: 500;
  color: var(--ink2);
  margin-bottom: 2px;
}
.ac-total-sub { font-size: 11px; color: var(--ink3); }
.ac-total-n {
  font-family: var(--mono);
  font-size: 34px;
  font-weight: 600;
  color: var(--teal);
  letter-spacing: -0.03em;
  line-height: 1;
}
.ac-cta {
  margin-top: 16px;
  color: var(--bg);
  background: var(--teal);
  border: 1px solid var(--teal);
}
.ac-cta:hover { background: #00DFB0; }

/* blinking cursor - keep but subtler */
.cursor {
  display: inline-block;
  width: 2px; height: 12px;
  background: var(--teal);
  margin-left: 3px;
  vertical-align: middle;
  animation: cur 1.1s step-end infinite;
}
@keyframes cur { 0%,100%{opacity:1} 50%{opacity:0} }

/* ════════════════════════════════════════
   INTELLIGENCE STRIP - 4 monospace stats
   Replace boring ticker: editorial data row
════════════════════════════════════════ */
.intel {
  border-top: 1px solid var(--rule);
  border-bottom: 1px solid var(--rule);
  background: var(--bg2);
}
.intel-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
}
.intel-card {
  padding: 36px 36px 32px;
  border-right: 1px solid var(--rule);
  position: relative;
  overflow: hidden;
  transition: background 0.35s var(--ease);
  cursor: default;
}
.intel-card:last-child { border-right: none; }
.intel-card:hover { background: var(--bg3); }
/* Left accent bar reveals on hover */
.intel-card::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 2px;
  background: var(--teal);
  transform: scaleY(0);
  transform-origin: bottom;
  transition: transform 0.4s var(--ease2);
}
.intel-card:hover::before { transform: scaleY(1); }
.intel-eyebrow {
  font-family: var(--mono);
  font-size: 9.5px;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink3);
  margin-bottom: 10px;
}
.intel-n {
  font-family: var(--mono);
  font-size: 54px;
  font-weight: 600;
  letter-spacing: -0.04em;
  line-height: 1;
  color: var(--ink);
  margin-bottom: 10px;
  transition: color 0.3s;
}
.intel-card:hover .intel-n { color: var(--teal); }
.intel-desc {
  font-family: var(--sans);
  font-size: 13px;
  color: var(--ink2);
  line-height: 1.58;
  font-weight: 300;
  max-width: 220px;
  margin-bottom: 16px;
}
.intel-bar-track { height: 2px; background: rgba(226,221,208,0.07); border-radius: 1px; overflow: hidden; }
.intel-bar-fill { height: 100%; width: 0; border-radius: 1px; background: var(--teal); transition: width 1.4s var(--ease2); }
.intel-src {
  font-family: var(--mono);
  font-size: 9.5px;
  letter-spacing: 0.06em;
  color: var(--ink3);
  margin-top: 8px;
  font-weight: 300;
}

/* ════════════════════════════════════════
   SHARED UTILITIES
════════════════════════════════════════ */
.wrap { padding: 96px 48px; }
.wrap.alt { background: var(--bg2); }
.inner { max-width: 1200px; margin: 0 auto; }

/* Horizontal rule section divider */
.rule-label {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 56px;
}
.rule-label::before {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--rule);
  max-width: 60px;
}
.rule-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--rule);
}
.section-tag {
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--teal);
}
.sec-h {
  font-family: var(--serif);
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: -0.01em;
  margin-bottom: 16px;
  text-align: left;
}
.sec-h em { font-style: italic; color: var(--teal); }
.sec-p {
  font-size: 16.5px;
  color: var(--ink2);
  line-height: 1.74;
  max-width: 520px;
  font-weight: 300;
  text-align: left;
}

/* ════════════════════════════════════════
   PROBLEM SECTION
════════════════════════════════════════ */
.prob-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
/* Photo collage */
.collage { position: relative; height: 480px; }
.c-main {
  position: absolute;
  top: 0; left: 0;
  width: 66%; height: 70%;
  border-radius: 4px;
  overflow: hidden;
  border: 1px solid var(--rule2);
}
.c-main img, .c-sec img {
  width: 100%; height: 100%;
  object-fit: cover;
  filter: grayscale(20%) brightness(0.8);
  transition: transform 0.6s var(--ease), filter 0.4s;
}
/* Subtle teal tint overlay - unifies all imagery */
.c-main::before, .c-sec::before {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(0,196,154,0.06);
  z-index: 1;
  pointer-events: none;
}
.c-main:hover img, .c-sec:hover img { transform: scale(1.04); filter: grayscale(5%) brightness(0.9); }
.c-sec {
  position: absolute;
  bottom: 0; right: 0;
  width: 58%; height: 55%;
  border-radius: 4px;
  overflow: hidden;
  border: 1px solid var(--rule2);
}
/* Stat overlay card */
.stat-float {
  position: absolute;
  bottom: 32%; left: 42%;
  transform: translate(-50%, 50%);
  background: rgba(9,12,11,0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(0,196,154,0.32);
  border-radius: 4px;
  padding: 14px 18px;
  z-index: 10;
}
.sf-n {
  font-family: var(--mono);
  font-size: 36px;
  font-weight: 600;
  color: var(--teal);
  line-height: 1;
  letter-spacing: -0.03em;
}
.sf-l { font-size: 11px; color: var(--ink2); margin-top: 4px; line-height: 1.45; max-width: 148px; font-family: var(--sans); font-weight: 300; }
/* Fallback */
.img-fb { display: none; position: absolute; inset: 0; background: var(--bg3); align-items: center; justify-content: center; }
img[data-failed] { display: none; }
img[data-failed] ~ .img-fb { display: flex; }
/* Always show a subtle gradient background on image containers so they never look empty */
.step-img, .tool-img, .svc-img {
  background: linear-gradient(135deg, var(--bg3) 0%, var(--bg4) 100%);
}
.step-img::before { content: ''; position: absolute; inset: 0; background: rgba(0,196,154,0.04); z-index: 1; pointer-events: none; }

/* Pain points */
.pain-list { display: flex; flex-direction: column; gap: 12px; margin-top: 28px; }
.pain {
  display: flex;
  gap: 16px;
  align-items: flex-start;
  background: var(--bg3);
  border: 1px solid var(--rule);
  border-radius: 4px;
  padding: 16px 18px;
  transition: border-color 0.25s, transform 0.25s var(--ease);
}
.pain:hover { border-color: rgba(0,196,154,0.2); transform: translateX(4px); }
.pain-ic {
  width: 28px; height: 28px;
  border-radius: 3px;
  display: flex; align-items: center; justify-content: center;
  font-size: 13px;
  flex-shrink: 0;
  background: rgba(240,64,64,0.1);
}
.pain h4 {
  font-family: var(--sans);
  font-size: 13.5px;
  font-weight: 600;
  margin-bottom: 3px;
