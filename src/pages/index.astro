  grid-template-columns: auto 1fr;
  gap: 32px 52px;
  align-items: start;
}
.audit-n {
  font-family: var(--mono);
  font-size: 56px;
  font-weight: 600;
  color: var(--teal);
  letter-spacing: -0.04em;
  line-height: 1;
}
.audit-sub {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--ink3);
  margin-top: 4px;
  letter-spacing: 0.04em;
}
.audit-header {
  font-family: var(--mono);
  font-size: 9.5px;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink3);
  margin-bottom: 18px;
}
.audit-rows { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 36px; }
.ar { display: flex; align-items: flex-start; gap: 9px; font-size: 13px; color: var(--ink2); line-height: 1.5; font-weight: 300; }
.ar-ic { flex-shrink: 0; font-size: 12px; margin-top: 2px; font-family: var(--mono); }
.ar-ic.bad { color: var(--neg); }
.ar-ic.ok  { color: var(--pos); }

/* Revenue leak example */
.rev-example { background: var(--bg3); border: 1px solid var(--rule2); border-radius: 6px; padding: 28px 32px; margin-top: 16px; text-align: center; }
.re-label { font-family: var(--mono); font-size: 9.5px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink3); margin-bottom: 20px; text-align: center; }
.re-grid { display: flex; align-items: center; justify-content: center; gap: 0; flex-wrap: wrap; row-gap: 14px; margin-bottom: 18px; }
.re-item { text-align: center; padding: 0 18px; }
.re-n { font-family: var(--mono); font-size: 28px; font-weight: 600; letter-spacing: -0.03em; color: var(--ink); line-height: 1; margin-bottom: 4px; }
.re-n.teal { color: var(--teal); }
.re-l { font-size: 11px; color: var(--ink3); font-weight: 300; }
.re-sep { font-family: var(--mono); font-size: 20px; color: var(--ink3); padding: 0 4px; align-self: center; }
.re-result { background: rgba(240,64,64,0.07); border: 1px solid rgba(240,64,64,0.2); border-radius: 4px; padding: 14px 24px; margin-left: 12px; text-align: left; }
.re-result-n { font-family: var(--mono); font-size: 32px; font-weight: 700; color: var(--neg); letter-spacing: -0.03em; line-height: 1; margin-bottom: 4px; }
.re-result-l { font-size: 11px; color: var(--ink2); font-weight: 300; line-height: 1.45; }
.cta-ghost,
.svc-btn.ghost {
  color: var(--ink2);
  background: transparent;
  border: 1px solid var(--rule2);
}
.cta-ghost:hover,
.svc-btn.ghost:hover {
  color: var(--ink);
  border-color: rgba(226,221,208,0.3);
  background: rgba(226,221,208,0.04);
}
.cta-filled,
.svc-btn.filled {
  color: var(--bg);
  background: var(--teal);
  border: 1px solid var(--teal);
}
.cta-filled:hover,
.svc-btn.filled:hover { background: #00DFB0; }
.re-cta { display: flex; gap: 10px; align-items: center; justify-content: center; border-top: 1px solid var(--rule); padding-top: 16px; }
.re-cta a { flex: 1 1 0; max-width: 320px; }

/* Agency comparison table */
.agency-compare { margin-top: 48px; }

/* Responsive grid comparison - no table, no horizontal scroll */
.ac-grid {
  border: 1px solid var(--rule);
  border-radius: 6px;
  overflow: hidden;
  margin-top: 20px;
}
.ac-row {
  display: grid;
  grid-template-columns: 1.2fr 1.3fr 1.3fr;
  border-bottom: 1px solid var(--rule);
}
.ac-row-last { border-bottom: none; }
.ac-header-row { background: var(--bg3); }
.ac-col-label,
.ac-col-agency,
.ac-col-us {
  padding: 13px 18px;
  font-size: 13px;
  line-height: 1.55;
  font-weight: 300;
  color: var(--ink2);
}
.ac-header-row .ac-col-label,
.ac-header-row .ac-col-agency,
.ac-header-row .ac-col-us {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 12px 18px;
}
.ac-col-label { background: var(--bg2); color: var(--ink3); font-family: var(--mono); font-size: 11px; letter-spacing: 0.04em; }
.ac-header-row .ac-col-label { color: var(--ink3); background: var(--bg3); }
.ac-col-agency { background: rgba(240,64,64,0.03); border-left: 1px solid var(--rule); }
.ac-header-row .ac-col-agency { color: var(--neg); background: rgba(240,64,64,0.06); }
.ac-col-us { background: rgba(0,196,154,0.03); border-left: 1px solid var(--rule); color: var(--ink); }
.ac-header-row .ac-col-us { color: var(--teal); background: rgba(0,196,154,0.06); }

/* Mobile: stack into 2-col label/value pairs */
@media (max-width: 640px) {
  .ac-header-row { display: none; }
  .ac-row {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 0;
  }
  .ac-col-label {
    grid-column: 1 / -1;
    background: var(--bg3);
    font-family: var(--mono); font-size: 9px; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--ink3); padding: 10px 16px;
    border-bottom: 1px solid var(--rule);
  }
  .ac-col-agency { border-left: none; padding: 12px 16px; }
  .ac-col-us { border-left: 1px solid var(--rule); padding: 12px 16px; }
  .ac-col-agency::before { content: 'Agency'; display: block; font-family: var(--mono); font-size: 8px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--neg); margin-bottom: 5px; }
  .ac-col-us::before { content: 'Built on Tenth'; display: block; font-family: var(--mono); font-size: 8px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--teal); margin-bottom: 5px; }
}

/* Tools funnel section */
.tools-funnel-intro { margin-bottom: 40px; }
.tools-funnel-steps { display: flex; flex-direction: column; gap: 12px; margin-bottom: 36px; }
.tfs { display: grid; grid-template-columns: 44px 1fr auto; gap: 18px; align-items: center; background: var(--bg3); border: 1px solid var(--rule); border-radius: 5px; padding: 16px 20px; text-decoration: none; color: inherit; transition: border-color 0.2s, transform 0.2s var(--ease); }
.tfs:hover { border-color: rgba(0,196,154,0.3); transform: translateX(4px); }
.tfs-num { font-family: var(--mono); font-size: 20px; font-weight: 600; color: var(--teal); letter-spacing: -0.02em; line-height: 1; }
.tfs-body h4 { font-family: var(--sans); font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 3px; }
.tfs-body p { font-size: 12.5px; color: var(--ink2); font-weight: 300; line-height: 1.55; }
.tfs-arrow { font-family: var(--mono); font-size: 13px; color: var(--teal); transition: transform 0.2s; }
.tfs:hover .tfs-arrow { transform: translateX(4px); }
.tools-bridge { background: var(--bg3); border: 1px solid var(--rule2); border-radius: 5px; padding: 16px 20px; font-size: 13.5px; color: var(--ink2); line-height: 1.65; font-weight: 300; }
.tools-bridge strong { color: var(--ink); font-weight: 500; }

/* Services v2.5 */
.svc-start-label { font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 8px; }
.svc-start-label.step1 { color: var(--teal); }
.svc-start-label.step2 { color: #C9A035; }
.svc-start-label.step3 { color: var(--ink3); }
.svc-self-select { font-size: 12px; color: var(--ink3); font-weight: 300; margin-top: 10px; font-style: italic; }
.steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
  border-radius: 4px;
  overflow: hidden;
  margin-top: 48px;
}
.step {
  background: var(--bg2);
  overflow: hidden;
  transition: background 0.3s;
}
.step:hover { background: var(--bg3); }
.step-img {
  width: 100%;
  height: 200px;
  overflow: hidden;
  position: relative;
}
.step-img img {
  width: 100%; height: 100%;
  object-fit: cover;
  filter: grayscale(25%) brightness(0.75);
  transition: transform 0.6s var(--ease), filter 0.4s;
}
/* Teal tint on all step images */
.step-img::before {
  content: '';
  position: absolute; inset: 0; z-index: 1;
  background: rgba(0,196,154,0.07);
  pointer-events: none;
}
.step:hover .step-img img { transform: scale(1.05); filter: grayscale(5%) brightness(0.85); }
.step-img::after {
  content: '';
  position: absolute; inset: 0; z-index: 2;
  background: linear-gradient(to bottom, transparent 40%, rgba(14,20,18,0.85) 100%);
  pointer-events: none;
}
.step-body { padding: 26px 28px 32px; }
.step-tag {
  font-family: var(--mono);
  font-size: 9.5px;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.step-tag::before { content: ''; width: 14px; height: 1.5px; background: var(--teal); flex-shrink: 0; }
.step h3 {
  font-family: var(--serif);
  font-size: 22px;
  font-weight: 400;
  line-height: 1.22;
  margin-bottom: 12px;
}
.step p { font-size: 13.5px; color: var(--ink2); line-height: 1.68; font-weight: 300; }

/* ════════════════════════════════════════
   FREE TOOLS
════════════════════════════════════════ */
.tools-header {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: end;
  margin-bottom: 48px;
}
.tools-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
  border-radius: 4px;
  overflow: hidden;
}
.tool {
  background: var(--bg);
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: background 0.3s;
}
.tool:hover { background: var(--bg3); }
.tool-img {
  width: 100%; height: 140px;
  overflow: hidden;
  position: relative;
}
.tool-img img {
  width: 100%; height: 100%;
  object-fit: cover;
  filter: grayscale(25%) brightness(0.68);
  transition: transform 0.6s var(--ease), filter 0.4s;
}
/* Teal tint on all tool images */
.tool-img::before {
  content: '';
  position: absolute; inset: 0; z-index: 1;
  background: rgba(0,196,154,0.08);
