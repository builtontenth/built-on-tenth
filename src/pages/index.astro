}
.tool-body { padding: 18px 20px 22px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
/* Badge inside card body */
.tool-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--pos);
  background: rgba(34,211,122,0.09);
  border: 1px solid rgba(34,211,122,0.22);
