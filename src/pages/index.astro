.ft-btm { max-width: 1200px; margin: 36px auto 0; padding: 18px 0 36px; border-top: 1px solid var(--rule); display: flex; justify-content: space-between; align-items: center; }
.ft-btm p, .ft-btm a { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.05em; color: var(--ink3); text-decoration: none; font-weight: 300; transition: color 0.2s; }
.ft-btm a:hover { color: var(--ink2); }

/* ════════════════════════════════════════
   ANIMATIONS
════════════════════════════════════════ */
@keyframes fadeUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
/* Content is always visible - JS progressively enhances with entrance animation */
.reveal { opacity: 1; transform: translateY(0); transition: opacity 0.7s var(--ease), transform 0.7s var(--ease); }
.reveal.will-animate { opacity: 0; transform: translateY(24px); }
.reveal.will-animate.on { opacity: 1; transform: translateY(0); }

/* ── TOOLS BRIDGE BAR ── */
.tools-bridge-bar {
  margin-top: 32px;
  display: flex; align-items: center; justify-content: space-between; gap: 24px;
  padding: 20px 24px;
  background: var(--bg3); border: 1px solid var(--rule2); border-radius: 4px;
  flex-wrap: wrap;
}
.tools-bridge-bar p {
  font-size: 14px; color: var(--ink2); font-weight: 300; line-height: 1.6; flex: 1;
}

/* ── SERVICES BRIDGE BAR ── */
.svc-bridge {
  background: var(--bg2);
  border-top: 1px solid var(--rule);
  border-bottom: 1px solid var(--rule);
  padding: 28px 48px;
}
.svc-bridge-inner {
  max-width: 1200px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between; gap: 24px;
  flex-wrap: wrap;
}
.svc-bridge-text {
  font-family: var(--mono); font-size: 12px; color: var(--ink2); letter-spacing: 0.04em;
}
.svc-bridge-btns { display: flex; gap: 10px; flex-wrap: wrap; }

/* ════════════════════════════════════════
   RESPONSIVE - COMPREHENSIVE MOBILE FIX
════════════════════════════════════════ */

/* 1100px: collapse hero to single column */
@media (max-width: 1100px) {
  .hero { grid-template-columns: 1fr; padding-top: 96px; }
  .hero-left { padding-right: 0; }
  .hero-right { display: none; }
}

/* 960px: main mobile breakpoint */
@media (max-width: 960px) {
  /* ── HERO ── */
  .hero { padding: 84px 20px 56px; min-height: auto; }
  .hero-h { font-size: clamp(30px, 8vw, 48px); line-height: 1.1; }
  .hero-body { font-size: 15px; }
  .hero-ctas { flex-direction: column; gap: 10px; align-items: stretch; }
