<!-- ══════════ FOOTER ══════════ -->

<script>
  /* Nav scroll handled by Layout */

  /* Intel strip bar animations */
  const intelObs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const bar = entry.target.querySelector('.intel-bar-fill');
      const pct = entry.target.dataset.bar || '50';
      setTimeout(() => { if (bar) bar.style.width = pct + '%'; }, 250);
      intelObs.unobserve(entry.target);
    });
  }, { threshold: 0.3 });
  document.querySelectorAll('.intel-card').forEach(c => intelObs.observe(c));

  /* Audit card bar animations */
  const acObs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      entry.target.querySelectorAll('.ac-bar-fill').forEach((bar, i) => {
        const w = bar.dataset.w || '0';
        setTimeout(() => { bar.style.width = w + '%'; }, 300 + i * 140);
      });
      acObs.unobserve(entry.target);
    });
  }, { threshold: 0.2 });
  document.querySelectorAll('.audit-card').forEach(t => acObs.observe(t));

  /* Newsletter submit - calls Brevo API */
  document.getElementById('nl-btn').addEventListener('click', async function () {
    const inp = document.querySelector('.nl-in');
    const btn = this;
    if (!inp.value.includes('@')) {
      inp.style.borderColor = 'rgba(240,64,64,0.55)';
      inp.focus();
      return;
    }
    btn.textContent = 'Subscribing...';
    btn.disabled = true;
    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: inp.value.trim(), source: 'homepage' }),
      });
      const data = await res.json();
      if (data.success) {
        btn.textContent = "You're in \u2713";
        btn.style.background = '#22D37A';
        btn.style.borderColor = '#22D37A';
        inp.disabled = true;
      } else {
        btn.textContent = 'Try again';
        btn.disabled = false;
      }
    } catch {
      btn.textContent = 'Try again';
      btn.disabled = false;
    }
  });
</script>

