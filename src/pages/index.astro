}
.tool.nl { background: rgba(0,196,154,0.03); border-color: rgba(0,196,154,0.18); }
.tool.nl:hover { border-color: rgba(0,196,154,0.42); }
.tool h3 {
  font-family: var(--serif);
  font-size: 16px;
  font-weight: 400;
  line-height: 1.3;
}
.tool p { font-size: 12.5px; color: var(--ink2); line-height: 1.65; flex: 1; font-weight: 300; }
.tool-cta {
  font-family: var(--mono);
  font-size: 10.5px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--teal);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 46px;
  width: fit-content;
  padding: 0 18px;
  border: 1px solid rgba(0,196,154,0.32);
  background: rgba(0,196,154,0.06);
  border-radius: 4px;
  transition: background 0.2s, border-color 0.2s, transform 0.2s, color 0.2s;
}
.tool:hover .tool-cta {
  background: rgba(0,196,154,0.12);
  border-color: rgba(0,196,154,0.48);
  color: var(--ink);
  transform: translateY(-1px);
}

/* ════════════════════════════════════════
   SERVICES
════════════════════════════════════════ */
.svcs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-top: 48px;
}
.svc {
  background: var(--bg2);
  border: 1px solid var(--rule);
  border-radius: 4px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: border-color 0.25s var(--ease), transform 0.25s var(--ease);
}
.svc:hover { border-color: var(--rule2); transform: translateY(-3px); }
.svc.ft { border-color: rgba(0,196,154,0.28); }
.svc.ft:hover { border-color: rgba(0,196,154,0.52); }

.svc-img { width: 100%; height: 160px; overflow: hidden; position: relative; }
.svc-img img {
  width: 100%; height: 100%;
  object-fit: cover;
  filter: grayscale(30%) brightness(0.65);
  transition: transform 0.6s var(--ease);
}
.svc-img::before {
  content: '';
  position: absolute; inset: 0; z-index: 1;
  background: rgba(0,196,154,0.07);
  pointer-events: none;
}
.svc:hover .svc-img img { transform: scale(1.05); }
.svc-img::after {
  content: '';
  position: absolute; inset: 0; z-index: 2;
  background: linear-gradient(to bottom, transparent 20%, rgba(9,12,11,0.82) 100%);
  pointer-events: none;
}
.svc-body { padding: 26px 26px 26px; display: flex; flex-direction: column; flex: 1; }
/* FIXED tier labels - visible now */
.svc-tier {
  font-family: var(--mono);
  font-size: 9.5px;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink3);
  margin-bottom: 8px;
}
.svc-tier.ft { color: var(--teal); }
.svc-name {
  font-family: var(--serif);
  font-size: 20px;
  font-weight: 400;
  margin-bottom: 4px;
}
.svc-price {
  font-family: var(--mono);
  font-size: 40px;
  font-weight: 600;
  letter-spacing: -0.04em;
  line-height: 1;
  margin: 12px 0 10px;
  color: var(--ink);
}
.svc-desc { font-size: 13px; color: var(--ink2); line-height: 1.65; margin-bottom: 20px; font-weight: 300; }
.svc-div { height: 1px; background: var(--rule); margin-bottom: 18px; }
.svc-ul { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 22px; flex: 1; }
.svc-ul li { display: flex; align-items: flex-start; gap: 10px; font-size: 12.5px; color: var(--ink2); line-height: 1.55; font-weight: 300; }
.svc-ul li::before {
  content: '';
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--teal);
  margin-top: 7px;
  flex-shrink: 0;
}
.svc-btn { width: 100%; }

/* ════════════════════════════════════════
   NEWSLETTER SECTION
════════════════════════════════════════ */
.nl-section { padding: 112px 48px; text-align: center; position: relative; overflow: hidden; }
/* Faint newsletter photo behind content */
.nl-photo { position: absolute; inset: 0; background-image: url('https://images.unsplash.com/photo-1512314889357-e157c22f938d?w=1400&q=55'); background-size: cover; background-position: center; opacity: 0.05; filter: grayscale(50%); }
.nl-glow  { position: absolute; inset: 0; background: radial-gradient(ellipse 65% 65% at 50% 50%, rgba(0,196,154,0.07) 0%, transparent 65%); }
.nl-inner { position: relative; z-index: 1; max-width: 540px; margin: 0 auto; }
.nl-h {
  font-family: var(--serif);
  font-size: clamp(36px, 5vw, 58px);
  font-weight: 400;
  line-height: 1.06;
  letter-spacing: -0.01em;
  margin-bottom: 18px;
}
.nl-h em { font-style: italic; color: var(--teal); }
.nl-sub { font-size: 16px; color: var(--ink2); line-height: 1.74; margin-bottom: 36px; font-weight: 300; }
.nl-form { display: flex; gap: 10px; max-width: 420px; margin: 0 auto 14px; }
.nl-in {
  flex: 1;
  background: var(--bg2);
  border: 1px solid var(--rule2);
  border-radius: 4px;
  padding: 13px 18px;
  font-family: var(--sans);
  font-size: 14px;
  color: var(--ink);
