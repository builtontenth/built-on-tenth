---
interface Props {
  src: string;
  alt: string;
  widths?: number[];
  sizes?: string;
  loading?: 'lazy' | 'eager';
  priority?: boolean;
  class?: string;
  style?: string;
  fit?: 'cover' | 'contain' | 'fill' | 'inside' | 'outside' | 'none' | 'scale-down';
  position?: string;
  formats?: ('avif' | 'webp' | 'png' | 'jpg' | 'jpeg')[];
}

const {
  src,
  alt,
  sizes,
  loading = 'lazy',
  priority = false,
  class: className,
  style,
  fit = 'cover',
  position = 'center',
} = Astro.props;

const isPublicLocal = src.startsWith('/images/') || src.startsWith('/tanvir');
const isRemote = /^https?:\/\//.test(src);

if (!isPublicLocal && !isRemote) {
  throw new Error(`ResponsiveImage only supports public local or remote assets: ${src}`);
}

const inlineStyle = `${style ? `${style};` : ''}object-fit:${fit};object-position:${position};`;
---
<img
  src={src}
  alt={alt}
  sizes={sizes}
  loading={priority ? 'eager' : loading}
  decoding="async"
  fetchpriority={priority ? 'high' : 'auto'}
  class={className}
  style={inlineStyle}
/>
