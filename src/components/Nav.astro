---
const { active = '' } = Astro.props;
---
<nav class="site-nav" id="nav">
  <div class="site-nav__inner">
    <div class="site-nav__left">
      <a href="/" class="site-nav__brand" aria-label="Built on Tenth home">
        <img src="/logo.svg" alt="" class="site-nav__mark-image" aria-hidden="true" />
        <span class="site-nav__brand-copy">
          <span class="site-nav__name">Built on Tenth</span>
        </span>
      </a>

      <ul class="site-nav__links" aria-label="Primary">
        <li><a href="/insights" class={active === 'insights' ? 'active' : ''}>HVAC Market Insights</a></li>
        <li><a href="/tools" class={active === 'tools' ? 'active' : ''}>HVAC Calculators</a></li>
        <li><a href="/report" class={active === 'report' ? 'active' : ''}>Local Market Report</a></li>
        <li><a href="/about" class={active === 'about' ? 'active' : ''}>Why Built on Tenth</a></li>
      </ul>
    </div>

    <div class="site-nav__actions">
      <a href="/report" class="site-nav__btn btn btn--primary">Request your report</a>
      <button class="site-nav__menu" id="nav-menu-btn" aria-label="Open navigation menu">Menu</button>
    </div>
  </div>
</nav>

<div class="site-nav__overlay" id="mobile-overlay"></div>

<div class="site-nav__sheet" id="mobile-sheet">
  <div class="site-nav__handle"></div>
  <nav class="site-nav__sheet-nav" aria-label="Mobile">
    <a href="/" class="site-nav__sheet-link">Home</a>
    <a href="/insights" class="site-nav__sheet-link">HVAC Market Insights</a>
    <a href="/tools" class="site-nav__sheet-link">HVAC Calculators</a>
    <a href="/report" class="site-nav__sheet-link">Local Market Report</a>
    <a href="/about" class="site-nav__sheet-link">Why Built on Tenth</a>
  </nav>
  <div class="site-nav__sheet-actions">
    <a href="/tools" class="site-nav__sheet-btn btn btn--ghost">Explore HVAC calculators</a>
    <a href="/report" class="site-nav__sheet-btn btn btn--primary">Request your report</a>
  </div>
</div>

<script>
  const menuBtn = document.getElementById('nav-menu-btn');
  const sheet = document.getElementById('mobile-sheet');
  const overlay = document.getElementById('mobile-overlay');

  function openMenu() {
    sheet?.classList.add('open');
    overlay?.classList.add('open');
    document.body.classList.add('nav-open');
  }

  function closeMenu() {
    sheet?.classList.remove('open');
    overlay?.classList.remove('open');
    document.body.classList.remove('nav-open');
  }

  menuBtn?.addEventListener('click', openMenu);
  overlay?.addEventListener('click', closeMenu);
  sheet?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeMenu();
  });
</script>
