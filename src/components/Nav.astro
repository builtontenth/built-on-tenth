---
const { active = '' } = Astro.props;
---
<nav id="nav">
  <a href="/" class="nav-logo">
    <div class="nav-logo-mark"></div>
    <span class="nav-logo-text">Built on Tenth</span>
  </a>
  <ul class="nav-links">
    <li><a href="/insights"   class={active === 'insights'   ? 'active' : ''}>Insights</a></li>
    <li><a href="/tools"      class={active === 'tools'      ? 'active' : ''}>Free Tools</a></li>
    <li><a href="/services"   class={active === 'services'   ? 'active' : ''}>Services</a></li>
    <li><a href="/about"      class={active === 'about'      ? 'active' : ''}>About</a></li>
    <li><a href="/newsletter" class={active === 'newsletter' ? 'active' : ''}>Newsletter</a></li>
  </ul>
  <div class="nav-right">
    <a href="/newsletter" class="nav-btn-ghost">Read Research</a>
    <a href="/apply"      class="nav-btn-teal">Get an Audit</a>
  </div>
</nav>

<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });
</script>
