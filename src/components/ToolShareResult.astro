---
interface Props {
  sectionId?: string;
  toolUrl?: string;
  profile?: 'internal' | 'mixed' | 'public';
  heading?: string;
}

const {
  sectionId = 'share-section',
  toolUrl = '',
  profile = 'internal',
  heading,
} = Astro.props;

const profileHeadings = {
  internal: 'Send this result',
  mixed: 'Share or send this result',
  public: 'Share this result',
};

const actionsByProfile = {
  internal: ['email', 'whatsapp', 'copy-summary'],
  mixed: ['email', 'whatsapp', 'linkedin', 'copy-summary'],
  public: ['linkedin', 'facebook', 'x', 'copy-post'],
} as const;

const actionLabels = {
  email: 'Email',
  whatsapp: 'WhatsApp',
  linkedin: 'LinkedIn',
  facebook: 'Facebook',
  x: 'X',
  'copy-summary': 'Copy Summary',
  'copy-post': 'Copy Post',
};

const actionIcons = {
  email: '@',
  whatsapp: 'WA',
  linkedin: 'in',
  facebook: 'f',
  x: 'X',
  'copy-summary': '[]',
  'copy-post': '[]',
};

const actions = actionsByProfile[profile];
const resolvedHeading = heading || profileHeadings[profile];
---
<div
  id={sectionId}
  class="tool-share"
  data-tool-share
  data-profile={profile}
  data-tool-url={toolUrl}
  data-public-share-text=""
  data-internal-share-text=""
  data-email-subject=""
  data-email-body=""
  hidden
>
  <div class="tool-share-heading">{resolvedHeading}</div>
  <div class="tool-share-actions">
    {actions.map((action) => (
      <button
        type="button"
        class="tool-share-btn"
        data-share-action={action}
        aria-label={actionLabels[action]}
      >
        <span class="tool-share-icon" aria-hidden="true">{actionIcons[action]}</span>
        <span data-share-label>{actionLabels[action]}</span>
      </button>
    ))}
  </div>
</div>


<script>
  function getShareUrl(container) {
    return container.dataset.toolUrl || window.location.href;
  }

  function getInternalShareText(container) {
    return container.dataset.internalShareText || getShareUrl(container);
  }

  function getPublicShareText(container) {
    return container.dataset.publicShareText || getShareUrl(container);
  }

  function getEmailSubject(container) {
    return container.dataset.emailSubject || 'Built on Tenth result';
  }

  function getEmailBody(container) {
    return container.dataset.emailBody || getInternalShareText(container);
  }

  async function copyText(button, text) {
    const label = button.querySelector('[data-share-label]');
    const originalLabel = label ? label.textContent : 'Copy';

    try {
      await navigator.clipboard.writeText(text);
      if (label) {
        label.textContent = 'Copied';
        window.setTimeout(() => {
          label.textContent = originalLabel;
        }, 2000);
      }
    } catch {
      window.prompt('Copy this text', text);
    }
  }

  function openShareWindow(url) {
    window.open(url, '_blank', 'noopener,noreferrer');
  }

  document.querySelectorAll('[data-tool-share]').forEach(container => {
    container.querySelectorAll('[data-share-action]').forEach(button => {
      button.addEventListener('click', () => {
        const action = button.dataset.shareAction;
        const shareUrl = getShareUrl(container);
        const publicShareText = getPublicShareText(container);
        const internalShareText = getInternalShareText(container);
        const emailSubject = getEmailSubject(container);
        const emailBody = getEmailBody(container);

        if (action === 'email') {
          window.location.href = `mailto:?subject=${encodeURIComponent(emailSubject)}&body=${encodeURIComponent(emailBody)}`;
          return;
        }

        if (action === 'whatsapp') {
          openShareWindow(`https://wa.me/?text=${encodeURIComponent(internalShareText)}`);
          return;
        }

        if (action === 'linkedin') {
          openShareWindow(`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`);
          return;
        }

        if (action === 'facebook') {
          openShareWindow(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`);
          return;
        }

        if (action === 'x') {
          openShareWindow(`https://twitter.com/intent/tweet?text=${encodeURIComponent(publicShareText)}`);
          return;
        }

        if (action === 'copy-summary') {
          copyText(button, internalShareText);
          return;
        }

        if (action === 'copy-post') {
          copyText(button, publicShareText);
        }
      });
    });
  });
</script>
