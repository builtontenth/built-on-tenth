{
  "$ref": "#/definitions/blog",
  "definitions": {
    "blog": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "pubDate": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "updatedDate": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "author": {
          "type": "string",
          "default": "Built on Tenth"
        },
        "category": {
          "type": "string",
          "enum": [
            "Revenue Diagnostics",
            "Pipeline Systems",
            "Channel Teardowns",
            "Growth Benchmarks",
            "Operator Case Studies"
          ]
        },
        "trade": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "HVAC",
              "Roofing",
              "Plumbing",
              "All"
            ]
          }
        },
        "heroImage": {
          "type": "string"
        },
        "heroImageAlt": {
          "type": "string"
        },
        "readTime": {
          "type": "number"
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "seoKeywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description",
        "pubDate",
        "category",
        "trade",
        "heroImage",
        "heroImageAlt",
        "readTime",
        "seoKeywords"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}