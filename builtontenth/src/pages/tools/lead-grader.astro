---
import Base from '../../layouts/Base.astro';
---
<Base title="Lead Source Grader for Home Service Companies | Built on Tenth" description="Grade your marketing channels against industry data. Find out which to keep, fix, or cut." solidNav={true}>
<section class="page-hero">
  <div class="breadcrumb"><a href="/">Home</a> / <a href="/tools">Tools</a> / Lead Source Grader</div>
  <h1>Grade Your <em>Lead Sources</em></h1>
  <p>Select your marketing channels. We grade each one against industry performance data and tell you where to put your next dollar.</p>
</section>
<style>
.gs{padding:4rem 2.5rem 5rem;background:var(--cream)}.gi{max-width:800px;margin:0 auto}
.gf{background:#fff;border-radius:16px;padding:2.5rem;box-shadow:0 4px 20px rgba(0,0,0,.06);border:1px solid var(--warm-gray);margin-bottom:2rem}
.gf h2{font-family:var(--font-display);font-size:1.3rem;font-weight:700;color:var(--navy);margin-bottom:.5rem}
.gf>p{font-size:.88rem;color:var(--text-light);margin-bottom:2rem}
.sg{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:2rem}
.so{display:flex;align-items:center;gap:.75rem;padding:.85rem 1rem;border:1.5px solid var(--warm-gray);border-radius:8px;cursor:pointer;transition:all .3s;user-select:none}
.so:hover{border-color:var(--amber)}.so.a{border-color:var(--amber);background:rgba(245,158,11,.06)}
.so .ck{width:20px;height:20px;border-radius:5px;border:2px solid var(--warm-gray);display:flex;align-items:center;justify-content:center;font-size:.7rem;color:#fff;flex-shrink:0;transition:all .3s}
.so.a .ck{background:var(--amber);border-color:var(--amber)}
.so span{font-size:.9rem;color:var(--text-dark);font-weight:500}
.calc-btn{width:100%;padding:1rem;background:var(--amber);color:var(--navy);border:none;border-radius:8px;font-family:var(--font-display);font-weight:700;font-size:1rem;cursor:pointer}
.gr{display:none}.gc{background:#fff;border-radius:12px;padding:1.5rem;margin-bottom:1rem;border:1px solid var(--warm-gray);display:flex;align-items:flex-start;gap:1.25rem}
.gb{width:48px;height:48px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:1.1rem;font-weight:800;color:#fff;flex-shrink:0}
.gA{background:#10b981}.gB{background:#f59e0b}.gC{background:#f97316}.gD{background:#ef4444}
.ginfo h3{font-family:var(--font-display);font-size:1rem;font-weight:700;color:var(--navy);margin-bottom:.3rem}
.ginfo .vd{font-size:.82rem;font-weight:600;margin-bottom:.4rem}
.vd.keep{color:#10b981}.vd.opt{color:#d97706}.vd.eval{color:#f97316}
.ginfo p{font-size:.85rem;color:var(--text-mid);line-height:1.55}
.gcta{background:var(--navy);border-radius:16px;padding:2rem;margin-top:2rem}
.gcta-inner{display:flex;align-items:center;justify-content:space-between;gap:1.5rem;flex-wrap:wrap}
.gcta h3{font-family:var(--font-display);font-size:1.1rem;font-weight:700;color:#fff;margin-bottom:.3rem}
.gcta p{color:rgba(255,255,255,.5);font-size:.85rem}
.gate-email{display:flex;gap:.5rem;margin-top:1.5rem}
.gate-email input{flex:1;padding:.75rem 1rem;border:1px solid rgba(255,255,255,.15);border-radius:8px;background:rgba(255,255,255,.05);color:#fff;font-family:var(--font-body);font-size:.88rem;outline:none}
.gate-email input::placeholder{color:rgba(255,255,255,.3)}
.gate-email button{padding:.75rem 1.25rem;background:var(--amber);color:var(--navy);border:none;border-radius:8px;font-family:var(--font-display);font-weight:700;font-size:.82rem;cursor:pointer;white-space:nowrap}
@media(max-width:768px){.gs{padding:2rem 1.5rem 3rem}.sg{grid-template-columns:1fr}.gate-email{flex-direction:column}}
</style>

<section class="gs"><div class="gi">
  <div class="gf">
    <h2>Which lead sources do you currently use?</h2><p>Select all that apply. We will grade each one.</p>
    <div class="sg">
      <div class="so" data-s="google_ads" onclick="this.classList.toggle('a')"><div class="ck">&#10003;</div><span>Google Ads (PPC)</span></div>
      <div class="so" data-s="lsa" onclick="this.classList.toggle('a')"><div class="ck">&#10003;</div><span>Local Service Ads</span></div>
      <div class="so" data-s="seo" onclick="this.classList.toggle('a')"><div class="ck">&#10003;</div><span>SEO / Organic Search</span></div>
      <div class="so" data-s="gbp" onclick="this.classList.toggle('a')"><div class="ck">&#10003;</div><span>Google Business Profile</span></div>
      <div class="so" data-s="angi" onclick="this.classList.toggle('a')"><div class="ck">&#10003;</div><span>Angi / HomeAdvisor</span></div>
      <div class="so" data-s="thumbtack" onclick="this.classList.toggle('a')"><div class="ck">&#10003;</div><span>Thumbtack</span></div>
      <div class="so" data-s="referrals" onclick="this.classList.toggle('a')"><div class="ck">&#10003;</div><span>Referrals / Word of Mouth</span></div>
      <div class="so" data-s="social" onclick="this.classList.toggle('a')"><div class="ck">&#10003;</div><span>Social Media Ads</span></div>
      <div class="so" data-s="directmail" onclick="this.classList.toggle('a')"><div class="ck">&#10003;</div><span>Direct Mail</span></div>
      <div class="so" data-s="doorknock" onclick="this.classList.toggle('a')"><div class="ck">&#10003;</div><span>Door Knocking</span></div>
    </div>
    <button class="calc-btn" onclick="grade()">Grade My Lead Sources &#8594;</button>
  </div>
  <div class="gr" id="gr"></div>
</div></section>

<script is:inline>
const D={google_ads:{n:'Google Ads (PPC)',g:'B',v:'opt',vt:'Optimize \u2014 high potential but most companies waste 30%+',d:'High-intent channel. Without conversion tracking and negative keywords, most companies waste 25-40% of spend. Fix tracking first, then optimize.'},lsa:{n:'Local Service Ads',g:'A',v:'keep',vt:'Double down \u2014 best cost-per-lead in most markets',d:'Consistently lowest cost per lead. Google Guaranteed badge builds instant trust. Reviews and response speed directly impact your ranking.'},seo:{n:'SEO / Organic Search',g:'A',v:'keep',vt:'Keep investing \u2014 highest long-term ROI',d:'Lowest cost per lead over time since traffic is free once you rank. Takes 6-12 months but compounds indefinitely.'},gbp:{n:'Google Business Profile',g:'A',v:'keep',vt:'Essential \u2014 optimize aggressively',d:'Your single most important marketing asset. Companies with 100+ reviews and weekly activity consistently outperform competitors with bigger ad budgets.'},angi:{n:'Angi / HomeAdvisor',g:'C',v:'eval',vt:'Evaluate \u2014 shared leads with declining ROI',d:'Shared to 3-5 contractors. Close rates typically 10-18%. Cost per booked job often exceeds $500-800. Consider reallocating this budget to channels you own.'},thumbtack:{n:'Thumbtack',g:'C',v:'eval',vt:'Evaluate \u2014 works for small jobs only',d:'Reasonable for low-ticket repairs. For high-ticket installs and replacements, the ROI is typically poor compared to Google channels.'},referrals:{n:'Referrals / Word of Mouth',g:'A',v:'keep',vt:'Best channel \u2014 systematize it',d:'Highest close rate (50-70%) and zero acquisition cost. Most companies leave this to luck. Build a system: post-job referral ask, review requests, past-customer reactivation campaigns.'},social:{n:'Social Media Ads',g:'B',v:'opt',vt:'Optimize \u2014 effective for retargeting only',d:'Facebook and Instagram rarely produce high-intent leads when targeting cold audiences. Where they work well is retargeting people who already visited your website.'},directmail:{n:'Direct Mail',g:'B',v:'opt',vt:'Strong when targeted to the right neighborhoods',d:'Works when sent to neighborhoods with aging homes and systems. Track with unique phone numbers or landing page URLs. Without tracking, you are guessing.'},doorknock:{n:'Door Knocking',g:'B',v:'opt',vt:'Effective post-storm, expensive otherwise',d:'High labor cost per lead. Best after storm events or in specific neighborhoods. Invest in inbound channels that work while your team is on jobs.'}};
function grade(){const s=document.querySelectorAll('.so.a');if(!s.length)return;const o={A:0,B:1,C:2,D:3},sorted=[...s].sort((a,b)=>o[D[a.dataset.s].g]-o[D[b.dataset.s].g]);
let h='';sorted.forEach(e=>{const d=D[e.dataset.s];h+='<div class="gc reveal"><div class="gb g'+d.g+'">'+d.g+'</div><div class="ginfo"><h3>'+d.n+'</h3><div class="vd '+d.v+'">'+d.vt+'</div><p>'+d.d+'</p></div></div>';});
h+='<div class="gcta"><div><h3 style="font-family:var(--font-display);font-size:1.1rem;font-weight:700;color:#fff">Get your full Lead Source Optimization Report</h3><p style="color:rgba(255,255,255,.5);font-size:.85rem">Detailed analysis for each channel with specific budget reallocation recommendations and ROI projections.</p><div class="gate-email"><input type="email" id="graderEmail" placeholder="Enter your email"><button onclick="this.textContent='Sent! \u2713';this.style.background='#10b981'">Send My Report</button></div></div></div>';
h+='<div style="text-align:center;margin-top:1.5rem"><a href="/services#audit" class="btn-primary">Get a Full Revenue Leak Audit \u2014 $750 &#8594;</a></div>';
const el=document.getElementById('gr');el.innerHTML=h;el.style.display='block';el.scrollIntoView({behavior:'smooth'});el.querySelectorAll('.reveal').forEach((r,i)=>setTimeout(()=>r.classList.add('visible'),i*100));}
</script>
</Base>
